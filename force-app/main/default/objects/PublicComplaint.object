<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <fields>
        <fullName>Method_of_Submission__c</fullName>
        <description>Method used to submit the comment.</description>
        <inlineHelpText>How the comment was submitted (online, email, mail, or in-person).</inlineHelpText>
        <label>Method of Submission</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Online</fullName>
                    <default>false</default>
                    <label>Online</label>
                </value>
                <value>
                    <fullName>Email</fullName>
                    <default>false</default>
                    <label>Email</label>
                </value>
                <value>
                    <fullName>Mail</fullName>
                    <default>false</default>
                    <label>Mail</label>
                </value>
                <value>
                    <fullName>In-Person</fullName>
                    <default>false</default>
                    <label>In-Person</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_agency_response__c</fullName>
        <description>Formal reply from the agency, if applicable.</description>
        <inlineHelpText>Formal agency reply to this comment, if applicable.</inlineHelpText>
        <label>Agency Response</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>5</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_public_access__c</fullName>
        <description>Public access level for the comment.</description>
        <inlineHelpText>Public (externally visible) or Internal (agency only).</inlineHelpText>
        <label>Public Access</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Public</fullName>
                    <default>false</default>
                    <label>Public</label>
                </value>
                <value>
                    <fullName>Internal</fullName>
                    <default>false</default>
                    <label>Internal</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <!-- CEQ Standard v1.2 additions -->
    <fields>
        <fullName>nepa_parent_document__c</fullName>
        <description>ContentDocumentId of the NEPA document this comment relates to (e.g., a Draft EIS). Stored as Text because Salesforce does not permit Lookup fields targeting ContentDocument/ContentVersion. Per CEQ standard Figure 1, comments are children of documents.</description>
        <inlineHelpText>ContentDocumentId of the NEPA document (e.g., Draft EIS) this comment was submitted in response to.</inlineHelpText>
        <externalId>false</externalId>
        <label>Related Document ID</label>
        <length>18</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_organization__c</fullName>
        <description>Optional organization affiliation of the commenter.</description>
        <inlineHelpText>Organization or affiliation of the commenter (optional).</inlineHelpText>
        <externalId>false</externalId>
        <label>Organization</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_category__c</fullName>
        <description>Optional category to organize types of comments or to tag comments based on the topics addressed in the comment. Supports AI-assisted comment analysis.</description>
        <inlineHelpText>Topic category or tag for this comment (supports automated comment analysis).</inlineHelpText>
        <externalId>false</externalId>
        <label>Comment Category</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_date_submitted__c</fullName>
        <description>Date the comment was submitted. Verify whether the standard PSS PublicComplaint object has a native date field before using this custom field.</description>
        <inlineHelpText>Date this comment was submitted.</inlineHelpText>
        <label>Date Submitted</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>nepa_document_location_ref__c</fullName>
        <description>If applicable, the part of the document being referenced by the comment (e.g., section number, page number, or paragraph reference).</description>
        <inlineHelpText>Section, page, or paragraph of the document this comment addresses.</inlineHelpText>
        <externalId>false</externalId>
        <label>Document Location Reference</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_public_source__c</fullName>
        <description>Indicates whether this comment was submitted from a public source (vs. internal agency use).</description>
        <inlineHelpText>Check if this comment was submitted from a public source.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Public Source</label>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
    <!-- Priority 1: AI-Assisted Comment Analysis fields -->
    <fields>
        <fullName>nepa_sentiment__c</fullName>
        <description>AI-assigned sentiment classification for this comment.</description>
        <inlineHelpText>Sentiment of this comment as classified by AI analysis (human-validated).</inlineHelpText>
        <externalId>false</externalId>
        <label>Sentiment</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Supportive</fullName>
                    <default>false</default>
                    <label>Supportive</label>
                </value>
                <value>
                    <fullName>Neutral</fullName>
                    <default>false</default>
                    <label>Neutral</label>
                </value>
                <value>
                    <fullName>Opposed</fullName>
                    <default>false</default>
                    <label>Opposed</label>
                </value>
                <value>
                    <fullName>Mixed</fullName>
                    <default>false</default>
                    <label>Mixed</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_is_substantive__c</fullName>
        <description>Indicates whether this comment is substantive and requires an individual agency response. AI-assigned, human-validated.</description>
        <inlineHelpText>Check if this comment is substantive and requires an individual response per NEPA requirements.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Is Substantive</label>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_cluster_id__c</fullName>
        <description>Groups near-duplicate form-letter comments for unified response. AI-assigned cluster identifier.</description>
        <inlineHelpText>Cluster ID grouping near-duplicate form letters for consolidated response tracking.</inlineHelpText>
        <externalId>false</externalId>
        <label>Cluster ID</label>
        <length>50</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_response_status__c</fullName>
        <description>Tracks the lifecycle of the agency response for this comment from draft through final.</description>
        <inlineHelpText>Current status of the agency response for this comment.</inlineHelpText>
        <externalId>false</externalId>
        <label>Response Status</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Pending</fullName>
                    <default>true</default>
                    <label>Pending</label>
                </value>
                <value>
                    <fullName>Draft</fullName>
                    <default>false</default>
                    <label>Draft</label>
                </value>
                <value>
                    <fullName>Reviewed</fullName>
                    <default>false</default>
                    <label>Reviewed</label>
                </value>
                <value>
                    <fullName>Finalized</fullName>
                    <default>false</default>
                    <label>Finalized</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <!-- Provenance fields (CEQ Standard v1.2 - required on all entities) -->
    <fields>
        <fullName>nepa_data_record_version__c</fullName>
        <description>The version of the record, for tracking updates or changes to the data.</description>
        <inlineHelpText>Version of this record for data exchange tracking.</inlineHelpText>
        <externalId>false</externalId>
        <label>Data Record Version</label>
        <length>50</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_data_source_agency__c</fullName>
        <description>The name of the agency or organization that provided the data.</description>
        <inlineHelpText>Agency or organization that provided this data.</inlineHelpText>
        <externalId>false</externalId>
        <label>Data Source Agency</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_data_source_system__c</fullName>
        <description>The system or database where the data originally came from.</description>
        <inlineHelpText>Source system or database for this record.</inlineHelpText>
        <externalId>false</externalId>
        <label>Data Source System</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_record_owner_agency__c</fullName>
        <description>The agency responsible for maintaining or owning this record.</description>
        <inlineHelpText>Agency responsible for owning and maintaining this record.</inlineHelpText>
        <externalId>false</externalId>
        <label>Record Owner Agency</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_retrieved_timestamp__c</fullName>
        <description>The date and time when this record was retrieved from its source.</description>
        <inlineHelpText>Date and time this record was retrieved from its source system.</inlineHelpText>
        <label>Retrieved Timestamp</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>DateTime</type>
    </fields>
    <!-- Portal submission fields -->
    <fields>
        <fullName>nepa_comment_body__c</fullName>
        <description>Full text of the public comment submitted via the portal or other channel.</description>
        <inlineHelpText>Full text of this public comment.</inlineHelpText>
        <label>Comment Body</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>8</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_email__c</fullName>
        <description>Email address of the commenter, collected only when they opt in to receive notifications.</description>
        <inlineHelpText>Commenter email for notification opt-in (collected only with consent).</inlineHelpText>
        <externalId>false</externalId>
        <label>Commenter Email</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Email</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_pii_redacted__c</fullName>
        <description>Set to true once PII has been reviewed and the redacted body has been populated. Gates portal visibility — Experience Cloud users see only nepa_redacted_body__c when this is true.</description>
        <inlineHelpText>Check after completing PII review and populating the redacted body field.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>PII Redacted</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_redacted_body__c</fullName>
        <description>Portal-safe version of the comment body with PII removed. Displayed to Experience Cloud public portal users. Populated by staff after PII review. Left blank until nepa_pii_redacted__c is set to true.</description>
        <inlineHelpText>Enter the PII-redacted version of the comment body for public portal display.</inlineHelpText>
        <label>Redacted Comment Body</label>
        <length>32768</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>8</visibleLines>
    </fields>
    <!-- AI Triage Audit Trail fields (OMB M-24-10) -->
    <fields>
        <fullName>nepa_ai_confidence_score__c</fullName>
        <description>Confidence score (0–100) returned by the Agentforce Comment Triage Agent. Values below 60 should trigger human review.</description>
        <inlineHelpText>AI confidence score 0–100. Lower scores indicate uncertain classifications.</inlineHelpText>
        <label>AI Confidence Score</label>
        <precision>5</precision>
        <required>false</required>
        <scale>2</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_ai_triage_rationale__c</fullName>
        <description>1–2 sentence rationale written by the AI when marking a comment non-substantive, explaining the NEPA criteria that led to that determination. Mandatory when nepa_is_substantive__c = false.</description>
        <inlineHelpText>AI explanation of substantive/non-substantive determination. Required when non-substantive.</inlineHelpText>
        <label>AI Triage Rationale</label>
        <length>4000</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>5</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_requires_human_review__c</fullName>
        <description>Set to true by the EJ detector gate when the comment mentions tribal sovereignty, sacred sites, environmental justice communities, low-income impact, or civil rights. Bypasses AI categorization and routes to a human EJ/Tribal Liaison coordinator.</description>
        <inlineHelpText>Flagged for mandatory human review. Set automatically when EJ/tribal/civil-rights triggers are detected.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Requires Human Review</label>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_human_override__c</fullName>
        <description>Set to true by a human reviewer when they override the AI's substantive/sentiment classification. Enables systematic measurement of AI bias patterns by zip code, commenter type, or project.</description>
        <inlineHelpText>Check if a human reviewer has overridden the AI classification.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Human Override Applied</label>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_ai_triage_timestamp__c</fullName>
        <description>Date and time the Agentforce Comment Triage Agent completed its analysis. Used for audit trail and performance monitoring.</description>
        <inlineHelpText>When AI triage was completed.</inlineHelpText>
        <label>AI Triage Timestamp</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>DateTime</type>
    </fields>

    <!-- Mandate 1: Comment period kill-switch — lookup to parent IA for server-side gate -->
    <fields>
        <fullName>nepa_related_process__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Lookup to the IndividualApplication (NEPA process) this comment was submitted against. Required for the NEPA_Comment_Period_Gate before-save flow and the NEPA_Comment_Period_Closed validation rule to enforce exact-minute comment period deadlines without human admin intervention.</description>
        <inlineHelpText>The NEPA process (IndividualApplication) this comment responds to. Set by the portal OmniScript on submission.</inlineHelpText>
        <label>Related NEPA Process</label>
        <referenceTo>IndividualApplication</referenceTo>
        <relationshipLabel>Public Comments</relationshipLabel>
        <relationshipName>Public_Comments</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <!-- Issue exhaustion / litigation threat fields (Vermont Yankee doctrine — Mandate 2) -->
    <fields>
        <fullName>nepa_litigation_threat_flag__c</fullName>
        <description>True when the AI Triage Agent has identified this comment as a potential "issue exhaustion" comment under the Vermont Yankee doctrine. These are technically specific, legally precise objections that may be setting up a future APA lawsuit. Flagged comments must be routed to agency legal counsel for a substantive written response in the Final EIS — failure to respond may result in vacatur. Set by NEPA_Comment_Triage Agent; human-reviewable via nepa_legal_review_status__c.</description>
        <inlineHelpText>AI flagged this comment as a potential Vermont Yankee issue exhaustion comment. Route to legal counsel for required written response.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Litigation Threat Flag</label>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_litigation_threat_basis__c</fullName>
        <description>AI-generated explanation of why this comment was flagged as a potential Vermont Yankee issue exhaustion comment. Should identify: the specific legal or technical standard cited, the specific inadequacy alleged, and why this rises to the level of a legally specific objection rather than a general substantive concern. Written by the NEPA_Comment_Triage Agent alongside the flag.</description>
        <inlineHelpText>AI explanation of the litigation threat: what legal/technical standard was cited, what inadequacy was alleged, and why this may set up a future APA challenge.</inlineHelpText>
        <label>Litigation Threat Basis</label>
        <length>32768</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>5</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_legal_review_status__c</fullName>
        <description>Legal counsel review status for litigation-threat-flagged comments. Pending Legal Review: flagged, not yet assigned. Assigned to Counsel: routed to a specific attorney. Legal Response Drafted: attorney has drafted a response for inclusion in the Final EIS comment response chapter. Response Finalized: response included in the published Final EIS. No Action Required: counsel determined this does not require a specific response.</description>
        <inlineHelpText>Legal review status for litigation-threat-flagged comments. Required response workflow — flagged comments must reach Response Finalized before Final EIS publication.</inlineHelpText>
        <label>Legal Review Status</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Pending Legal Review</fullName><default>false</default><label>Pending Legal Review</label></value>
                <value><fullName>Assigned to Counsel</fullName><default>false</default><label>Assigned to Counsel</label></value>
                <value><fullName>Legal Response Drafted</fullName><default>false</default><label>Legal Response Drafted</label></value>
                <value><fullName>Response Finalized</fullName><default>false</default><label>Response Finalized</label></value>
                <value><fullName>No Action Required</fullName><default>false</default><label>No Action Required</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_ai_substantive_recommendation__c</fullName>
        <description>AI-generated substantive determination written by the Comment Triage Agent. Read-only — do not edit. Human reviewers use nepa_is_substantive__c (human-only) to record the official determination. Separation required by OMB M-24-10: AI recommendations must not directly constitute adverse actions.</description>
        <inlineHelpText>AI recommendation only. Official determination is in Is Substantive (human-set).</inlineHelpText>
        <label>AI Substantive Recommendation</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Substantive</fullName><default>false</default><label>Substantive</label></value>
                <value><fullName>Non-Substantive</fullName><default>false</default><label>Non-Substantive</label></value>
                <value><fullName>Uncertain</fullName><default>false</default><label>Uncertain</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_other__c</fullName>
        <description>Extension bag for agency-specific or non-standard properties. Stores arbitrary JSON for interoperability with systems that require fields beyond the CEQ standard schema. Maps to the CEQ standard comment.other (jsonb) property.</description>
        <inlineHelpText>JSON extension bag for additional properties not covered by the standard schema.</inlineHelpText>
        <label>Other (JSON)</label>
        <length>32768</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>2</visibleLines>
    </fields>
    <validationRules>
        <fullName>NEPA_Comment_Period_Closed</fullName>
        <active>true</active>
        <description>Blocks new comments after the comment period end date. ISNEW() guard allows flows to update existing records post-deadline. Fail-open: missing lookup or end date allows insert.</description>
        <errorConditionFormula>AND(
  ISNEW(),
  NOT(ISBLANK(nepa_related_process__c)),
  NOT(ISBLANK(nepa_related_process__r.nepa_public_comment_period_end_date__c)),
  nepa_related_process__r.nepa_public_comment_period_end_date__c &lt; NOW()
)</errorConditionFormula>
        <errorMessage>The public comment period for this NEPA process has closed. Comments submitted after the deadline cannot be accepted.</errorMessage>
    </validationRules>
</CustomObject>
