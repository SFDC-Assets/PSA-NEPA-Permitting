<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <fields>
        <fullName>Method_of_Submission__c</fullName>
        <description>Method used to submit the comment.</description>
        <inlineHelpText>How the comment was submitted (online, email, mail, or in-person).</inlineHelpText>
        <label>Method of Submission</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Online</fullName>
                    <default>false</default>
                    <label>Online</label>
                </value>
                <value>
                    <fullName>Email</fullName>
                    <default>false</default>
                    <label>Email</label>
                </value>
                <value>
                    <fullName>Mail</fullName>
                    <default>false</default>
                    <label>Mail</label>
                </value>
                <value>
                    <fullName>In-Person</fullName>
                    <default>false</default>
                    <label>In-Person</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_agency_response__c</fullName>
        <description>Formal reply from the agency, if applicable.</description>
        <inlineHelpText>Formal agency reply to this comment, if applicable.</inlineHelpText>
        <label>Agency Response</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>5</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_public_access__c</fullName>
        <description>Public access level for the comment.</description>
        <inlineHelpText>Public (externally visible) or Internal (agency only).</inlineHelpText>
        <label>Public Access</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Public</fullName>
                    <default>false</default>
                    <label>Public</label>
                </value>
                <value>
                    <fullName>Internal</fullName>
                    <default>false</default>
                    <label>Internal</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <!-- CEQ Standard v1.2 additions -->
    <fields>
        <fullName>nepa_parent_document__c</fullName>
        <description>ContentDocumentId of the NEPA document this comment relates to (e.g., a Draft EIS). Stored as Text because Salesforce does not permit Lookup fields targeting ContentDocument/ContentVersion. Per CEQ standard Figure 1, comments are children of documents.</description>
        <inlineHelpText>ContentDocumentId of the NEPA document (e.g., Draft EIS) this comment was submitted in response to.</inlineHelpText>
        <externalId>false</externalId>
        <label>Related Document ID</label>
        <length>18</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_organization__c</fullName>
        <description>Optional organization affiliation of the commenter.</description>
        <inlineHelpText>Organization or affiliation of the commenter (optional).</inlineHelpText>
        <externalId>false</externalId>
        <label>Organization</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_category__c</fullName>
        <description>Optional category to organize types of comments or to tag comments based on the topics addressed in the comment. Supports AI-assisted comment analysis.</description>
        <inlineHelpText>Topic category or tag for this comment (supports automated comment analysis).</inlineHelpText>
        <externalId>false</externalId>
        <label>Comment Category</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_date_submitted__c</fullName>
        <description>Date the comment was submitted. Verify whether the standard PSS PublicComplaint object has a native date field before using this custom field.</description>
        <inlineHelpText>Date this comment was submitted.</inlineHelpText>
        <label>Date Submitted</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>nepa_document_location_ref__c</fullName>
        <description>If applicable, the part of the document being referenced by the comment (e.g., section number, page number, or paragraph reference).</description>
        <inlineHelpText>Section, page, or paragraph of the document this comment addresses.</inlineHelpText>
        <externalId>false</externalId>
        <label>Document Location Reference</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_public_source__c</fullName>
        <description>Indicates whether this comment was submitted from a public source (vs. internal agency use).</description>
        <inlineHelpText>Check if this comment was submitted from a public source.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Public Source</label>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
    <!-- Priority 1: AI-Assisted Comment Analysis fields -->
    <fields>
        <fullName>nepa_sentiment__c</fullName>
        <description>AI-assigned sentiment classification for this comment.</description>
        <inlineHelpText>Sentiment of this comment as classified by AI analysis (human-validated).</inlineHelpText>
        <externalId>false</externalId>
        <label>Sentiment</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Supportive</fullName>
                    <default>false</default>
                    <label>Supportive</label>
                </value>
                <value>
                    <fullName>Neutral</fullName>
                    <default>false</default>
                    <label>Neutral</label>
                </value>
                <value>
                    <fullName>Opposed</fullName>
                    <default>false</default>
                    <label>Opposed</label>
                </value>
                <value>
                    <fullName>Mixed</fullName>
                    <default>false</default>
                    <label>Mixed</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_is_substantive__c</fullName>
        <description>Indicates whether this comment is substantive and requires an individual agency response. AI-assigned, human-validated.</description>
        <inlineHelpText>Check if this comment is substantive and requires an individual response per NEPA requirements.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Is Substantive</label>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_cluster_id__c</fullName>
        <description>Groups near-duplicate form-letter comments for unified response. AI-assigned cluster identifier.</description>
        <inlineHelpText>Cluster ID grouping near-duplicate form letters for consolidated response tracking.</inlineHelpText>
        <externalId>false</externalId>
        <label>Cluster ID</label>
        <length>50</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_response_status__c</fullName>
        <description>Tracks the lifecycle of the agency response for this comment from draft through final.</description>
        <inlineHelpText>Current status of the agency response for this comment.</inlineHelpText>
        <externalId>false</externalId>
        <label>Response Status</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Pending</fullName>
                    <default>true</default>
                    <label>Pending</label>
                </value>
                <value>
                    <fullName>Draft</fullName>
                    <default>false</default>
                    <label>Draft</label>
                </value>
                <value>
                    <fullName>Reviewed</fullName>
                    <default>false</default>
                    <label>Reviewed</label>
                </value>
                <value>
                    <fullName>Finalized</fullName>
                    <default>false</default>
                    <label>Finalized</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <!-- Provenance fields (CEQ Standard v1.2 - required on all entities) -->
    <fields>
        <fullName>nepa_data_record_version__c</fullName>
        <description>The version of the record, for tracking updates or changes to the data.</description>
        <inlineHelpText>Version of this record for data exchange tracking.</inlineHelpText>
        <externalId>false</externalId>
        <label>Data Record Version</label>
        <length>50</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_data_source_agency__c</fullName>
        <description>The name of the agency or organization that provided the data.</description>
        <inlineHelpText>Agency or organization that provided this data.</inlineHelpText>
        <externalId>false</externalId>
        <label>Data Source Agency</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_data_source_system__c</fullName>
        <description>The system or database where the data originally came from.</description>
        <inlineHelpText>Source system or database for this record.</inlineHelpText>
        <externalId>false</externalId>
        <label>Data Source System</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_record_owner_agency__c</fullName>
        <description>The agency responsible for maintaining or owning this record.</description>
        <inlineHelpText>Agency responsible for owning and maintaining this record.</inlineHelpText>
        <externalId>false</externalId>
        <label>Record Owner Agency</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_retrieved_timestamp__c</fullName>
        <description>The date and time when this record was retrieved from its source.</description>
        <inlineHelpText>Date and time this record was retrieved from its source system.</inlineHelpText>
        <label>Retrieved Timestamp</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>DateTime</type>
    </fields>
    <!-- Portal submission fields -->
    <fields>
        <fullName>nepa_comment_body__c</fullName>
        <description>Full text of the public comment submitted via the portal or other channel.</description>
        <inlineHelpText>Full text of this public comment.</inlineHelpText>
        <label>Comment Body</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>8</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_email__c</fullName>
        <description>Email address of the commenter, collected only when they opt in to receive notifications.</description>
        <inlineHelpText>Commenter email for notification opt-in (collected only with consent).</inlineHelpText>
        <externalId>false</externalId>
        <label>Commenter Email</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Email</type>
        <unique>false</unique>
    </fields>
</CustomObject>
