    <fields>
        <fullName>Agency__c</fullName>
        <deleteConstraint>Restrict</deleteConstraint>
        <description>The federal agency involved in this permitting application process</description>
        <inlineHelpText>The federal agency involved in this permitting application process</inlineHelpText>
        <label>Agency</label>
        <referenceTo>Account</referenceTo>
        <relationshipName>nepa_permit_application_agencies</relationshipName>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>Processes__c</fullName>
        <description>The NEPA application process this agency is involved in</description>
        <inlineHelpText>The NEPA application process this agency is involved in</inlineHelpText>
        <label>Process</label>
        <referenceTo>IndividualApplication</referenceTo>
        <relationshipLabel>Related Agencies</relationshipLabel>
        <relationshipName>Process_Agency_Relationships</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <reparentableMasterDetail>false</reparentableMasterDetail>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>false</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>nepa_role__c</fullName>
        <description>What is the type of relationship this agency has to this permitting process?</description>
        <inlineHelpText>What is the type of relationship this agency has to this permitting process?</inlineHelpText>
        <label>Role</label>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Cooperating</fullName>
                    <default>false</default>
                    <label>Cooperating</label>
                </value>
                <value>
                    <fullName>Participating</fullName>
                    <default>false</default>
                    <label>Participating</label>
                </value>
                <value>
                    <fullName>Proponent</fullName>
                    <default>false</default>
                    <label>Proponent</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_input_due_date__c</fullName>
        <description>Deadline by which this agency must submit their formal input (e.g., biological opinion, Section 106 letter, Water Quality Certification). Used by Priority 7 Interagency Coordination Hub.</description>
        <inlineHelpText>Deadline for this agency's formal input submission.</inlineHelpText>
        <label>Input Due Date</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>nepa_input_status__c</fullName>
        <description>Status of this agency's formal input submission. Used by Priority 7 Interagency Coordination Hub for task tracking.</description>
        <inlineHelpText>Submission status of this agency's formal input.</inlineHelpText>
        <label>Input Status</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Pending</fullName>
                    <default>true</default>
                    <label>Pending</label>
                </value>
                <value>
                    <fullName>In Progress</fullName>
                    <default>false</default>
                    <label>In Progress</label>
                </value>
                <value>
                    <fullName>Submitted</fullName>
                    <default>false</default>
                    <label>Submitted</label>
                </value>
                <value>
                    <fullName>Accepted</fullName>
                    <default>false</default>
                    <label>Accepted</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <label>Process Agency Relationship</label>
    <nameField>
        <displayFormat>PA-{00000000}</displayFormat>
        <label>Process Agency Relationship Name</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Process Agency Relationships</pluralLabel>
    <searchLayouts/>
    <sharingModel>ControlledByParent</sharingModel>
    <visibility>Public</visibility>
</CustomObject>
