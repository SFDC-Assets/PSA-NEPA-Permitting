<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>nepa_sensitivity_classification__c</fullName>
    <description>CUI sensitivity classification for this GIS dataset. Controls visibility to external parties. Aligns with NARA CUI registry categories.</description>
    <inlineHelpText>Controlled Unclassified Information classification. Set to indicate restricted access to sensitive GIS layers (e.g., tribal sacred sites, critical infrastructure).</inlineHelpText>
    <label>Sensitivity Classification</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Unclassified</fullName>
                <default>true</default>
                <label>Unclassified</label>
            </value>
            <value>
                <fullName>CUI</fullName>
                <default>false</default>
                <label>CUI</label>
            </value>
            <value>
                <fullName>CUI//FEDONLY</fullName>
                <default>false</default>
                <label>CUI//FEDONLY</label>
            </value>
            <value>
                <fullName>CUI//SP-TRIBAL</fullName>
                <default>false</default>
                <label>CUI//SP-TRIBAL</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
