<?xml version='1.0' encoding='UTF-8'?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata"><fullName>nepa_sponsor_type__c</fullName>
        <description>Sponsor entity type enum. Addresses NEPATEC sponsor field noise: private companies, BLM field offices, and individuals were mixed without a type discriminator, reducing the sponsor feature's lift from the expected 0.61 to lower in practice. CE screening uses this for confidence modifiers (Operator → Energy CE likely; Government → check agency CE namespace).</description>
        <inlineHelpText>Type of project sponsor entity. Used by CE Screener as a routing confidence modifier.</inlineHelpText>
        <label>Sponsor Type</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Operator</fullName><default>false</default><label>Operator (Oil/Gas/Mining/Utility)</label></value>
                <value><fullName>Utility</fullName><default>false</default><label>Utility (Electric/Water/Telecom)</label></value>
                <value><fullName>Government</fullName><default>false</default><label>Government (Federal/State/Local)</label></value>
                <value><fullName>Individual</fullName><default>false</default><label>Individual / Private Person</label></value>
                <value><fullName>Tribe</fullName><default>false</default><label>Tribal Nation / Tribal Entity</label></value>
                <value><fullName>NGO</fullName><default>false</default><label>Non-Governmental Organization (NGO)</label></value>
            </valueSetDefinition>
        </valueSet>
    </CustomField>