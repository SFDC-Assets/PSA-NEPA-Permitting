    <deploymentStatus>Deployed</deploymentStatus>
    <description>Structured record of each dependent federal permit required by a NEPA process. One record per permit. Used by the cross-agency permit dependency LWC to fetch live status from other agencies' NEPA REST APIs. Maps to the CEQ Permits entity.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>ControlledByParent</externalSharingModel>
    <fields>
        <fullName>nepa_process__c</fullName>
        <description>The NEPA process (IndividualApplication) that requires this permit. Master-detail — deleting the process deletes all dependent permit records.</description>
        <inlineHelpText>The NEPA review process that requires this permit from another agency.</inlineHelpText>
        <label>Process</label>
        <referenceTo>IndividualApplication</referenceTo>
        <relationshipLabel>Required Permits</relationshipLabel>
        <relationshipName>Required_Permits</relationshipName>
        <relationshipOrder>0</relationshipOrder>
        <reparentableMasterDetail>false</reparentableMasterDetail>
        <trackTrending>false</trackTrending>
        <type>MasterDetail</type>
        <writeRequiresMasterRead>false</writeRequiresMasterRead>
    </fields>
    <fields>
        <fullName>nepa_permit_type__c</fullName>
        <description>Type of federal permit or authorization required. Based on statutory authority.</description>
        <inlineHelpText>The type of permit or authorization this record tracks.</inlineHelpText>
        <label>Permit Type</label>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>true</sorted>
                <value>
                    <fullName>BLM Right-of-Way</fullName>
                    <default>false</default>
                    <label>BLM Right-of-Way</label>
                </value>
                <value>
                    <fullName>CWA Section 401 Water Quality Certification</fullName>
                    <default>false</default>
                    <label>CWA Section 401 Water Quality Certification</label>
                </value>
                <value>
                    <fullName>CWA Section 404 Permit</fullName>
                    <default>false</default>
                    <label>CWA Section 404 Permit</label>
                </value>
                <value>
                    <fullName>ESA Section 7 Consultation</fullName>
                    <default>false</default>
                    <label>ESA Section 7 Consultation</label>
                </value>
                <value>
                    <fullName>FERC Certificate</fullName>
                    <default>false</default>
                    <label>FERC Certificate</label>
                </value>
                <value>
                    <fullName>NHPA Section 106 Consultation</fullName>
                    <default>false</default>
                    <label>NHPA Section 106 Consultation</label>
                </value>
                <value>
                    <fullName>Other</fullName>
                    <default>false</default>
                    <label>Other</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_lead_agency__c</fullName>
        <description>Federal agency responsible for issuing this permit. Must have a corresponding active NEPA_Agency_Endpoint__mdt record if live status lookup is desired.</description>
        <inlineHelpText>The federal agency issuing this permit.</inlineHelpText>
        <label>Lead Agency</label>
        <required>true</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>true</sorted>
                <value>
                    <fullName>BLM</fullName>
                    <default>false</default>
                    <label>BLM</label>
                </value>
                <value>
                    <fullName>EPA</fullName>
                    <default>false</default>
                    <label>EPA</label>
                </value>
                <value>
                    <fullName>FERC</fullName>
                    <default>false</default>
                    <label>FERC</label>
                </value>
                <value>
                    <fullName>Other</fullName>
                    <default>false</default>
                    <label>Other</label>
                </value>
                <value>
                    <fullName>SHPO</fullName>
                    <default>false</default>
                    <label>SHPO</label>
                </value>
                <value>
                    <fullName>USACE</fullName>
                    <default>false</default>
                    <label>USACE</label>
                </value>
                <value>
                    <fullName>USFWS</fullName>
                    <default>false</default>
                    <label>USFWS</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_external_federal_id__c</fullName>
        <description>The other agency's federal_unique_id for this permit process — UUID format. Used as the path parameter when calling that agency's NEPA REST API at /nepa/v1/processes/{id}. Required for live status lookup.</description>
        <inlineHelpText>The other agency's federal_unique_id (UUID). Required for live API status lookup.</inlineHelpText>
        <label>External Federal ID</label>
        <required>false</required>
        <externalId>true</externalId>
        <unique>false</unique>
        <length>36</length>
        <trackTrending>false</trackTrending>
        <type>Text</type>
    </fields>
    <fields>
        <fullName>nepa_agency_endpoint_ref__c</fullName>
        <description>DeveloperName reference to the NEPA_Agency_Endpoint__mdt record that defines the base URL and Named Credential for this agency's NEPA REST API (e.g., USACE, USFWS, BLM). Must match the DeveloperName of an active endpoint record.</description>
        <inlineHelpText>Agency endpoint reference — must match a NEPA_Agency_Endpoint__mdt DeveloperName (e.g., USACE).</inlineHelpText>
        <label>Agency Endpoint Reference</label>
        <required>false</required>
        <length>40</length>
        <trackTrending>false</trackTrending>
        <type>Text</type>
    </fields>
    <fields>
        <fullName>nepa_permit_status__c</fullName>
        <description>Locally cached permit status. Updated by the permit coordinator manually or via scheduled sync. The LWC displays the live status from the agency REST API when available, falling back to this value.</description>
        <inlineHelpText>Cached permit status. The live status from the agency API takes precedence when the API is reachable.</inlineHelpText>
        <label>Permit Status</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Not Started</fullName>
                    <default>true</default>
                    <label>Not Started</label>
                </value>
                <value>
                    <fullName>Under Review</fullName>
                    <default>false</default>
                    <label>Under Review</label>
                </value>
                <value>
                    <fullName>Issued</fullName>
                    <default>false</default>
                    <label>Issued</label>
                </value>
                <value>
                    <fullName>Denied</fullName>
                    <default>false</default>
                    <label>Denied</label>
                </value>
                <value>
                    <fullName>Withdrawn</fullName>
                    <default>false</default>
                    <label>Withdrawn</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_expected_completion__c</fullName>
        <description>Expected permit decision date per coordination agreement or statutory deadline.</description>
        <inlineHelpText>Expected date for the permit decision.</inlineHelpText>
        <label>Expected Completion</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>nepa_actual_completion__c</fullName>
        <description>Actual date the permit was issued, denied, or withdrawn.</description>
        <inlineHelpText>Actual date of the permit decision.</inlineHelpText>
        <label>Actual Completion</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>nepa_is_critical_path__c</fullName>
        <description>When true, this permit is on the critical path — the project cannot advance to the next stage until this permit is issued. The LWC highlights critical-path rows with a warning indicator.</description>
        <inlineHelpText>Check if project advancement is blocked until this permit is issued.</inlineHelpText>
        <label>Critical Path</label>
        <defaultValue>false</defaultValue>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_regulatory_citation__c</fullName>
        <description>Statutory citation for this permit requirement (e.g., 33 USC 1344 for CWA Section 404).</description>
        <inlineHelpText>Statutory citation (e.g., 33 USC 1344).</inlineHelpText>
        <label>Regulatory Citation</label>
        <required>false</required>
        <length>80</length>
        <trackTrending>false</trackTrending>
        <type>Text</type>
    </fields>
    <fields>
        <fullName>nepa_agency_system_url__c</fullName>
        <description>Direct URL to the permit record in the other agency's system (e.g., ORM2, DARTER, BLM ePlanning). Rendered as a link in the LWC.</description>
        <inlineHelpText>Link to the permit record in the issuing agency's system.</inlineHelpText>
        <label>Agency System URL</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Url</type>
    </fields>
    <fields>
        <fullName>nepa_last_synced__c</fullName>
        <description>Timestamp of the last successful live status fetch from the agency's NEPA REST API. Set by NepaAgencyPermitService after each successful callout. Used by the LWC to show data freshness.</description>
        <inlineHelpText>When the live agency status was last successfully retrieved.</inlineHelpText>
        <label>Last Synced</label>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>DateTime</type>
    </fields>
    <label>NEPA Required Permit</label>
    <nameField>
        <displayFormat>RP-{00000000}</displayFormat>
        <label>Required Permit Name</label>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>NEPA Required Permits</pluralLabel>
