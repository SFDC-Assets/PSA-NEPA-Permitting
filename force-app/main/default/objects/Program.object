<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <fields>
        <fullName>nepa_current_status__c</fullName>
        <description>Current phase (e.g., pre-application, in progress, paused, completed, cancelled)
of the NEPA, permitting, or other authorization process (may be aggregated from related process
status and related milestones or events).</description>
        <inlineHelpText>Current phase (e.g., pre-application, in progress, paused, completed, cancelled)
of the NEPA, permitting, or other authorization process (may be aggregated from related process
status and related milestones or events).</inlineHelpText>
        <label>Current Status</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>pre-application</fullName>
                    <default>false</default>
                    <label>pre-application</label>
                </value>
                <value>
                    <fullName>underway</fullName>
                    <default>false</default>
                    <label>underway</label>
                </value>
                <value>
                    <fullName>paused</fullName>
                    <default>false</default>
                    <label>paused</label>
                </value>
                <value>
                    <fullName>completed</fullName>
                    <default>false</default>
                    <label>completed</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_lead_agency__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Federal agency that is undertaking the activity or responsible for the decision.</description>
        <inlineHelpText>Federal agency that is undertaking the activity or responsible for the decision.</inlineHelpText>
        <label>Lead Agency</label>
        <referenceTo>Account</referenceTo>
        <relationshipLabel>Projects</relationshipLabel>
        <relationshipName>Projects</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>nepa_location__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Geographic area, including relationship to GIS Object, optionally also stored as a simple property
here (e.g., latitude / longitude coordinates of the centroid of the project footprint). Where location is
more complex than a point or is multi-state or regional, could be a text response.</description>
        <inlineHelpText>Geographic area, including relationship to GIS Object, optionally also stored as a simple property
here (e.g., latitude / longitude coordinates of the centroid of the project footprint). Where location is
more complex than a point or is multi-state or regional, could be a text response.</inlineHelpText>
        <label>Location</label>
        <referenceTo>Location</referenceTo>
        <relationshipLabel>Projects</relationshipLabel>
        <relationshipName>Projects</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>nepa_parent_project__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <label>Parent Project</label>
        <referenceTo>Program</referenceTo>
        <relationshipLabel>Child Projects</relationshipLabel>
        <relationshipName>Child_Projects</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>nepa_project_description__c</fullName>
        <description>Summary of the project&apos;s goals and scope</description>
        <externalId>false</externalId>
        <inlineHelpText>Summary of the project&apos;s goals and scope</inlineHelpText>
        <label>Project Description</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_project_id__c</fullName>
        <caseSensitive>false</caseSensitive>
        <description>Unique identification number for the project</description>
        <externalId>true</externalId>
        <inlineHelpText>Unique identification number for the project</inlineHelpText>
        <label>Project Id</label>
        <length>32</length>
        <required>false</required>
