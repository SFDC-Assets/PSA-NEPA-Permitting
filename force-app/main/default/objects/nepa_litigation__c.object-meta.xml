    <description>PermitTEC-sourced federal litigation cases linked to NEPA projects. Each record represents one court case challenging a federal agency action under NEPA. Linked to Program via nepa_project_id__c (ExternalId join key).</description>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <fields>
        <fullName>nepa_case_title__c</fullName>
        <description>Full case title as extracted from PermitTEC (e.g., "FRIENDS OF ANIMALS v. USFWS").</description>
        <inlineHelpText>Full case title.</inlineHelpText>
        <externalId>false</externalId>
        <label>Case Title</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_citation__c</fullName>
