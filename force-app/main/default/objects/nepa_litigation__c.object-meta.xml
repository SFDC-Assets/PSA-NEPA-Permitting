        <label>Court</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_circuit__c</fullName>
        <description>Federal circuit (e.g., "9th", "District of Columbia", "10th").</description>
        <inlineHelpText>Federal circuit in which the case was decided.</inlineHelpText>
        <externalId>false</externalId>
        <label>Circuit</label>
        <length>100</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
