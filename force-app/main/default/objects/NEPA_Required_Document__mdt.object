<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Defines required document types per NEPA review type for administrative record completeness scoring. Seeded with minimum viable checklist per CEQ regulations. Used by NEPA_Administrative_Record_Checker Flow to calculate IndividualApplication.nepa_record_completeness__c.</description>
    <label>NEPA Required Document</label>
    <pluralLabel>NEPA Required Documents</pluralLabel>
    <fields>
        <fullName>Review_Type__c</fullName>
        <description>NEPA review type this requirement applies to: CE, EA, or EIS.</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Review Type</label>
        <length>10</length>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Document_Type__c</fullName>
        <description>Required document type. Must match a valid value in ContentVersion.nepa_document_type__c.</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Document Type</label>
        <length>100</length>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Gate_Event_Type__c</fullName>
        <description>The exact nepa_event_type__c picklist value on ApplicationTimeline that gates this document. When a timeline event of this type is set to Completed, NEPA_Stage_Gate_Doc_Check verifies the document is present before allowing the save. Must exactly match a value in ApplicationTimeline.nepa_event_type__c. Leave blank to omit from gate checks (document is scored but not gate-blocking).</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Gate Event Type</label>
        <length>100</length>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Is_Required__c</fullName>
        <description>When true, the document must be present in Approved or Published status for the process to reach full completeness. When false, the document is recommended but not counted in the score. SubscriberControlled so agencies can adjust requirements to their process.</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Is Required</label>
        <type>Checkbox</type>
        <defaultValue>true</defaultValue>
    </fields>
    <fields>
        <fullName>Stage_Required_By__c</fullName>
        <description>Process stage by which this document must be present (informational). Used to generate missing-document alert context. SubscriberControlled so agencies can tune stage gates.</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Stage Required By</label>
        <length>100</length>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Display_Order__c</fullName>
        <description>Sort order for display in completeness gap messages. SubscriberControlled so agencies can reorder their document checklist.</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Display Order</label>
        <precision>3</precision>
        <scale>0</scale>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Active__c</fullName>
        <description>Inactive rules are excluded from completeness calculations. SubscriberControlled so agencies can enable/disable requirements without a package update.</description>
        <fieldManageability>SubscriberControlled</fieldManageability>
        <label>Active</label>
        <type>Checkbox</type>
        <defaultValue>true</defaultValue>
    </fields>

    <!-- Mandate 2: EO 14270 temporal versioning -->
    <fields>
        <fullName>Effective_Start_Date__c</fullName>
        <description>Date this record version becomes effective. Flows compare inp_EvaluationDate (= nepa_start_date__c on the IA) against this: only records where Effective_Start_Date__c IS NULL OR &lt;= EvaluationDate are returned. Null = effective from the beginning of time.</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Effective Start Date</label>
        <required>false</required>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>Sunset_Date__c</fullName>
        <description>Date after which this record version is no longer effective (EO 14270 sunset compliance). Flows filter: Sunset_Date__c IS NULL OR &gt;= EvaluationDate. Null = no sunset.</description>
        <fieldManageability>DeveloperControlled</fieldManageability>
        <label>Sunset Date</label>
        <required>false</required>
        <type>Date</type>
    </fields>
</CustomObject>
