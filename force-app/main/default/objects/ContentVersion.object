    <fields>
        <fullName>nepa_main_document__c</fullName>
        <description>Indicates whether this file is the primary/main document (true) or supporting material such as an appendix, attachment, or supplemental file (false). Aligns with NEPATEC2.0 main_document flag.</description>
        <inlineHelpText>Check if this is the main document. Leave unchecked for appendices, attachments, and supplemental files.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Main Document</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
