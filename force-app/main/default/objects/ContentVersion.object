        <label>Contributing Agencies</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_document_summary__c</fullName>
        <description>Machine-readable summary of the document structure, including table of contents and short descriptions of sections. Include at minimum: project, process, high-level case events, and associated GIS data.</description>
        <inlineHelpText>Document table of contents and section summaries (structured data per CEQ Document Structures guidance).</inlineHelpText>
        <label>Document Summary / TOC</label>
        <length>131072</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>5</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_document_files__c</fullName>
        <description>Optional JSON reference to document files associated with this record (per CEQ standard Document Files property added in v1.2).</description>
        <inlineHelpText>JSON references to document file attachments or external file locations.</inlineHelpText>
        <label>Document Files (JSON)</label>
        <length>131072</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
