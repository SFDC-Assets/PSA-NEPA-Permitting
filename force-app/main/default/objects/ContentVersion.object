    <!-- Priority 3: AI-assisted document generation fields -->
    <fields>
        <fullName>nepa_ai_generated__c</fullName>
        <description>Indicates this document was fully or partially generated by an AI system (e.g., Agentforce document generation). Required for administrative record defensibility — AI-generated content must be disclosed and SME-reviewed before publication.</description>
        <inlineHelpText>Check if this document was generated by an AI system. AI-generated documents require SME review before publication.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>AI Generated</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>

    <fields>
        <fullName>nepa_clm_template_id__c</fullName>
        <description>ID of the CLM template used to generate this document. Enables traceability from document back to the template version and clause library. Populated by Agentforce document generation action.</description>
        <inlineHelpText>CLM template ID used to generate this document (populated automatically for AI-generated documents).</inlineHelpText>
        <externalId>false</externalId>
        <label>CLM Template ID</label>
        <length>36</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>

    <fields>
        <fullName>nepa_reviewer__c</fullName>
        <description>User assigned to review and approve this document before publication. Required for AI-generated documents and for any document that will be included in the administrative record.</description>
        <inlineHelpText>User responsible for reviewing and approving this document.</inlineHelpText>
        <deleteConstraint>SetNull</deleteConstraint>
        <label>Reviewer</label>
        <referenceTo>User</referenceTo>
        <relationshipLabel>Documents Under Review</relationshipLabel>
        <relationshipName>NEPA_Documents_UnderReview</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>

    <fields>
        <fullName>nepa_reviewed_date__c</fullName>
        <description>Date the document was reviewed and approved for publication or inclusion in the administrative record. Set by the reviewer when they approve the document.</description>
        <inlineHelpText>Date this document was reviewed and approved.</inlineHelpText>
        <label>Reviewed Date</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Date</type>
    </fields>

    <fields>
        <fullName>nepa_process__c</fullName>
        <description>Direct Lookup to the IndividualApplication (NEPA process) this document belongs to. Set on upload or by the NEPA_AdminRecord_AutoCreate flow. Provides a stable, queryable parent reference that survives ContentDocumentLink traversal limitations in OmniScript Integration Procedures (Phase 2). Enables SOQL FROM ContentVersion WHERE nepa_process__c = :processId without going through ContentDocumentLink.</description>
        <inlineHelpText>The NEPA permitting process this document belongs to.</inlineHelpText>
        <label>NEPA Process</label>
        <deleteConstraint>SetNull</deleteConstraint>
        <referenceTo>IndividualApplication</referenceTo>
        <relationshipLabel>NEPA Documents</relationshipLabel>
        <relationshipName>NEPA_Documents</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>

    <fields>
        <fullName>nepa_section_tags__c</fullName>
        <description>One or more document sections represented in this file. Used for Phase 2 RAG-based document retrieval to scope search to specific EIS/EA sections. Multi-select to support files that span multiple sections (e.g., a combined Affected Environment + Environmental Consequences chapter).</description>
        <inlineHelpText>Select all EIS/EA sections covered by this document.</inlineHelpText>
        <label>Section Tags</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>MultiselectPicklist</type>
        <visibleLines>4</visibleLines>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Purpose and Need</fullName><default>false</default><label>Purpose and Need</label></value>
                <value><fullName>Alternatives</fullName><default>false</default><label>Alternatives</label></value>
                <value><fullName>Affected Environment</fullName><default>false</default><label>Affected Environment</label></value>
                <value><fullName>Environmental Consequences</fullName><default>false</default><label>Environmental Consequences</label></value>
                <value><fullName>Mitigation</fullName><default>false</default><label>Mitigation</label></value>
                <value><fullName>Appendix</fullName><default>false</default><label>Appendix</label></value>
                <value><fullName>Full Document</fullName><default>false</default><label>Full Document</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>

    <fields>
        <fullName>nepa_main_document__c</fullName>
        <description>Indicates whether this file is the primary/main document (true) or supporting material such as an appendix, attachment, or supplemental file (false). Aligns with NEPATEC2.0 main_document flag.</description>
        <inlineHelpText>Check if this is the main document. Leave unchecked for appendices, attachments, and supplemental files.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Main Document</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
    <!-- Mandate 4: AI EIS section generation fields -->
    <fields>
        <fullName>nepa_section_type__c</fullName>
        <description>Single-select EIS section type for AI-generated drafts. Distinct from nepa_section_tags__c (multi-select taxonomy) — this identifies the primary section being drafted by NEPA_EIS_Section_Assembler. Required for OMB M-24-10 AI disclosure and 40 CFR 1502 section traceability.</description>
        <inlineHelpText>EIS section this document represents. Set automatically by AI draft generation; editable by SME reviewer.</inlineHelpText>
        <label>EIS Section Type</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Purpose and Need</fullName><default>false</default><label>Purpose and Need</label></value>
                <value><fullName>Affected Environment</fullName><default>false</default><label>Affected Environment</label></value>
                <value><fullName>Alternatives</fullName><default>false</default><label>Alternatives</label></value>
                <value><fullName>Environmental Consequences</fullName><default>false</default><label>Environmental Consequences</label></value>
                <value><fullName>Mitigation Measures</fullName><default>false</default><label>Mitigation Measures</label></value>
                <value><fullName>Cumulative Impacts</fullName><default>false</default><label>Cumulative Impacts</label></value>
                <value><fullName>Index</fullName><default>false</default><label>Index</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_draft_source__c</fullName>
        <description>Provenance of this document draft. AI-Generated = fully machine-authored by NEPA_EIS_Section_Assembler; Human-Authored = entirely written by staff; AI-Assisted = AI-generated draft subsequently edited by a human. Required for OMB M-24-10 AI use disclosure. AI-Generated documents must be reviewed by a Subject Matter Expert before publication.</description>
        <inlineHelpText>Who authored this document. AI-Generated drafts require SME review and sign-off before inclusion in the administrative record.</inlineHelpText>
        <label>Draft Source</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>AI-Generated</fullName><default>false</default><label>AI-Generated</label></value>
                <value><fullName>Human-Authored</fullName><default>false</default><label>Human-Authored</label></value>
                <value><fullName>AI-Assisted</fullName><default>false</default><label>AI-Assisted</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>

    <!-- FRA Page Limit Compliance fields (2023 FRA: 75 pages EA, 150 Draft EIS, 300 Final EIS — excluding appendices and citations) -->
    <fields>
        <fullName>nepa_is_appendix__c</fullName>
        <description>True when this file is an appendix, attachment, or citation supplement rather than core NEPA document text. FRA page limits (EA = 75, Draft EIS = 150, Final EIS = 300) explicitly exclude appendices. This flag is the basis for the FRA Page Limit Compliance Report: core text files count against the limit; appendices do not.</description>
        <inlineHelpText>Appendices and citation supplements are excluded from FRA page limits. Check this for any file that is not core document text.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Is Appendix / Supplement</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_page_count__c</fullName>
        <description>Page count of this document's core text, excluding citations and appendices per FRA 42 U.S.C. 4336a. For files where nepa_is_appendix__c = false, this rolls up to the FRA compliance report. Populated manually by the uploader or automatically by an Apex PDFPageCount action on insert.</description>
        <inlineHelpText>Page count of core document text only. Do not include appendix or citation pages — those are excluded from FRA page limits.</inlineHelpText>
        <label>Page Count</label>
        <precision>6</precision>
        <required>false</required>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_fra_page_limit__c</fullName>
        <description>FRA statutory page limit for this document type: EA = 75, Draft EIS = 150, Final EIS = 300. Set by a before-save flow based on nepa_document_type__c. Null for document types with no statutory limit (CE documents, appendices, supporting analysis). Stored here to enable report formula comparisons without a CMT lookup.</description>
        <inlineHelpText>FRA statutory page limit: EA = 75, Draft EIS = 150, Final EIS = 300. Null for exempt types.</inlineHelpText>
        <label>FRA Page Limit</label>
        <precision>6</precision>
        <required>false</required>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_fra_overlimit__c</fullName>
        <description>Formula checkbox: true when nepa_page_count__c exceeds nepa_fra_page_limit__c for a core text file (nepa_is_appendix__c = false). Drives the FRA Page Limit Compliance Report filter and the NEPA_SLA_Escalation_Monitor warning. False/null for appendices, CE documents, and files without page counts.</description>
        <inlineHelpText>True when this document exceeds its FRA statutory page limit. Appendices are excluded from this calculation.</inlineHelpText>
        <formula>AND(
  NOT(nepa_is_appendix__c),
  NOT(ISBLANK(nepa_page_count__c)),
  NOT(ISBLANK(nepa_fra_page_limit__c)),
  nepa_page_count__c &gt; nepa_fra_page_limit__c
)</formula>
        <label>FRA Page Limit Exceeded</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <!-- Sponsor chain-of-custody fields (FRA project sponsor document drafting — Mandate 3) -->
    <fields>
        <fullName>nepa_document_custody__c</fullName>
        <description>Chain-of-custody status for FRA sponsor-prepared documents. Agency Original: no sponsor involvement. Sponsor Draft: uploaded by the project sponsor portal user, not yet reviewed. Agency Under Review: assigned to an agency reviewer. Agency Modified: agency made substantive edits. Agency Adopted: agency independently evaluated and formally adopted the document per FRA requirements. History tracking enabled — the transition from Sponsor Draft to Agency Adopted is the key APA defensibility record.</description>
        <inlineHelpText>Custody status of this document. Sponsor Draft documents must reach Agency Adopted before use in the official administrative record.</inlineHelpText>
        <label>Document Custody Status</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Agency Original</fullName><default>true</default><label>Agency Original</label></value>
                <value><fullName>Sponsor Draft</fullName><default>false</default><label>Sponsor Draft</label></value>
                <value><fullName>Agency Under Review</fullName><default>false</default><label>Agency Under Review</label></value>
                <value><fullName>Agency Modified</fullName><default>false</default><label>Agency Modified</label></value>
                <value><fullName>Agency Adopted</fullName><default>false</default><label>Agency Adopted</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_sponsor_submitted_by__c</fullName>
        <description>Portal username or display name of the project sponsor who uploaded this document. Auto-populated by the portal submission flow for Sponsor Draft documents. Part of the FRA chain-of-custody record that proves the agency received and independently reviewed sponsor-prepared materials.</description>
        <inlineHelpText>Project sponsor portal user who submitted this draft. Auto-populated for sponsor-submitted documents.</inlineHelpText>
        <label>Sponsor Submitted By</label>
        <length>255</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_agency_adopted_date__c</fullName>
        <description>Date the agency formally adopted this sponsor-prepared document into the official administrative record. The period between document upload and this date quantifies the agency's independent review time — a critical metric for demonstrating supervisory control in APA litigation. Required when nepa_document_custody__c = Agency Adopted.</description>
        <inlineHelpText>Date the agency formally adopted this sponsor-prepared document. Captures independent review duration for APA defensibility.</inlineHelpText>
        <label>Agency Adopted Date</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <!-- AR Export fields (Mandate 4: 60-day Administrative Record package) -->
    <fields>
        <fullName>nepa_ar_included__c</fullName>
        <description>True when this file has been marked for inclusion in a formal Administrative Record export package. Set by the NEPA_AR_Export process. Allows the AR exporter to filter ContentVersion records to exactly the documents designated for the AR without querying all files attached to the process.</description>
        <inlineHelpText>This document is included in the Administrative Record export package.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Included in AR Export</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_ar_index_number__c</fullName>
        <description>Sequential index number assigned to this document within an Administrative Record export package. Court-ready AR packages require a numbered document index. Assigned by the NEPA_AR_Export process when nepa_ar_included__c is set to true.</description>
        <inlineHelpText>AR package document index number. Assigned automatically when the AR export is compiled.</inlineHelpText>
        <label>AR Index Number</label>
        <precision>8</precision>
        <required>false</required>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <recordTypes>
        <fullName>nepa_permit_document</fullName>
        <active>true</active>
        <description>A type of document associated to NEPA permitting processes</description>
        <label>Document</label>
        <picklistValues>
            <picklist>nepa_document_type__c</picklist>
