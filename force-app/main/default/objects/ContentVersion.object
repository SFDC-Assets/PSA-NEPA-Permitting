                    <default>false</default>
                    <label>Memorandum to File</label>
                </value>
                <value>
                    <fullName>Permit</fullName>
                    <default>false</default>
                    <label>Permit</label>
                </value>
                <value>
                    <fullName>Comment Response</fullName>
                    <default>false</default>
                    <label>Comment Response</label>
                </value>
                <value>
                    <fullName>Alternatives Analysis</fullName>
                    <default>false</default>
                    <label>Alternatives Analysis</label>
                </value>
                <value>
                    <fullName>Other</fullName>
                    <default>false</default>
                    <label>Other</label>
