            </values>
            <values>
                <fullName>Programmatic EIS</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Final EIS</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>ROD</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Environmental Assessment</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>FONSI</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>CE Determination</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Memorandum to File</fullName>
                <default>false</default>
            </values>
            <values>
                <fullName>Comment Response</fullName>
