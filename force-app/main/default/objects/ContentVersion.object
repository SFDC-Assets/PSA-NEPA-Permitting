    <fields>
        <fullName>nepa_document_revision__c</fullName>
        <description>Indicates which revision of the document (e.g., first revised Draft EIS).</description>
        <externalId>false</externalId>
        <inlineHelpText>Indicates which revision of the document (e.g., first revised Draft EIS).</inlineHelpText>
        <label>Document Revision</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
