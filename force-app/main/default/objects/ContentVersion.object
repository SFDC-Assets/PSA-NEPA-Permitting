    <fields>
        <fullName>nepa_prepared_by__c</fullName>
        <description>Responsible entity that prepared this document.</description>
        <externalId>false</externalId>
        <inlineHelpText>Responsible entity that prepared this document.</inlineHelpText>
        <label>Prepared By</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_public_access__c</fullName>
        <defaultValue>false</defaultValue>
        <description>Whether this document is publicly accessible. True = publicly visible; False = restricted to agency staff.</description>
        <inlineHelpText>Check to make this document publicly visible on the portal.</inlineHelpText>
        <label>Public Access</label>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_publish_date__c</fullName>
        <description>Publication or submission date.</description>
        <inlineHelpText>Publication or submission date.</inlineHelpText>
        <label>Publish Date</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>nepa_revision_number__c</fullName>
        <description>Numeric revision sequence number of the document.</description>
        <externalId>false</externalId>
        <inlineHelpText>Numeric revision sequence number.</inlineHelpText>
        <label>Revision Number</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_status__c</fullName>
        <description>Document production phase.</description>
        <inlineHelpText>Current production phase of this document.</inlineHelpText>
        <label>Status</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Draft</fullName>
                    <default>false</default>
                    <label>Draft</label>
                </value>
                <value>
                    <fullName>Pending Review</fullName>
                    <default>false</default>
                    <label>Pending Review</label>
                </value>
                <value>
                    <fullName>Approved</fullName>
                    <default>false</default>
                    <label>Approved</label>
                </value>
                <value>
                    <fullName>Published</fullName>
                    <default>false</default>
                    <label>Published</label>
                </value>
                <value>
                    <fullName>Complete</fullName>
                    <default>false</default>
                    <label>Complete</label>
                </value>
                <value>
                    <fullName>Rejected</fullName>
                    <default>false</default>
                    <label>Rejected</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_supplement_number__c</fullName>
        <description>If the document is a supplement to another document, this indicates the sequence number of the supplement.</description>
        <externalId>false</externalId>
        <inlineHelpText>Supplement sequence number (if this is a supplemental document).</inlineHelpText>
        <label>Supplement Number</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_volume_title__c</fullName>
        <description>Title of a specific document section or volume (e.g., Appendix 1 - Location Maps, Chapter 3 - Affected Environment).</description>
        <inlineHelpText>Title of this document section or volume.</inlineHelpText>
        <label>Volume / Section Title</label>
        <length>32768</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <!-- CEQ Standard v1.2 additions -->
    <fields>
        <fullName>nepa_related_document__c</fullName>
        <description>ContentDocumentId of a related NEPA document (e.g., links a Final EIS to its Draft EIS). Stored as Text because Salesforce does not permit Lookup fields targeting ContentDocument/ContentVersion. Maps to CEQ standard Related Document IDs property.</description>
        <inlineHelpText>ContentDocumentId of the related NEPA document (e.g., the Draft EIS this Final EIS responds to).</inlineHelpText>
        <externalId>false</externalId>
        <label>Related Document ID</label>
        <length>18</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_notes__c</fullName>
        <description>Additional notes or context for this document not captured by other fields.</description>
        <inlineHelpText>Additional notes or context for this document.</inlineHelpText>
        <label>Notes</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_url__c</fullName>
        <description>Online link to the document, if publicly available.</description>
        <inlineHelpText>Public URL where this document can be accessed.</inlineHelpText>
        <label>Document URL</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Url</type>
    </fields>
    <fields>
        <fullName>nepa_related_case_event__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Reference to the Case Event (ApplicationTimeline) that this document is associated with (e.g., NOI publication event).</description>
        <inlineHelpText>Case event milestone that produced or is associated with this document.</inlineHelpText>
        <label>Related Case Event</label>
        <referenceTo>ApplicationTimeline</referenceTo>
        <relationshipLabel>Documents</relationshipLabel>
        <relationshipName>NEPA_Documents</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>nepa_contributing_agencies__c</fullName>
        <description>Agencies that contributed to preparation or review of this document.</description>
        <inlineHelpText>Agencies that contributed to preparation or review of this document.</inlineHelpText>
        <label>Contributing Agencies</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_document_summary__c</fullName>
        <description>Machine-readable summary of the document structure, including table of contents and short descriptions of sections. Include at minimum: project, process, high-level case events, and associated GIS data.</description>
        <inlineHelpText>Document table of contents and section summaries (structured data per CEQ Document Structures guidance).</inlineHelpText>
        <label>Document Summary / TOC</label>
        <length>131072</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>5</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_document_files__c</fullName>
        <description>Optional JSON reference to document files associated with this record (per CEQ standard Document Files property added in v1.2).</description>
        <inlineHelpText>JSON references to document file attachments or external file locations.</inlineHelpText>
        <label>Document Files (JSON)</label>
        <length>131072</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_record_category__c</fullName>
        <description>Administrative record classification for this document, supporting FOIA and litigation needs.</description>
        <inlineHelpText>Administrative record category for this document.</inlineHelpText>
        <label>Record Category</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Supporting Analysis</fullName>
                    <default>false</default>
                    <label>Supporting Analysis</label>
                </value>
                <value>
                    <fullName>Public Comment</fullName>
                    <default>false</default>
                    <label>Public Comment</label>
                </value>
                <value>
                    <fullName>Agency Communication</fullName>
                    <default>false</default>
                    <label>Agency Communication</label>
                </value>
                <value>
                    <fullName>Decision Record</fullName>
                    <default>false</default>
                    <label>Decision Record</label>
                </value>
                <value>
                    <fullName>Permit</fullName>
                    <default>false</default>
                    <label>Permit</label>
                </value>
                <value>
                    <fullName>Other</fullName>
                    <default>false</default>
                    <label>Other</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <!-- Provenance fields (CEQ Standard v1.2 - required on all entities) -->
    <fields>
        <fullName>nepa_data_record_version__c</fullName>
        <description>The version of the record, for tracking updates or changes to the data.</description>
        <inlineHelpText>Version of this record for data exchange tracking.</inlineHelpText>
        <externalId>false</externalId>
        <label>Data Record Version</label>
        <length>50</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_data_source_agency__c</fullName>
        <description>The name of the agency or organization that provided the data.</description>
        <inlineHelpText>Agency or organization that provided this data.</inlineHelpText>
        <externalId>false</externalId>
        <label>Data Source Agency</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_data_source_system__c</fullName>
        <description>The system or database where the data originally came from.</description>
        <inlineHelpText>Source system or database for this record.</inlineHelpText>
        <externalId>false</externalId>
        <label>Data Source System</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_record_owner_agency__c</fullName>
        <description>The agency responsible for maintaining or owning this record.</description>
        <inlineHelpText>Agency responsible for owning and maintaining this record.</inlineHelpText>
        <externalId>false</externalId>
        <label>Record Owner Agency</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_retrieved_timestamp__c</fullName>
        <description>The date and time when this record was retrieved from its source.</description>
        <inlineHelpText>Date and time this record was retrieved from its source system.</inlineHelpText>
        <label>Retrieved Timestamp</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>DateTime</type>
    </fields>
    <!-- Priority 3: AI-assisted document generation fields -->
    <fields>
        <fullName>nepa_ai_generated__c</fullName>
        <description>Indicates this document was fully or partially generated by an AI system (e.g., Agentforce document generation). Required for administrative record defensibility — AI-generated content must be disclosed and SME-reviewed before publication.</description>
        <inlineHelpText>Check if this document was generated by an AI system. AI-generated documents require SME review before publication.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>AI Generated</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>

    <fields>
        <fullName>nepa_clm_template_id__c</fullName>
        <description>ID of the CLM template used to generate this document. Enables traceability from document back to the template version and clause library. Populated by Agentforce document generation action.</description>
        <inlineHelpText>CLM template ID used to generate this document (populated automatically for AI-generated documents).</inlineHelpText>
        <externalId>false</externalId>
        <label>CLM Template ID</label>
        <length>36</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>

    <fields>
        <fullName>nepa_reviewer__c</fullName>
        <description>User assigned to review and approve this document before publication. Required for AI-generated documents and for any document that will be included in the administrative record.</description>
        <inlineHelpText>User responsible for reviewing and approving this document.</inlineHelpText>
        <deleteConstraint>SetNull</deleteConstraint>
        <referenceTo>User</referenceTo>
        <relationshipLabel>Documents Under Review</relationshipLabel>
        <relationshipName>NEPA_Documents_UnderReview</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>

    <fields>
        <fullName>nepa_reviewed_date__c</fullName>
        <description>Date the document was reviewed and approved for publication or inclusion in the administrative record. Set by the reviewer when they approve the document.</description>
        <inlineHelpText>Date this document was reviewed and approved.</inlineHelpText>
        <label>Reviewed Date</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Date</type>
    </fields>

    <fields>
        <fullName>nepa_process__c</fullName>
        <description>Direct Lookup to the IndividualApplication (NEPA process) this document belongs to. Set on upload or by the NEPA_AdminRecord_AutoCreate flow. Provides a stable, queryable parent reference that survives ContentDocumentLink traversal limitations in OmniScript Integration Procedures (Phase 2). Enables SOQL FROM ContentVersion WHERE nepa_process__c = :processId without going through ContentDocumentLink.</description>
        <inlineHelpText>The NEPA permitting process this document belongs to.</inlineHelpText>
        <label>NEPA Process</label>
        <deleteConstraint>SetNull</deleteConstraint>
        <referenceTo>IndividualApplication</referenceTo>
        <relationshipLabel>NEPA Documents</relationshipLabel>
        <relationshipName>NEPA_Documents</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>

    <fields>
        <fullName>nepa_main_document__c</fullName>
        <description>Indicates whether this file is the primary/main document (true) or supporting material such as an appendix, attachment, or supplemental file (false). Aligns with NEPATEC2.0 main_document flag.</description>
        <inlineHelpText>Check if this is the main document. Leave unchecked for appendices, attachments, and supplemental files.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Main Document</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
