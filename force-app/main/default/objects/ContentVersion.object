    <fields>
        <fullName>nepa_volume_title__c</fullName>
        <description>Title of a specific document section or volume (e.g., Appendix 1 - Location Maps, Chapter 3 - Affected Environment).</description>
        <inlineHelpText>Title of this document section or volume.</inlineHelpText>
        <label>Volume / Section Title</label>
        <length>32768</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <!-- CEQ Standard v1.2 additions -->
    <fields>
        <fullName>nepa_url__c</fullName>
        <description>Online link to the document, if publicly available.</description>
        <inlineHelpText>Public URL where this document can be accessed.</inlineHelpText>
        <label>Document URL</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Url</type>
    </fields>
    <fields>
        <fullName>nepa_related_case_event__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Reference to the Case Event (ApplicationTimeline) that this document is associated with (e.g., NOI publication event).</description>
        <inlineHelpText>Case event milestone that produced or is associated with this document.</inlineHelpText>
        <label>Related Case Event</label>
        <referenceTo>ApplicationTimeline</referenceTo>
        <relationshipLabel>Documents</relationshipLabel>
        <relationshipName>NEPA_Documents</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>
    <fields>
        <fullName>nepa_contributing_agencies__c</fullName>
