        </picklistValues>
    </recordTypes>
    <validationRules>
        <fullName>NEPA_AIDocumentRequiresSMEReview</fullName>
        <active>true</active>
        <description>OMB M-24-10: AI-generated documents require a named reviewer and review date before Approved/Published/Complete status. Blocks unreviewed AI content from the administrative record.</description>
        <errorConditionFormula>AND(
  ISPICKVAL(nepa_draft_source__c, "AI-Generated"),
  OR(
    ISPICKVAL(nepa_status__c, "Approved"),
    ISPICKVAL(nepa_status__c, "Published"),
    ISPICKVAL(nepa_status__c, "Complete")
  ),
  OR(
    ISBLANK(nepa_reviewer__c),
    ISBLANK(nepa_reviewed_date__c)
  )
)</errorConditionFormula>
        <errorMessage>AI-generated documents require a named reviewer and review date before approval. Set Reviewer and Reviewed Date fields before changing status to Approved, Published, or Complete.</errorMessage>
    </validationRules>
    <fields>
        <fullName>nepa_record_completeness__c</fullName>
        <description>Numeric completeness score (0-100) calculated by NEPA_Record_Completeness_Scorer flow indicating how complete the document record is.</description>
        <label>Record Completeness</label>
        <precision>5</precision>
        <scale>0</scale>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_other__c</fullName>
        <description>Extension bag for agency-specific or non-standard properties. Stores arbitrary JSON for interoperability with systems that require fields beyond the CEQ standard schema. Maps to the CEQ standard document.other (jsonb) property.</description>
        <inlineHelpText>JSON extension bag for additional properties not covered by the standard schema.</inlineHelpText>
        <label>Other (JSON)</label>
        <length>32768</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>2</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_record_completeness_updated__c</fullName>
        <description>Timestamp when nepa_record_completeness__c was last calculated by the completeness scorer flow.</description>
        <label>Record Completeness Updated</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>DateTime</type>
    </fields>
</CustomObject>
