    <fields>
        <fullName>nepa_public_access__c</fullName>
        <description>Public access level for the document.</description>
        <inlineHelpText>Disclosable (public) or Non-disclosable (restricted).</inlineHelpText>
        <label>Public Access</label>
        <required>false</required>
