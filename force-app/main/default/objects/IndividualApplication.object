<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <fields>
        <fullName>nepa_completion_date__c</fullName>
        <description>Conclusion date (may be aggregated from a related case event for the process, as defined by the agency).</description>
        <inlineHelpText>Conclusion date (may be aggregated from a related case event for the process, as defined by the agency).</inlineHelpText>
        <label>Completion Date</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>nepa_federal_unique_id__c</fullName>
        <caseSensitive>false</caseSensitive>
        <description>Federal Unique ID for this process. Recommend UUID format for global uniqueness.</description>
        <externalId>true</externalId>
        <label>Federal Unique Id</label>
        <length>36</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>true</unique>
    </fields>
    <fields>
        <fullName>nepa_joint_lead_agency__c</fullName>
        <deleteConstraint>SetNull</deleteConstraint>
        <description>Joint lead agency, if applicable.</description>
