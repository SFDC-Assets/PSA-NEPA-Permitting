    <!-- Phase 1 Risk Intelligence fields -->
    <fields>
        <fullName>nepa_risk_score__c</fullName>
        <description>Composite litigation risk score (0-100) calculated from review type, lead agency litigation rate, circuit, and project sector. Recalculated by Flow on create/update.</description>
        <inlineHelpText>Composite risk score 0–100. Higher = greater litigation exposure based on historical PermitTEC patterns.</inlineHelpText>
        <externalId>false</externalId>
        <label>Litigation Risk Score</label>
        <precision>5</precision>
        <required>false</required>
        <scale>1</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_risk_tier__c</fullName>
        <description>Human-readable litigation risk tier derived from nepa_risk_score__c. Low (0-24), Moderate (25-49), High (50-74), Very High (75-100).</description>
        <inlineHelpText>Risk tier: Low / Moderate / High / Very High.</inlineHelpText>
        <label>Risk Tier</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>Low</fullName>
                    <default>false</default>
                    <label>Low</label>
                </value>
                <value>
                    <fullName>Moderate</fullName>
                    <default>false</default>
                    <label>Moderate</label>
                </value>
                <value>
                    <fullName>High</fullName>
                    <default>false</default>
                    <label>High</label>
                </value>
                <value>
                    <fullName>Very High</fullName>
                    <default>false</default>
                    <label>Very High</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_risk_score_factors__c</fullName>
        <description>Semicolon-delimited list of contributing risk factor labels and their point values, written by the risk scoring Flow.</description>
        <inlineHelpText>Factors that contributed to the risk score (e.g., Review Type: EIS +40; Agency: Forest Service +15).</inlineHelpText>
        <label>Risk Score Factors</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_risk_score_updated__c</fullName>
        <description>Timestamp of the last risk score calculation. Use to identify stale scores when metadata weights are updated.</description>
        <inlineHelpText>When the risk score was last calculated.</inlineHelpText>
        <label>Risk Score Updated</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>DateTime</type>
    </fields>
    <fields>
        <fullName>nepa_predicted_challenge_grounds__c</fullName>
        <description>Semicolon-delimited list of predicted NEPA challenge grounds ordered by likelihood, derived from project attributes and PermitTEC patterns.</description>
        <inlineHelpText>Predicted challenge grounds (e.g., EIS/EA Inadequacy; Failure to Supplement).</inlineHelpText>
        <label>Predicted Challenge Grounds</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_challenge_prediction_notes__c</fullName>
        <description>Plain-language explanation of each predicted challenge ground and the attributes that triggered it.</description>
        <inlineHelpText>Why each challenge ground was predicted based on this process's attributes.</inlineHelpText>
        <label>Challenge Prediction Notes</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>4</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_defensibility_score__c</fullName>
        <description>Percentage (0-100) of expected administrative record elements present for this process type. Recalculated when documents, engagements, or timeline events change.</description>
        <inlineHelpText>Record completeness score: percentage of required documents and milestones present.</inlineHelpText>
        <externalId>false</externalId>
        <label>Defensibility Score</label>
        <precision>5</precision>
        <required>false</required>
        <scale>1</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_defensibility_gaps__c</fullName>
        <description>Semicolon-delimited list of missing record elements detected by the Defensibility Gap Flow (e.g., ROD Missing; No Public Engagement Events).</description>
        <inlineHelpText>Missing record elements that could create defensibility risk.</inlineHelpText>
        <label>Defensibility Gaps</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_defensibility_updated__c</fullName>
        <description>Timestamp of the last defensibility gap check.</description>
        <inlineHelpText>When the defensibility gaps were last evaluated.</inlineHelpText>
        <label>Defensibility Updated</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>DateTime</type>
    </fields>
    <!-- FRA Statutory Clock fields (2023 Fiscal Responsibility Act — 1 year EA / 2 year EIS hard deadlines) -->
    <fields>
        <fullName>nepa_fra_statutory_deadline__c</fullName>
        <description>Hard FRA statutory deadline: nepa_start_date__c + 365 days for EA, + 730 days for EIS, per 42 U.S.C. 4336a. This is a legal constraint, not a project management guideline. Set by NEPA_SLA_Due_Date_Setter alongside nepa_sla_due_date__c. Stored separately from the SLA due date so that clock-pause extensions are visible without overwriting the original statutory date.</description>
        <inlineHelpText>FRA hard deadline: 1 year (EA) or 2 years (EIS) from start date. Cannot be extended without project sponsor agreement per 42 U.S.C. 4336a(b).</inlineHelpText>
        <label>FRA Statutory Deadline</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>nepa_clock_paused__c</fullName>
        <description>True when the FRA statutory clock is formally suspended. Under 42 U.S.C. 4336a, the clock may pause only when the project sponsor explicitly agrees in writing to a suspension. This flag blocks NEPA_SLA_Escalation_Monitor from marking the process overdue while the suspension is in effect.</description>
        <inlineHelpText>Statutory clock suspended with project sponsor agreement. Pause requires documented sponsor consent — see nepa_clock_pause_reason__c.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Statutory Clock Paused</label>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_clock_pause_start__c</fullName>
        <description>Date the statutory clock was suspended. Together with nepa_clock_pause_end__c, used to calculate total suspended days and adjust the effective deadline. Null if clock is not paused.</description>
        <inlineHelpText>Date the statutory clock suspension began. Required when nepa_clock_paused__c is true.</inlineHelpText>
        <label>Clock Pause Start</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>nepa_clock_pause_end__c</fullName>
        <description>Date the statutory clock suspension ended. When populated, the NEPA_SLA_Due_Date_Setter recalculates nepa_fra_adjusted_deadline__c by adding (pause_end - pause_start) days to nepa_fra_statutory_deadline__c.</description>
        <inlineHelpText>Date the clock suspension ended. Triggers automatic adjusted deadline recalculation.</inlineHelpText>
        <label>Clock Pause End</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>nepa_clock_pause_days__c</fullName>
        <description>Formula: IF(nepa_clock_pause_start__c is not null AND nepa_clock_pause_end__c is not null, nepa_clock_pause_end__c - nepa_clock_pause_start__c, 0). Calculated number of suspended days to add back to the statutory deadline.</description>
        <inlineHelpText>Total days the clock has been suspended. Added to statutory deadline to compute adjusted deadline.</inlineHelpText>
        <formula>IF(
  AND(NOT(ISBLANK(nepa_clock_pause_start__c)), NOT(ISBLANK(nepa_clock_pause_end__c))),
  nepa_clock_pause_end__c - nepa_clock_pause_start__c,
  0
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Clock Pause Days</label>
        <precision>8</precision>
        <scale>0</scale>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_fra_adjusted_deadline__c</fullName>
        <description>Effective FRA deadline after adding clock suspension days. Formula: nepa_fra_statutory_deadline__c + nepa_clock_pause_days__c. This is the date used for overdue determination in NEPA_SLA_Escalation_Monitor when the clock has been paused. Equals nepa_fra_statutory_deadline__c when no pause has occurred.</description>
        <inlineHelpText>Statutory deadline + suspended days. This is the operative compliance deadline when a pause has occurred.</inlineHelpText>
        <formula>nepa_fra_statutory_deadline__c + nepa_clock_pause_days__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>FRA Adjusted Deadline</label>
        <trackTrending>false</trackTrending>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>nepa_clock_pause_reason__c</fullName>
        <description>Required documentation of the project sponsor's written agreement to the clock suspension, per 42 U.S.C. 4336a(b). Must reference the specific communication (letter, email, form) in which the sponsor consented. Part of the administrative record.</description>
        <inlineHelpText>Document the sponsor's written agreement to this clock suspension. Required for FRA compliance — cite the letter, email, or form.</inlineHelpText>
        <label>Clock Pause / Sponsor Agreement</label>
        <length>1000</length>
        <required>false</required>
        <trackTrending>false</trackTrending>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <!-- SLA tracking fields -->
    <fields>
        <fullName>nepa_sla_due_date__c</fullName>
        <description>Computed SLA deadline: nepa_start_date__c + NEPA_SLA_Config__mdt.Total_Days__c for the matching review type. Set by NEPA_SLA_Due_Date_Setter on create or when nepa_review_type__c / nepa_start_date__c changes. NULL until both fields are populated.</description>
        <inlineHelpText>Statutory deadline for this review. Computed automatically from start date and review type.</inlineHelpText>
        <label>SLA Due Date</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>nepa_sla_warning_sent__c</fullName>
        <description>Set to true by NEPA_SLA_Escalation_Monitor when TODAY >= nepa_sla_due_date__c - Warning_Days. Prevents duplicate warning notifications on subsequent daily runs. Reset to false when nepa_sla_due_date__c changes (new review type or start date correction).</description>
        <inlineHelpText>Warning notification has been sent for this SLA deadline.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>SLA Warning Sent</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_sla_overdue__c</fullName>
        <description>Set to true by NEPA_SLA_Escalation_Monitor when TODAY > nepa_sla_due_date__c and the process is not yet completed or cancelled. Drives list views, dashboard tiles, and secondary escalation notifications.</description>
        <inlineHelpText>Process has passed its SLA due date without reaching a terminal status.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>SLA Overdue</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>

    <!-- Priority 6: Workflow Orchestration fields -->
    <fields>
        <fullName>nepa_last_stage_transition__c</fullName>
        <description>Timestamp of the most recent nepa_process_stage__c change. Set by the NEPA_Stage_Gate Flow on every stage transition. Used by the Timeline Risk Scorer (Priority 4) to compute days-in-stage.</description>
        <inlineHelpText>When the process last advanced to a new stage. Updated automatically by Flow.</inlineHelpText>
        <label>Last Stage Transition</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>DateTime</type>
    </fields>
    <fields>
        <fullName>nepa_target_completion_date__c</fullName>
        <description>Target completion date set at Action Plan creation based on review type default durations (CE: 30 days, EA: 180 days, EIS: 730 days). May be updated by NEPA coordinator.</description>
        <inlineHelpText>Target completion date (set at process initiation based on review type).</inlineHelpText>
        <label>Target Completion Date</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Date</type>
    </fields>
    <!-- Priority 4: Timeline Risk fields -->
    <fields>
        <fullName>nepa_timeline_risk_tier__c</fullName>
        <description>Current timeline risk tier derived from days in current stage vs. review-type baseline. On Track: within expected range; At Risk: 10-25% over baseline; Stalled: 25-50% over baseline; Overdue: 50%+ over baseline. Written by NEPA_Timeline_Risk_Assessor Flow.</description>
        <inlineHelpText>Timeline risk classification for this process. Updated automatically by Flow when stage or status changes.</inlineHelpText>
        <externalId>false</externalId>
        <label>Timeline Risk Tier</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value>
                    <fullName>On Track</fullName>
                    <default>false</default>
                    <label>On Track</label>
                </value>
                <value>
                    <fullName>At Risk</fullName>
                    <default>false</default>
                    <label>At Risk</label>
                </value>
                <value>
                    <fullName>Stalled</fullName>
                    <default>false</default>
                    <label>Stalled</label>
                </value>
                <value>
                    <fullName>Overdue</fullName>
                    <default>false</default>
                    <label>Overdue</label>
                </value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_estimated_completion_date__c</fullName>
        <description>Projected completion date based on current process stage, days-in-stage, and review-type baseline. Calculated by NEPA_Timeline_Risk_Assessor Flow. Updated whenever stage or risk tier changes.</description>
        <inlineHelpText>Projected completion date based on current pace and review type baseline. Updated automatically.</inlineHelpText>
        <label>Estimated Completion Date</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>nepa_days_in_current_stage__c</fullName>
        <description>Formula field: number of calendar days elapsed since nepa_last_stage_transition__c (or nepa_start_date__c if no transition recorded). Used by NEPA_Timeline_Risk_Assessor to determine risk tier.</description>
        <inlineHelpText>Days elapsed in the current process stage. Recalculates daily.</inlineHelpText>
        <externalId>false</externalId>
        <formula>IF(
  NOT(ISBLANK(nepa_last_stage_transition__c)),
  TODAY() - DATEVALUE(nepa_last_stage_transition__c),
  IF(
    NOT(ISBLANK(nepa_start_date__c)),
    TODAY() - nepa_start_date__c,
    0
  )
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Days in Current Stage</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <!-- Priority 9: Administrative Record Completeness fields -->
    <fields>
        <fullName>nepa_record_completeness__c</fullName>
        <description>Percentage (0-100) of required documents present at Approved or Published status for this process's review type. Recalculated by NEPA_Administrative_Record_Checker Flow whenever a ContentVersion record is created or updated.</description>
        <inlineHelpText>Administrative record completeness: percentage of required documents present. 100% required before final stage gates.</inlineHelpText>
        <externalId>false</externalId>
        <label>Record Completeness</label>
        <precision>5</precision>
        <required>false</required>
        <scale>1</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_missing_documents__c</fullName>
        <description>Semicolon-delimited list of required document types not yet present at Approved or Published status. Written by NEPA_Administrative_Record_Checker Flow. Used in stage-gate blocking logic and displayed on the record page.</description>
        <inlineHelpText>Required documents not yet uploaded or approved. Blocks final stage gates when populated.</inlineHelpText>
        <label>Missing Documents</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <fields>
        <fullName>nepa_record_completeness_updated__c</fullName>
        <description>Timestamp of the last completeness score recalculation.</description>
        <inlineHelpText>When the record completeness score was last recalculated.</inlineHelpText>
        <label>Completeness Updated</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>DateTime</type>
    </fields>
    <!-- CE Screening fields (Priority 2: Automated CE Screening) -->
    <fields>
        <fullName>nepa_action_type__c</fullName>
        <description>Primary action verb describing what the applicant proposes to do. Primary discriminator for Tier 2 CE code selection when sector+type is ambiguous.</description>
        <inlineHelpText>What is the primary nature of the proposed action?</inlineHelpText>
        <label>Action Type</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Construct New</fullName><default>false</default><label>Construct New</label></value>
                <value><fullName>Modify Existing</fullName><default>false</default><label>Modify Existing</label></value>
                <value><fullName>Renew or Extend Existing</fullName><default>false</default><label>Renew or Extend Existing</label></value>
                <value><fullName>Abandon or Decommission</fullName><default>false</default><label>Abandon or Decommission</label></value>
                <value><fullName>Operate or Maintain Existing</fullName><default>false</default><label>Operate or Maintain Existing</label></value>
                <value><fullName>Research or Study</fullName><default>false</default><label>Research or Study</label></value>
                <value><fullName>Other</fullName><default>false</default><label>Other</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_disturbance_acres__c</fullName>
        <description>Total estimated surface disturbance in acres. Used by the CE Screener to enforce per-code acreage thresholds (e.g., EPA Sec.390(b)(1) ≤5 acres). Exceedance downgrades CE to EA.</description>
        <inlineHelpText>Estimated total surface disturbance (acres). Required for CE acreage threshold checks.</inlineHelpText>
        <externalId>false</externalId>
        <label>Disturbance Acres</label>
        <precision>10</precision>
        <required>false</required>
        <scale>2</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_regulatory_citation__c</fullName>
        <description>Regulatory citation the applicant believes applies (e.g., 10 CFR 1021 Appendix B, B1.3). Pre-filled by CE Screener; editable by permit manager.</description>
        <inlineHelpText>Regulatory citation for the applicable CE or review type.</inlineHelpText>
        <externalId>false</externalId>
        <label>Regulatory Citation</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_screening_confidence__c</fullName>
        <description>CE Screener confidence in the recommended review type classification. High = dominant pattern with ≥80% corpus support. Low = ambiguous or extraordinary circumstances present — requires SME review.</description>
        <inlineHelpText>Screener confidence: High / Medium-High / Medium / Low. Low requires SME review before routing.</inlineHelpText>
        <label>Screening Confidence</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>High</fullName><default>false</default><label>High</label></value>
                <value><fullName>Medium-High</fullName><default>false</default><label>Medium-High</label></value>
                <value><fullName>Medium</fullName><default>false</default><label>Medium</label></value>
                <value><fullName>Low</fullName><default>false</default><label>Low</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_extraordinary_circumstances__c</fullName>
        <description>Semicolon-delimited list of GIS-flagged extraordinary circumstances present at the project site (e.g., ESA Critical Habitat; Wetlands; Tribal Lands; Floodplain). Any value disqualifies CE and downgrades to EA per CEQ regulations.</description>
        <inlineHelpText>GIS-flagged extraordinary circumstances (e.g., ESA Critical Habitat; Wetlands). Any flag disqualifies CE.</inlineHelpText>
        <externalId>false</externalId>
        <label>Extraordinary Circumstances</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_classification_basis__c</fullName>
        <description>Audit trail of which CE Screener rule(s) fired, the matched tier, agency, and any override conditions applied. Written by the NEPA_CE_Screener Flow. Retained in the administrative record.</description>
        <inlineHelpText>Screener audit trail: which rule matched and why. Retained for the administrative record.</inlineHelpText>
        <label>Classification Basis</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>
    <!-- Provenance fields (CEQ Standard v1.2 - required on all entities) -->
    <fields>
        <fullName>nepa_data_record_version__c</fullName>
        <description>The version of the record, for tracking updates or changes to the data.</description>
        <inlineHelpText>Version of this record for data exchange tracking.</inlineHelpText>
        <externalId>false</externalId>
        <label>Data Record Version</label>
        <length>50</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_comment_period_days__c</fullName>
        <description>Number of calendar days between the public comment period start and end dates. Used by the Defensibility Gap Checker to verify the 30-day minimum required by 40 CFR 1503.1.</description>
        <inlineHelpText>Calculated days for the public comment period. Must be 30 or more for EIS processes.</inlineHelpText>
        <externalId>false</externalId>
        <formula>nepa_public_comment_period_end_date__c - nepa_public_comment_period_start__c</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Comment Period Days</label>
        <precision>18</precision>
        <required>false</required>
        <scale>0</scale>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_data_source_agency__c</fullName>
        <description>The name of the agency or organization that provided the data.</description>
        <inlineHelpText>Agency or organization that provided this data.</inlineHelpText>
        <externalId>false</externalId>
        <label>Data Source Agency</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_data_source_system__c</fullName>
        <description>The system or database where the data originally came from.</description>
        <inlineHelpText>Source system or database for this record.</inlineHelpText>
        <externalId>false</externalId>
        <label>Data Source System</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_record_owner_agency__c</fullName>
        <description>The agency responsible for maintaining or owning this record.</description>
        <inlineHelpText>Agency responsible for owning and maintaining this record.</inlineHelpText>
        <externalId>false</externalId>
        <label>Record Owner Agency</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_retrieved_timestamp__c</fullName>
        <description>The date and time when this record was retrieved from its source.</description>
        <inlineHelpText>Date and time this record was retrieved from its source system.</inlineHelpText>
        <label>Retrieved Timestamp</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>DateTime</type>
    </fields>

    <!-- P2 Data Quality fields -->
    <fields>
        <fullName>nepa_decision_document_type__c</fullName>
        <description>Type of decision document for this NEPA process. Separate from nepa_review_type__c (CE/EA/EIS) to fix doc_type conflation identified in feature engineering: ROD and FONSI must not co-label a CE process. Validation rule blocks FONSI/ROD when review type is CE.</description>
        <inlineHelpText>Decision document type (ROD, FONSI, NOA, DR). Separate from review type (CE/EA/EIS).</inlineHelpText>
        <label>Decision Document Type</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>ROD</fullName><default>false</default><label>Record of Decision (ROD)</label></value>
                <value><fullName>FONSI</fullName><default>false</default><label>Finding of No Significant Impact (FONSI)</label></value>
                <value><fullName>NOA</fullName><default>false</default><label>Notice of Availability (NOA)</label></value>
                <value><fullName>DR</fullName><default>false</default><label>Decision Record (DR)</label></value>
                <value><fullName>CE Determination</fullName><default>false</default><label>CE Determination</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_total_pages__c</fullName>
        <description>Total page count of the NEPA document package for this process. CE documents median 3-8 pages; EA 30-200; EIS 200+. Strong numeric discriminator (lift 0.68 in NEPATEC corpus). Used by CE Screener as a confidence modifier and by QA rules to flag implausibly thin documents.</description>
        <inlineHelpText>Total pages in the NEPA document package. CE: typically 3-8 pages; EA: 30-200; EIS: 200+.</inlineHelpText>
        <externalId>false</externalId>
        <label>Total Pages</label>
        <precision>6</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_pages_missing__c</fullName>
        <description>True when nepa_total_pages__c is blank. Surfaced on record page and in list views as a data-quality checklist flag. Auto-populating from ContentVersion attachment count is a future enhancement.</description>
        <inlineHelpText>Page count not yet entered. Enter total pages to improve CE screening accuracy.</inlineHelpText>
        <externalId>false</externalId>
        <formula>ISBLANK(nepa_total_pages__c)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Page Count Missing</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_ce_rationale_supplemental__c</fullName>
        <description>Free-text supplemental CE rationale. Companion to nepa_process_code__c (the structured CE code picklist). Addresses the ce_category free-text chaos identified in NEPATEC feature engineering — structured code goes in nepa_process_code__c; narrative explanation and non-standard citations go here.</description>
        <inlineHelpText>Supplemental CE rationale, non-standard citations, or coordinator notes. Use nepa_process_code__c for the structured CE code.</inlineHelpText>
        <label>CE Rationale Supplemental</label>
        <length>32768</length>
        <trackHistory>false</trackHistory>
        <type>LongTextArea</type>
        <visibleLines>3</visibleLines>
    </fields>

    <!-- P2 Validation rules -->
    <validationRules>
        <fullName>VR_Description_Minimum_Length</fullName>
        <active>true</active>
        <description>Enforces minimum 200-character description when nepa_description__c is populated. Addresses NEPATEC data quality finding: truncated descriptions and placeholder text degrade CE classification accuracy (feature lift 0.71). Fires only when description is non-blank to avoid blocking legacy records.</description>
        <errorConditionFormula>AND(
  NOT(ISBLANK(nepa_description__c)),
  LEN(nepa_description__c) &lt; 200
)</errorConditionFormula>
        <errorMessage>Process Description must be at least 200 characters. Include: purpose, location summary, disturbance type (new/existing/renewal), and estimated acreage. This improves CE screening accuracy.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>VR_FONSI_ROD_On_CE</fullName>
        <active>true</active>
        <description>Blocks FONSI or ROD as decision document type when the process review type is CE. Addresses NEPATEC doc_type conflation finding where ROD/FONSI appeared within the CE stratum, corrupting the training corpus. CE decisions use DR or CE Determination, not FONSI/ROD.</description>
        <errorConditionFormula>AND(
  ISPICKVAL(nepa_review_type__c, "CE"),
  OR(
    ISPICKVAL(nepa_decision_document_type__c, "FONSI"),
    ISPICKVAL(nepa_decision_document_type__c, "ROD")
  )
)</errorConditionFormula>
        <errorMessage>FONSI and ROD are not valid decision document types for a Categorical Exclusion (CE) process. Use "CE Determination" or "DR" for CE decision documents.</errorMessage>
    </validationRules>

    <!-- AI AUP compliance fields -->
    <fields>
        <fullName>nepa_ce_pathway_recommendation__c</fullName>
        <description>AI-recommended NEPA pathway set by NEPA_CE_Screener. Human NEPA Coordinator must confirm and set nepa_review_type__c before the pathway is official. Satisfies Salesforce AI AUP and OMB M-24-10 human-in-the-loop requirement: AI recommends, human decides.</description>
        <inlineHelpText>AI screening recommendation. Not official until a NEPA Coordinator reviews and confirms by setting the Review Type field.</inlineHelpText>
        <label>CE Pathway Recommendation (AI)</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Pending</fullName><default>false</default><label>Pending</label></value>
                <value><fullName>CE-Recommended</fullName><default>false</default><label>CE Recommended</label></value>
                <value><fullName>EA-Required</fullName><default>false</default><label>EA Required</label></value>
                <value><fullName>EIS-Required</fullName><default>false</default><label>EIS Required</label></value>
                <value><fullName>Escalated-Senior-Review</fullName><default>false</default><label>Escalated — Senior Review Required</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_risk_score_is_ai__c</fullName>
        <description>Always true. Permanently indicates that nepa_risk_score__c is computed by NEPA_Litigation_Risk_Scorer using PermitTEC v0.1 historical data. Required by Salesforce AI AUP: AI-generated scores must be disclosed as such. Field is formula-driven and cannot be overwritten.</description>
        <inlineHelpText>This risk score is AI-computed from PermitTEC v0.1 historical litigation data. Treat as analytical guidance — not a legal determination.</inlineHelpText>
        <externalId>false</externalId>
        <formula>TRUE</formula>
        <label>Risk Score is AI-Generated</label>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>

    <!-- P5 Litigation Guardrail fields -->
    <fields>
        <fullName>nepa_small_sample_warning__c</fullName>
        <description>True when the circuit matched in NEPA_Circuit_Risk_Weight__mdt has Low_Data_Confidence__c = true (fewer than 5 PermitTEC cases for that circuit). Set by NEPA_Litigation_Risk_Scorer. UI component shows warning: litigation risk estimate for this circuit is based on fewer than 5 historical cases — treat as directional only.</description>
        <inlineHelpText>Circuit risk estimate based on fewer than 5 historical cases. Treat as directional guidance only — not a statistical prediction.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Circuit Small Sample Warning</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_waiver_invoked__c</fullName>
        <description>True when the agency is asserting a statutory NEPA waiver (e.g., IIRIRA Section 102(c), EPAct Section 390). Triggers VR-003 validation rule: blocks save without an attached OGC legal sufficiency memo and valid funding authority citation per 42 USC 4332(2)(C).</description>
        <inlineHelpText>Check only when a statutory NEPA waiver applies. Requires OGC legal sufficiency memo before project can advance.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>NEPA Waiver Invoked</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_waiver_statute_cite__c</fullName>
        <description>Required when nepa_waiver_invoked__c is true. Must cite the specific statutory provision authorizing the NEPA waiver (e.g., IIRIRA Section 102(c); EPAct 2005 Section 390). VR-003 blocks save when this is blank and nepa_waiver_invoked__c is true.</description>
        <inlineHelpText>Statutory citation for the NEPA waiver (e.g., IIRIRA 102(c)). Required when waiver is invoked.</inlineHelpText>
        <externalId>false</externalId>
        <label>Waiver Statute Citation</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>nepa_tiering_to_prior_eis__c</fullName>
        <description>True when this EA or EIS is explicitly tiered from a prior programmatic EIS under 40 CFR 1502.20. Triggers VR-006: if the prior EIS is older than 5 years (nepa_prior_nepa_date__c), requires a supplementation review determination before proceeding.</description>
        <inlineHelpText>This process tiers from a prior programmatic EIS. A supplementation review is required if the prior EIS is more than 5 years old.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Tiering to Prior EIS</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_prior_nepa_date__c</fullName>
        <description>Date of the prior NEPA document that this process tiers from or supplements. Used by VR-006 to check whether the prior EIS is older than 5 years (1,825 days), requiring a documented supplementation review per 40 CFR 1502.9(c).</description>
        <inlineHelpText>Date of the prior NEPA document being tiered from. If more than 5 years old, a supplementation review determination is required.</inlineHelpText>
        <label>Prior NEPA Document Date</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Date</type>
    </fields>
    <fields>
        <fullName>nepa_supplementation_review_complete__c</fullName>
        <description>True when a responsible official has documented a written supplementation determination per 40 CFR 1502.9(c). Required by VR-001 (new info post-ROD) and VR-006 (tiering to EIS older than 5 years) to unblock stage gate. Part of the administrative record.</description>
        <inlineHelpText>Responsible official has documented a supplementation review determination. Required before tiering from a prior EIS older than 5 years.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Supplementation Review Complete</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <type>Checkbox</type>
    </fields>
    <fields>
        <fullName>nepa_esa_consultation_status__c</fullName>
        <description>Status of ESA Section 7 consultation for this process. VR-004 (implemented as a Stage Gate extension) blocks FONSI/ROD stage advancement until this field is set to a terminal status. Required for EA/EIS processes where the project area intersects listed species range.</description>
        <inlineHelpText>ESA Section 7 consultation status. Must reach a terminal status before FONSI or ROD can be issued.</inlineHelpText>
        <label>ESA Section 7 Consultation Status</label>
        <required>false</required>
        <trackHistory>true</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Not Required</fullName><default>false</default><label>Not Required (documented)</label></value>
                <value><fullName>No Effect</fullName><default>false</default><label>No Effect (documented)</label></value>
                <value><fullName>May Affect - Initiated</fullName><default>false</default><label>May Affect — Consultation Initiated</label></value>
                <value><fullName>Concurrence Received</fullName><default>false</default><label>Concurrence Received (informal)</label></value>
                <value><fullName>Biological Opinion Issued</fullName><default>false</default><label>Biological Opinion Issued (formal)</label></value>
                <value><fullName>Reinitiated</fullName><default>false</default><label>Reinitiated</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>

    <!-- P5 Validation rules (VR-003, VR-006) -->
    <validationRules>
        <fullName>VR_003_NEPA_Waiver_Legal_Sufficiency</fullName>
        <active>true</active>
        <description>VR-003: Blocks save when nepa_waiver_invoked__c is true but nepa_waiver_statute_cite__c is blank. Addresses DG-003: agencies have lost cases by asserting NEPA waivers without valid legal authority. OGC sign-off documentation must be in the administrative record. Field check only; OGC memo attachment is enforced separately by the Stage Gate flow.</description>
        <errorConditionFormula>AND(
  nepa_waiver_invoked__c = true,
  ISBLANK(nepa_waiver_statute_cite__c)
)</errorConditionFormula>
        <errorMessage>NEPA waiver is checked but no statutory citation is provided. Enter the specific statutory provision authorizing the waiver (e.g., IIRIRA Section 102(c); EPAct 2005 Section 390). An OGC legal sufficiency memo must also be attached before the project can advance to implementation.</errorMessage>
    </validationRules>
    <validationRules>
        <fullName>VR_006_Tiering_Age_Check</fullName>
        <active>true</active>
        <description>VR-006: Blocks save when tiering to a prior EIS older than 5 years (1,825 days) without a supplementation review completion. Addresses failure_to_supplement challenge type (100% agency loss rate in PermitTEC linked cases). Both nepa_tiering_to_prior_eis__c and nepa_prior_nepa_date__c must be populated for this rule to fire.</description>
        <errorConditionFormula>AND(
  nepa_tiering_to_prior_eis__c = true,
  NOT(ISBLANK(nepa_prior_nepa_date__c)),
  nepa_prior_nepa_date__c &lt; (TODAY() - 1825),
  nepa_supplementation_review_complete__c = false
)</errorConditionFormula>
        <errorMessage>The prior EIS this process tiers from is more than 5 years old. A documented supplementation review determination is required under 40 CFR 1502.9(c) before proceeding. Check "Supplementation Review Complete" once the responsible official has made a written determination.</errorMessage>
    </validationRules>

    <!-- Screener run timestamp — prevents CE Screener write-back from re-triggering Risk Scorer -->
    <fields>
        <fullName>nepa_screener_last_run__c</fullName>
        <description>Timestamp stamped by NEPA_CE_Screener immediately before it writes screening results. NEPA_Litigation_Risk_Scorer reads this to skip re-firing when nepa_review_type__c was changed by the screener rather than by a human. Guards against the CE Screener → Risk Scorer → CE Screener recursion chain.</description>
        <inlineHelpText>Populated automatically by the CE Screener. Do not edit manually.</inlineHelpText>
        <label>Screener Last Run</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>DateTime</type>
    </fields>

    <!-- Priority 5: Applicant intake completeness fields -->
    <fields>
        <fullName>nepa_applicant_contact__c</fullName>
        <description>Primary contact for the applicant organization. Used to route RFIs and correspondence during the intake phase.</description>
        <inlineHelpText>Primary contact for this applicant.</inlineHelpText>
        <label>Applicant Contact</label>
        <deleteConstraint>SetNull</deleteConstraint>
        <referenceTo>Contact</referenceTo>
        <relationshipLabel>NEPA Applications (Applicant Contact)</relationshipLabel>
        <relationshipName>NEPA_Applications_ApplicantContact</relationshipName>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Lookup</type>
    </fields>

    <fields>
        <fullName>nepa_submission_complete__c</fullName>
        <description>Set to true when the application package is confirmed complete by agency staff. Triggers downstream intake workflow and stops RFI creation.</description>
        <inlineHelpText>Check when the application package has been confirmed complete.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Submission Complete</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>

    <fields>
        <fullName>nepa_rfi_count__c</fullName>
        <description>Count of open RFI tasks against this application. Populated by record-triggered flow when nepa_submission_complete__c is false. Used by the intake completeness score and portal display.</description>
        <inlineHelpText>Number of open requests for information on this application.</inlineHelpText>
        <label>Open RFI Count</label>
        <precision>4</precision>
        <scale>0</scale>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>

    <fields>
        <fullName>nepa_flow_error_count__c</fullName>
        <description>Rollup count of NEPA_Flow_Error__c records whose nepa_record_id__c matches this application's Id. Increments automatically via a rollup summary flow (or Apex trigger in future) whenever a flow fault is logged. When this count exceeds a threshold, the SLA escalation flow fires a case and notifies the integration team. Text match rollup is not natively supported — this field is populated by NEPA_Error_Logger subflow incrementing it via a before-save flow on NEPA_Flow_Error__c insert.</description>
        <inlineHelpText>Count of flow errors logged against this application. High counts trigger escalation.</inlineHelpText>
        <label>Flow Error Count</label>
        <precision>6</precision>
        <scale>0</scale>
        <defaultValue>0</defaultValue>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Number</type>
        <unique>false</unique>
    </fields>

    <!-- Mandate 1: Portal comment intake formula kill-switch -->
    <fields>
        <fullName>nepa_portal_comment_intake_open__c</fullName>
        <description>Formula checkbox: true when NOW() is between nepa_public_comment_period_start__c and nepa_public_comment_period_end_date__c. Drives portal OmniScript conditional visibility and CMS page visibility rules without human admin intervention. Recomputed on every page load — no async lag.</description>
        <inlineHelpText>Portal comment intake is open when checked. Automatically closes at the exact end datetime — no manual toggle needed.</inlineHelpText>
        <externalId>false</externalId>
        <formula>AND(
  NOT(ISBLANK(nepa_public_comment_period_start__c)),
  NOT(ISBLANK(nepa_public_comment_period_end_date__c)),
  NOW() &gt;= nepa_public_comment_period_start__c,
  NOW() &lt; nepa_public_comment_period_end_date__c
)</formula>
        <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
        <label>Portal Comment Intake Open</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>

    <!-- Mandate 3: Expedited procedure APA risk fields -->
    <fields>
        <fullName>nepa_review_timeline_type__c</fullName>
        <description>Procedure type governing APA litigation exposure. Expedited/Emergency and Alternative Arrangement procedures with incomplete administrative records receive a 1.5x risk multiplier from NEPA_Litigation_Risk_Scorer. Standard procedures are unaffected.</description>
        <inlineHelpText>Standard, Expedited/Emergency (e.g. 14-day EA, 28-day EIS), or Alternative Arrangement. Expedited + incomplete record triggers APA risk penalty.</inlineHelpText>
        <label>Review Timeline Type</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Picklist</type>
        <valueSet>
            <restricted>true</restricted>
            <valueSetDefinition>
                <sorted>false</sorted>
                <value><fullName>Standard</fullName><default>true</default><label>Standard</label></value>
                <value><fullName>Expedited/Emergency</fullName><default>false</default><label>Expedited/Emergency</label></value>
                <value><fullName>Alternative Arrangement</fullName><default>false</default><label>Alternative Arrangement</label></value>
            </valueSetDefinition>
        </valueSet>
    </fields>
    <fields>
        <fullName>nepa_expedited_risk_penalty_applied__c</fullName>
        <description>Set to true by NEPA_Litigation_Risk_Scorer when nepa_review_timeline_type__c is Expedited/Emergency AND nepa_record_completeness__c is below 100. Indicates that the 1.5x APA arbitrary-and-capricious risk multiplier was applied. Audit flag for legal review.</description>
        <inlineHelpText>APA risk penalty applied: expedited procedure + incomplete administrative record. Review completeness score and fill gaps immediately.</inlineHelpText>
        <defaultValue>false</defaultValue>
        <label>Expedited Risk Penalty Applied</label>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <type>Checkbox</type>
    </fields>
</CustomObject>
