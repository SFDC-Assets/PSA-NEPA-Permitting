@SuppressWarnings('PMD.ApexUnitTestClassShouldHaveRunAs,PMD.ApexDoc,PMD.ApexAssertionsShouldIncludeMessage,PMD.MethodNamingConventions')
@IsTest(SeeAllData=false)
private class NepaVisitCompletionAssessorTest {

    // ── @TestSetup: shared Program ────────────────────────────────────────────
    // Each test creates its own IA so assertions are isolated.
    // Program is shared because it has no bearing on the flag outcome.

    @TestSetup
    static void makeData() {
        NepaTestFactory.insertProgram('VCA-PROG-001', 'Visit Completion Assessor Test Project', 'BLM');
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static Program getProgram() {
        return [SELECT Id FROM Program WHERE nepa_project_id__c = 'VCA-PROG-001' LIMIT 1];
    }

    private static IndividualApplication insertIA() {
        return NepaTestFactory.insertOpenProcess(getProgram().Id, 'EIS');
    }

    private static IndividualApplication insertIAWithFlagSet() {
        IndividualApplication ia = NepaTestFactory.makeProcess(getProgram().Id, 'EIS', null, null);
        ia.nepa_surveys_complete__c = true;
        insert ia;
        return ia;
    }

    private static Visit buildHardGateVisit(Id processId, Boolean autoGenerated) {
        Visit v = new Visit();
        v.nepa_process__c       = processId;
        v.nepa_hard_gate__c     = true;
        v.nepa_auto_generated__c = autoGenerated;
        v.Status                = 'Planned';
        return v;
    }

    // ── Test 1: last hard-gate visit complete → sets flag ────────────────────

    @IsTest
    static void lastHardGateVisitComplete_setsSurveysComplete() {
        IndividualApplication ia = insertIA();

        Visit v = buildHardGateVisit(ia.Id, true);
        insert v;

        Test.startTest();
        v.Status = 'Completed';
        update v;
        Test.stopTest();

        IndividualApplication result = [
            SELECT nepa_surveys_complete__c FROM IndividualApplication WHERE Id = :ia.Id
        ];
        System.assertEquals(true, result.nepa_surveys_complete__c,
            'nepa_surveys_complete__c must be true when the last hard-gate visit is completed');
    }

    // ── Test 2: two hard-gate visits — flag sets only after the last ──────────

    @IsTest
    static void twoHardGateVisits_onlyLastSets() {
        IndividualApplication ia = insertIA();

        Visit v1 = buildHardGateVisit(ia.Id, true);
        Visit v2 = buildHardGateVisit(ia.Id, true);
        insert new List<Visit>{ v1, v2 };

        // Complete first visit outside startTest/stopTest so we can assert interim state
        v1.Status = 'Completed';
        update v1;

        // After first completion, second is still open — flag must remain false
        IndividualApplication interim = [
            SELECT nepa_surveys_complete__c FROM IndividualApplication WHERE Id = :ia.Id
        ];
        System.assertEquals(false, interim.nepa_surveys_complete__c,
            'nepa_surveys_complete__c must be false while a second hard-gate visit is still open');

        // Complete second (last) visit
        Test.startTest();
        v2.Status = 'Completed';
        update v2;
        Test.stopTest();

        IndividualApplication result = [
            SELECT nepa_surveys_complete__c FROM IndividualApplication WHERE Id = :ia.Id
        ];
        System.assertEquals(true, result.nepa_surveys_complete__c,
            'nepa_surveys_complete__c must be true after all hard-gate visits are completed');
    }

    // ── Test 3: non-hard-gate visit completion does not set flag ─────────────

    @IsTest
    static void nonHardGateVisit_doesNotSet() {
        IndividualApplication ia = insertIA();

        Visit v = new Visit();
        v.nepa_process__c        = ia.Id;
        v.nepa_hard_gate__c      = false;
        v.nepa_auto_generated__c = true;
        v.Status                 = 'Planned';
        insert v;

        Test.startTest();
        v.Status = 'Completed';
        update v;
        Test.stopTest();

        IndividualApplication result = [
            SELECT nepa_surveys_complete__c FROM IndividualApplication WHERE Id = :ia.Id
        ];
        System.assertEquals(false, result.nepa_surveys_complete__c,
            'Flow must not fire when nepa_hard_gate__c is false — entry filter 3 blocks it');
    }

    // ── Test 4: visit with null nepa_process__c — flow entry filter blocks ────

    @IsTest
    static void visitWithoutProcess_doesNotFire() {
        IndividualApplication ia = insertIA();

        Visit v = new Visit();
        v.nepa_process__c        = null;
        v.nepa_hard_gate__c      = true;
        v.nepa_auto_generated__c = true;
        v.Status                 = 'Planned';
        insert v;

        Boolean threw = false;
        Test.startTest();
        try {
            v.Status = 'Completed';
            update v;
        } catch (Exception e) {
            threw = true;
        }
        Test.stopTest();

        System.assertEquals(false, threw,
            'Completing a Visit with no nepa_process__c must not throw');

        IndividualApplication result = [
            SELECT nepa_surveys_complete__c FROM IndividualApplication WHERE Id = :ia.Id
        ];
        System.assertEquals(false, result.nepa_surveys_complete__c,
            'nepa_surveys_complete__c must not be set when the Visit has no nepa_process__c');
    }

    // ── Test 5: flag already true — no error, idempotent ─────────────────────

    @IsTest
    static void alreadySetFlag_noRedundantDml() {
        IndividualApplication ia = insertIAWithFlagSet();

        Visit v = buildHardGateVisit(ia.Id, true);
        insert v;

        Boolean threw = false;
        Test.startTest();
        try {
            v.Status = 'Completed';
            update v;
        } catch (Exception e) {
            threw = true;
        }
        Test.stopTest();

        System.assertEquals(false, threw,
            'Flow must not throw when nepa_surveys_complete__c is already true');

        IndividualApplication result = [
            SELECT nepa_surveys_complete__c FROM IndividualApplication WHERE Id = :ia.Id
        ];
        System.assertEquals(true, result.nepa_surveys_complete__c,
            'nepa_surveys_complete__c must remain true after Decision_AlreadySet short-circuit');
    }

    // ── Test 6: non-auto-generated hard-gate visit, open auto-generated exists ─
    // Flow fires (entry criteria: hard_gate=true, status changed to Completed, process not null).
    // Get_AnyOpenHardGateVisit finds the open auto-generated visit → Decision_AnyStillOpen
    // exits → flag stays false.

    @IsTest
    static void nonAutoGeneratedVisit_openAutoGenStillBlocks() {
        IndividualApplication ia = insertIA();

        // Auto-generated hard-gate visit — stays open
        Visit autoV = buildHardGateVisit(ia.Id, true);
        insert autoV;

        // Non-auto-generated hard-gate visit — will be completed
        Visit manualV = new Visit();
        manualV.nepa_process__c        = ia.Id;
        manualV.nepa_hard_gate__c      = true;
        manualV.nepa_auto_generated__c = false;
        manualV.Status                 = 'Planned';
        insert manualV;

        Test.startTest();
        manualV.Status = 'Completed';
        update manualV;
        Test.stopTest();

        IndividualApplication result = [
            SELECT nepa_surveys_complete__c FROM IndividualApplication WHERE Id = :ia.Id
        ];
        System.assertEquals(false, result.nepa_surveys_complete__c,
            'Flag must remain false when an auto-generated hard-gate visit is still open');
    }

    // ── Test 7: bulk — 250 hard-gate auto-generated visits all completed ───────

    @IsTest
    static void bulkPath_250Visits_allComplete() {
        IndividualApplication ia = insertIA();

        List<Visit> visits = new List<Visit>();
        for (Integer i = 0; i < 250; i++) {
            visits.add(buildHardGateVisit(ia.Id, true));
        }
        insert visits;

        List<Visit> completions = new List<Visit>();
        for (Visit v : visits) {
            completions.add(new Visit(Id = v.Id, Status = 'Completed'));
        }

        Test.startTest();
        update completions;
        Test.stopTest();

        IndividualApplication result = [
            SELECT nepa_surveys_complete__c FROM IndividualApplication WHERE Id = :ia.Id
        ];
        System.assertEquals(true, result.nepa_surveys_complete__c,
            'nepa_surveys_complete__c must be true after all 250 hard-gate visits are completed');
    }
}
