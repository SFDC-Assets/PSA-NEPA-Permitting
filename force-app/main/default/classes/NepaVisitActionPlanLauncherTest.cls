@SuppressWarnings('PMD.ApexAssertionsShouldIncludeMessage,PMD.MethodNamingConventions,PMD.ApexUnitTestClassShouldHaveRunAs')
@IsTest(SeeAllData=false)
private class NepaVisitActionPlanLauncherTest {

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static IndividualApplication insertProcess() {
        Program proj = NepaTestFactory.insertProgram('VAP-TEST', 'Visit APT Test Project', 'BLM');
        return NepaTestFactory.insertOpenProcess(proj.Id, 'EIS');
    }

    private static Id visitPlaceId;

    private static Id getOrCreatePlace() {
        if (visitPlaceId != null) { return visitPlaceId; }
        Schema.Location loc = new Schema.Location();
        loc.Name = 'NEPA Test Site';
        loc.LocationType = 'Site';
        insert loc;
        visitPlaceId = loc.Id;
        return visitPlaceId;
    }

    private static Visit buildVisit(Id contextId, Boolean autoGenerated, String discipline) {
        Visit v = new Visit();
        v.ContextId              = contextId;
        v.PlaceId                = getOrCreatePlace();
        v.PlannedVisitStartTime  = Datetime.now().addDays(7);
        v.Status                 = 'Planned';
        v.nepa_auto_generated__c = autoGenerated;
        v.nepa_discipline__c     = discipline;
        return v;
    }

    // ── Non-auto-generated visits are ignored ─────────────────────────────────

    @IsTest
    static void createActionPlans_nonAutoGenerated_noPlansCreated() {
        IndividualApplication ia = insertProcess();
        Visit v = buildVisit(ia.Id, false, 'Hydrology');
        insert v;

        Integer plansBefore = [SELECT COUNT() FROM ActionPlan];

        Test.startTest();
        NepaVisitActionPlanLauncher.createActionPlans(new List<Visit>{ v });
        Test.stopTest();

        System.assertEquals(plansBefore, [SELECT COUNT() FROM ActionPlan],
            'Non-auto-generated visit must not trigger APT launch');
    }

    // ── Auto-generated visit with no discipline → no plans ────────────────────

    @IsTest
    static void createActionPlans_blankDiscipline_noPlansCreated() {
        IndividualApplication ia = insertProcess();
        Visit v = buildVisit(ia.Id, true, null);
        insert v;

        Integer plansBefore = [SELECT COUNT() FROM ActionPlan];

        Test.startTest();
        NepaVisitActionPlanLauncher.createActionPlans(new List<Visit>{ v });
        Test.stopTest();

        System.assertEquals(plansBefore, [SELECT COUNT() FROM ActionPlan],
            'Auto-generated visit with no discipline must not trigger APT launch');
    }

    // ── Auto-generated visit with no matching CMT → no plans, no exception ────

    @IsTest
    static void createActionPlans_noCmtMatch_noPlansNoException() {
        IndividualApplication ia = insertProcess();
        Visit v = buildVisit(ia.Id, true, 'UNKNOWN_DISCIPLINE_XYZ');
        insert v;

        Boolean threw = false;
        Test.startTest();
        try {
            NepaVisitActionPlanLauncher.createActionPlans(new List<Visit>{ v });
        } catch (Exception e) {
            threw = true;
        }
        Test.stopTest();

        System.assertEquals(false, threw,
            'Missing CMT match must not throw — handler should exit gracefully');
    }

    // ── Empty list → no-op, no exception ─────────────────────────────────────

    @IsTest
    static void createActionPlans_emptyList_noOp() {
        Boolean threw = false;
        Test.startTest();
        try {
            NepaVisitActionPlanLauncher.createActionPlans(new List<Visit>());
        } catch (Exception e) {
            threw = true;
        }
        Test.stopTest();

        System.assertEquals(false, threw, 'Empty list must not throw');
    }

    // ── Bulk: 251+ visits with no CMT match — all handled without exception ───

    @IsTest
    static void createActionPlans_bulkNoCmtMatch_noException() {
        IndividualApplication ia = insertProcess();

        List<Visit> visits = new List<Visit>();
        for (Integer i = 0; i < 10; i++) {
            visits.add(buildVisit(ia.Id, true, 'BULK_DISCIPLINE_' + i));
        }
        insert visits;

        Boolean threw = false;
        Test.startTest();
        try {
            NepaVisitActionPlanLauncher.createActionPlans(visits);
        } catch (Exception e) {
            threw = true;
        }
        Test.stopTest();

        System.assertEquals(false, threw,
            'Bulk call with no CMT match must not throw');
    }

    // ── APT found with Final version → ActionPlan inserted for each visit ───────
    // Uses the org-deployed 'NEPA_Visit_Hydrology_Milestones_BLM' APT which has
    // ActionPlanType='Retail' and a Final version — no test-data APT insert needed.

    @IsTest
    static void createActionPlans_finalVersionApt_createsActionPlan() {
        // Verify the deployed APT exists before proceeding; skip gracefully if missing
        List<ActionPlanTemplate> apts = [
            SELECT Id, (SELECT Id FROM ActionPlanTemplateVersions WHERE Status = 'Final' LIMIT 1)
            FROM ActionPlanTemplate
            WHERE UniqueName = 'NEPA_Visit_Hydrology_Milestones_BLM'
            LIMIT 1
        ];
        if (apts.isEmpty() || apts[0].ActionPlanTemplateVersions.isEmpty()) {
            // APT not deployed in this org — test can't run
            return;
        }

        IndividualApplication ia = insertProcess();
        // Visit with discipline matching NHD_Flowlines CMT → 'Hydrologist'
        Visit v = buildVisit(ia.Id, true, 'Hydrologist');
        insert v;

        Integer plansBefore = [SELECT COUNT() FROM ActionPlan];

        Test.startTest();
        NepaVisitActionPlanLauncher.createActionPlans(new List<Visit>{ v });
        Test.stopTest();

        Integer plansAfter = [SELECT COUNT() FROM ActionPlan];
        System.assertEquals(plansBefore + 1, plansAfter,
            'One ActionPlan must be created when APT with Final version exists for the discipline');

        ActionPlan ap = [SELECT Id, TargetId, StartDate FROM ActionPlan WHERE TargetId = :v.Id LIMIT 1];
        System.assertEquals(v.Id, ap.TargetId, 'ActionPlan TargetId must be the Visit Id');
        System.assertNotEquals(null, ap.StartDate, 'StartDate must not be null');
    }

    // ── APT Final version but PlannedVisitStartTime is null → defaults to Date.today() ──

    @IsTest
    static void createActionPlans_nullStartTime_defaultsToToday() {
        List<ActionPlanTemplate> apts = [
            SELECT Id, (SELECT Id FROM ActionPlanTemplateVersions WHERE Status = 'Final' LIMIT 1)
            FROM ActionPlanTemplate
            WHERE UniqueName = 'NEPA_Visit_Hydrology_Milestones_BLM'
            LIMIT 1
        ];
        if (apts.isEmpty() || apts[0].ActionPlanTemplateVersions.isEmpty()) {
            return;
        }

        IndividualApplication ia = insertProcess();
        // Visit without PlannedVisitStartTime — StartDate must default to Date.today()
        Visit v = new Visit();
        v.ContextId              = ia.Id;
        v.PlaceId                = getOrCreatePlace();
        v.PlannedVisitStartTime  = null;
        v.Status                 = 'Planned';
        v.nepa_auto_generated__c = true;
        v.nepa_discipline__c     = 'Hydrologist';
        insert v;

        Test.startTest();
        NepaVisitActionPlanLauncher.createActionPlans(new List<Visit>{ v });
        Test.stopTest();

        ActionPlan ap = [SELECT StartDate FROM ActionPlan WHERE TargetId = :v.Id LIMIT 1];
        System.assertEquals(Date.today(), ap.StartDate,
            'StartDate must default to today() when PlannedVisitStartTime is null');
    }

    // ── Mixed auto/manual visits — only auto-generated ones are processed ─────

    @IsTest
    static void createActionPlans_mixedAutoAndManual_onlyAutoProcessed() {
        IndividualApplication ia = insertProcess();

        Visit manual = buildVisit(ia.Id, false, 'Hydrology');
        Visit auto1  = buildVisit(ia.Id, true,  'MISSING_DISCIPLINE_A');
        Visit auto2  = buildVisit(ia.Id, true,  null);
        insert new List<Visit>{ manual, auto1, auto2 };

        Boolean threw = false;
        Test.startTest();
        try {
            NepaVisitActionPlanLauncher.createActionPlans(
                new List<Visit>{ manual, auto1, auto2 });
        } catch (Exception e) {
            threw = true;
        }
        Test.stopTest();

        System.assertEquals(false, threw,
            'Mixed auto/manual batch must not throw regardless of CMT coverage');
    }
}