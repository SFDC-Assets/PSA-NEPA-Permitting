      "Type": "DataRaptor Extract Action",
      "SequenceNumber": 1,
      "Level": 0,
      "IsActive": true,
      "PropertySetConfig": {
        "bundleName": "DR_Extract_NEPA_Process",
        "inputMap": [
          {
            "name": "processId",
            "value": "%processId%",
            "valueType": "reference"
          }
        ],
        "outputPath": "ProcessData",
        "chainOnStep": "",
        "failOnStepError": true,
        "mergeOutputWithParent": false
      }
    },
    {
      "Name": "GetProjectForScreening",
      "Type": "DataRaptor Extract Action",
      "SequenceNumber": 2,
      "Level": 0,
      "IsActive": true,
