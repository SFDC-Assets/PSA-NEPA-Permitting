  "SubType": "CE_Screening_IP",
  "Language": "English",
  "VersionNumber": 1,
  "IsActive": true,
  "IsIntegrationProcedure": true,
  "Description": "CE screening Integration Procedure. Accepts project and process context, calls the NEPA_CE_Screener Expression Set BRE, and returns ReviewType, CECode, Confidence, and ClassificationBasis. Called by the NEPA_CE_Intake OmniScript on the screening step.",
  "PropertySetConfig": "{\"persistentComponent\":true,\"trackingCustomData\":{},\"enableLWCRuntime\":true}",
  "WebComponentKey": "NEPA/CE_Screening_IP/English/1",
