            "value": "%ProcessData:nepa_disturbance_acres__c%",
            "valueType": "reference"
          }
        ]
      }
    },
    {
      "Name": "CallCEScreenerBRE",
      "Type": "Expression Set",
      "SequenceNumber": 4,
      "Level": 0,
      "IsActive": true,
      "PropertySetConfig": {
        "expressionSetApiName": "NEPA_CE_Screener",
        "inputMap": [
          {
            "name": "AgencyAbbr",
            "value": "%AgencyAbbr%",
            "valueType": "reference"
          },
          {
            "name": "NAICSCode",
            "value": "%NAICSCode%",
            "valueType": "reference"
          },
          {
            "name": "SectorKey",
            "value": "%SectorKey%",
            "valueType": "reference"
          },
          {
            "name": "TypeKey",
            "value": "%TypeKey%",
