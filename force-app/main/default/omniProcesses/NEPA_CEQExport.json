{
  "Name": "NEPA_CEQExport",
  "Type": "NEPA",
  "SubType": "CEQExport",
  "Language": "English",
  "VersionNumber": 1,
  "IsActive": true,
  "IsIntegrationProcedure": true,
  "Description": "Assembles a CEQ NEPA and Permitting Data and Technology Standard v1.2 compliant JSON payload for a given Project (Program). Inputs: projectId (Program.Id). Output: CEQPayload containing all 9 implemented entities: Project (with project-level GIS Data), Processes (with Documents + Comments, Team Members, Legal Structure, process-level GIS Data), Public Engagement Events, and Case Events.",
  "PropertySetConfig": "{\"persistentComponent\":true,\"trackingCustomData\":{},\"enableLWCRuntime\":true}",
  "WebComponentKey": "NEPA/CEQExport/English/1",
  "Elements": [
    {
      "Name": "GetProject",
      "Type": "DataRaptor Extract Action",
      "SequenceNumber": 1,
      "Level": 0,
      "IsActive": true,
      "PropertySetConfig": {
        "bundleName": "DR_Extract_NEPA_Project",
        "inputMap": [
          {
            "name": "projectId",
            "value": "%projectId%",
            "valueType": "reference"
          }
        ],
        "outputPath": "Project",
        "chainOnStep": "",
        "failOnStepError": true,
        "postTransformBundle": "",
        "remoteClass": "",
        "remoteMethod": ""
      }
    },
    {
      "Name": "GetGISData",
      "Type": "DataRaptor Extract Action",
      "SequenceNumber": 2,
      "Level": 0,
      "IsActive": true,
      "PropertySetConfig": {
        "bundleName": "DR_Extract_NEPA_GISData",
        "inputMap": [
          {
            "name": "projectId",
            "value": "%projectId%",
            "valueType": "reference"
          }
        ],
        "outputPath": "Project:gis_data",
        "chainOnStep": "",
        "failOnStepError": false,
        "postTransformBundle": "",
        "remoteClass": "",
        "remoteMethod": ""
      }
    },
    {
      "Name": "GetProcesses",
      "Type": "DataRaptor Extract Action",
      "SequenceNumber": 3,
      "Level": 0,
      "IsActive": true,
      "PropertySetConfig": {
        "bundleName": "DR_Extract_NEPA_Process",
        "inputMap": [
          {
            "name": "projectId",
            "value": "%projectId%",
            "valueType": "reference"
          }
        ],
        "outputPath": "processes",
        "chainOnStep": "",
        "failOnStepError": false,
        "postTransformBundle": "",
        "remoteClass": "",
        "remoteMethod": ""
      }
    },
    {
      "Name": "LoopProcesses",
      "Type": "Loop",
      "SequenceNumber": 4,
      "Level": 0,
      "IsActive": true,
      "PropertySetConfig": {
        "loopInput": "%processes%",
        "currentItemOutput": "currentProcess",
        "indexOutput": "processIndex"
      },
      "Children": [
        {
          "Name": "GetDocuments",
          "Type": "DataRaptor Extract Action",
          "SequenceNumber": 1,
          "Level": 1,
          "IsActive": true,
          "PropertySetConfig": {
            "bundleName": "DR_Extract_NEPA_Document",
            "inputMap": [
              {
                "name": "processId",
                "value": "%currentProcess:id%",
                "valueType": "reference"
              }
            ],
            "outputPath": "documents",
            "failOnStepError": false,
            "postTransformBundle": ""
          }
        },
        {
          "Name": "LoopDocuments",
          "Type": "Loop",
          "SequenceNumber": 2,
          "Level": 1,
          "IsActive": true,
          "PropertySetConfig": {
            "loopInput": "%documents%",
            "currentItemOutput": "currentDocument",
            "indexOutput": "documentIndex"
          },
          "Children": [
            {
              "Name": "GetComments",
              "Type": "DataRaptor Extract Action",
              "SequenceNumber": 1,
              "Level": 2,
              "IsActive": true,
              "PropertySetConfig": {
                "bundleName": "DR_Extract_NEPA_Comment",
                "inputMap": [
                  {
                    "name": "documentId",
                    "value": "%currentDocument:id%",
                    "valueType": "reference"
                  }
                ],
                "outputPath": "currentDocument:comments",
                "failOnStepError": false,
                "postTransformBundle": ""
              }
            }
          ]
        },
        {
          "Name": "AssignDocumentsToProcess",
          "Type": "Set Values",
          "SequenceNumber": 3,
          "Level": 1,
          "IsActive": true,
          "PropertySetConfig": {
            "ElementValueMap": {
              "currentProcess:documents": "%documents%"
            }
          }
        },
        {
          "Name": "GetEngagementEvents",
          "Type": "DataRaptor Extract Action",
          "SequenceNumber": 4,
          "Level": 1,
          "IsActive": true,
          "PropertySetConfig": {
            "bundleName": "DR_Extract_NEPA_EngagementEvent",
            "inputMap": [
              {
                "name": "processId",
                "value": "%currentProcess:id%",
                "valueType": "reference"
              }
            ],
            "outputPath": "currentProcess:public_engagement_events",
            "failOnStepError": false,
            "postTransformBundle": ""
          }
        },
        {
          "Name": "GetCaseEvents",
          "Type": "DataRaptor Extract Action",
          "SequenceNumber": 5,
          "Level": 1,
          "IsActive": true,
          "PropertySetConfig": {
            "bundleName": "DR_Extract_NEPA_CaseEvent",
            "inputMap": [
              {
                "name": "processId",
                "value": "%currentProcess:id%",
                "valueType": "reference"
              }
            ],
            "outputPath": "currentProcess:case_events",
            "failOnStepError": false,
            "postTransformBundle": ""
          }
        },
        {
          "Name": "GetTeamMembers",
          "Type": "DataRaptor Extract Action",
          "SequenceNumber": 6,
          "Level": 1,
          "IsActive": true,
          "PropertySetConfig": {
            "bundleName": "DR_Extract_NEPA_TeamMember",
            "inputMap": [
              {
                "name": "processId",
                "value": "%currentProcess:id%",
                "valueType": "reference"
              }
            ],
            "outputPath": "currentProcess:team_members",
            "failOnStepError": false,
            "postTransformBundle": ""
          }
        },
        {
          "Name": "GetLegalStructure",
          "Type": "DataRaptor Extract Action",
          "SequenceNumber": 7,
          "Level": 1,
          "IsActive": true,
          "PropertySetConfig": {
            "bundleName": "DR_Extract_NEPA_LegalStructure",
            "inputMap": [
              {
                "name": "legalStructureId",
                "value": "%currentProcess:legal_structure_id%",
                "valueType": "reference"
              }
            ],
            "outputPath": "currentProcess:legal_structure",
            "failOnStepError": false,
            "postTransformBundle": ""
          }
        },
        {
          "Name": "GetGISDataForProcess",
          "Type": "DataRaptor Extract Action",
          "SequenceNumber": 8,
          "Level": 1,
          "IsActive": true,
          "PropertySetConfig": {
            "bundleName": "DR_Extract_NEPA_GISData_ByProcess",
            "inputMap": [
              {
                "name": "processId",
                "value": "%currentProcess:id%",
                "valueType": "reference"
              }
            ],
            "outputPath": "currentProcess:gis_data",
            "failOnStepError": false,
            "postTransformBundle": ""
          }
        }
      ]
    },
    {
      "Name": "AssembleCEQPayload",
      "Type": "Set Values",
      "SequenceNumber": 5,
      "Level": 0,
      "IsActive": true,
      "PropertySetConfig": {
        "ElementValueMap": {
          "CEQPayload:schema_version": "1.2",
          "CEQPayload:standard": "CEQ NEPA and Permitting Data and Technology Standard",
          "CEQPayload:exported_at": "%System.CurrentDateTime%",
          "CEQPayload:project": "%Project%",
          "CEQPayload:project:processes": "%processes%"
        }
      }
    }
  ]
}
