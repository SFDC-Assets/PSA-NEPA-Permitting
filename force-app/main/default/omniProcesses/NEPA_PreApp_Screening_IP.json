            "value": "%LeadAgencyKey%",
            "valueType": "reference"
          }
        ],
        "outputPath": "MatrixData",
        "chainOnStep": "CallCEScreenerBRE",
        "failOnStepError": false,
        "mergeOutputWithParent": false
      }
    },
