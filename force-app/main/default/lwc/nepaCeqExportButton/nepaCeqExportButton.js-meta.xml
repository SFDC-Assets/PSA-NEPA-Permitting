<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <isExposed>true</isExposed>
    <description>CEQ Data Standard v1.2 export button. Calls NepaCeqExportService.generateCeqExport and triggers a browser JSON file download. Place on the IndividualApplication (Process) record page.</description>
    <targets>
        <target>lightning__RecordPage</target>
        <target>lightning__AppPage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <objects>
                <object>IndividualApplication</object>
            </objects>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
