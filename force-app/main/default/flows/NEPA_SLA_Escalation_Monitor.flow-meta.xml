<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <description>Scheduled flow — runs daily. Queries active IndividualApplication records with a populated nepa_sla_due_date__c that have not yet reached a terminal process status (completed or cancelled). Before querying processes, iterates col_SLAConfigs to compute var_MaxWarningDays (the widest warning window across all review types) for the query bound, and reuses col_SLAConfigs per outer-loop iteration to look up the per-review-type warning window (var_SpecificWarningDays). For each record, evaluates: (1) overdue — TODAY > due date; (2) in warning window — due date &lt;= TODAY + review-type-specific warning days AND warning not yet sent. FeedItem records are collected in col_FeedItemsToCreate and bulk-created in a single DML call after the loop (no DML-in-loop). Record flag updates are also bulk operations. Fault paths log to NEPA_Error_Logger. Schedule must be configured at activation time in Flow Builder.</description>
    <label>NEPA SLA Escalation Monitor</label>
    <processType>AutoLaunchedFlow</processType>
    <status>Active</status>

    <!-- ============================================================
         ASSIGNMENTS
    ============================================================ -->

    <!-- Stage overdue record for bulk update collection; connector → FeedItem staging -->
    <assignments>
        <name>Build_OverdueUpdate</name>
        <label>Stage Overdue Flag Update</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_UpdateRecord.Id</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_Processes.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_UpdateRecord.nepa_sla_overdue__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>col_OverdueUpdates</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>var_UpdateRecord</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Stage_Overdue_FeedItem</targetReference>
        </connector>
    </assignments>

    <!-- Stage warning record for bulk update collection; connector → FeedItem staging -->
    <assignments>
        <name>Build_WarningUpdate</name>
        <label>Stage Warning Flag Update</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_UpdateRecord.Id</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_Processes.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_UpdateRecord.nepa_sla_warning_sent__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>col_WarningUpdates</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>var_UpdateRecord</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Stage_Warning_FeedItem</targetReference>
        </connector>
    </assignments>

    <!-- Build and collect overdue FeedItem — no DML here, bulk create after loop (M5 fix) -->
    <assignments>
        <name>Stage_Overdue_FeedItem</name>
        <label>Collect Overdue Chatter Notification</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_FeedItem.ParentId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_Processes.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_FeedItem.Body</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>⚠️ SLA OVERDUE: This {!Loop_Processes.nepa_review_type__c} review passed its SLA deadline of {!Loop_Processes.nepa_sla_due_date__c}. Immediate action required to document the cause and update the project timeline.</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_FeedItem.Type</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>TextPost</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>col_FeedItemsToCreate</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>var_FeedItem</elementReference>
            </value>
        </assignmentItems>
        <!-- No connector — returns control to loop for next iteration -->
    </assignments>

    <!-- Build and collect warning FeedItem — no DML here, bulk create after loop (M5 fix) -->
    <assignments>
        <name>Stage_Warning_FeedItem</name>
        <label>Collect Warning Chatter Notification</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_FeedItem.ParentId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_Processes.Id</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_FeedItem.Body</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>📅 SLA WARNING: This {!Loop_Processes.nepa_review_type__c} review is approaching its SLA deadline of {!Loop_Processes.nepa_sla_due_date__c}. Please review the project schedule and confirm the process is on track.</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_FeedItem.Type</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>TextPost</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>col_FeedItemsToCreate</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>var_FeedItem</elementReference>
            </value>
        </assignmentItems>
        <!-- No connector — returns control to loop for next iteration -->
    </assignments>

    <!-- Update var_MaxWarningDays when current CMT config is wider (M4 fix) -->
    <assignments>
        <name>Update_MaxWarning</name>
        <label>Update Max Warning Days</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_MaxWarningDays</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_ComputeMaxWarning.Warning_Days_Before_Due__c</elementReference>
            </value>
        </assignmentItems>
        <!-- No connector — inner loop resumes to next CMT record -->
    </assignments>

    <!-- Reset specific warning days to max fallback before inner lookup loop (M4 fix) -->
    <assignments>
        <name>Init_SpecificWarningDays</name>
        <label>Reset Specific Warning Days to Max Fallback</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_SpecificWarningDays</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>var_MaxWarningDays</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_FindConfigForProcess</targetReference>
        </connector>
    </assignments>

    <!-- Set per-review-type warning days when inner loop finds a matching config (M4 fix) -->
    <assignments>
        <name>Set_SpecificWarningDays</name>
        <label>Set Specific Warning Days for Review Type</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_SpecificWarningDays</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_FindConfigForProcess.Warning_Days_Before_Due__c</elementReference>
            </value>
        </assignmentItems>
        <!-- No connector — inner loop resumes to next CMT record -->
    </assignments>

    <!-- Error handlers -->
    <assignments>
        <name>Handle_QueryError</name>
        <label>Capture Query Error</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_ErrorMessage</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Flow.FaultMessage</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>var_CurrentStep</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Get_ActiveProcesses</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Call_ErrorLogger</targetReference>
        </connector>
    </assignments>

    <assignments>
        <name>Handle_UpdateError</name>
        <label>Capture Update Error</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>var_ErrorMessage</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Flow.FaultMessage</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Call_ErrorLogger</targetReference>
        </connector>
    </assignments>

    <!-- ============================================================
         DECISIONS
    ============================================================ -->

    <decisions>
        <name>Decision_ConfigsLoaded</name>
        <label>SLA Configs Loaded?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No Active Configs — exit</defaultConnectorLabel>
        <rules>
            <name>Configs_Present</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>col_SLAConfigs</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <!-- Route to max-warning-days computation before querying processes (M4 fix) -->
            <connector>
                <targetReference>Loop_ComputeMaxWarning</targetReference>
            </connector>
            <label>Configs Present</label>
        </rules>
    </decisions>

    <decisions>
        <name>Decision_ProcessesFound</name>
        <label>Processes to Evaluate?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>None — exit cleanly</defaultConnectorLabel>
        <rules>
            <name>Processes_Present</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>col_ActiveProcesses</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Loop_Processes</targetReference>
            </connector>
            <label>Processes Present</label>
        </rules>
    </decisions>

    <!-- Determine if current CMT config's warning window exceeds the running maximum (M4 fix) -->
    <decisions>
        <name>Decision_IsNewMax</name>
        <label>Config Warning Days Exceeds Current Max?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Not higher — skip</defaultConnectorLabel>
        <rules>
            <name>Is_New_Max</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_ComputeMaxWarning.Warning_Days_Before_Due__c</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>var_MaxWarningDays</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_MaxWarning</targetReference>
            </connector>
            <label>New Max Found</label>
        </rules>
    </decisions>

    <!-- Match inner config loop's review type to the current process (M4 fix) -->
    <decisions>
        <name>Decision_ConfigMatchesReviewType</name>
        <label>Config Review Type Matches Process?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No match — continue inner loop</defaultConnectorLabel>
        <rules>
            <name>Config_Matches</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_FindConfigForProcess.Review_Type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>Loop_Processes.nepa_review_type__c</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_SpecificWarningDays</targetReference>
            </connector>
            <label>Config Matches</label>
        </rules>
    </decisions>

    <!-- Classify each process as Overdue, In Warning Window, or neither.
         Uses formula_SpecificWarningCutoff (TODAY + per-review-type warning days) for the window check. -->
    <decisions>
        <name>Decision_EvaluateSLAState</name>
        <label>Overdue or In Warning Window?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Neither — skip</defaultConnectorLabel>
        <rules>
            <name>Is_Overdue</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Loop_Processes.nepa_sla_due_date__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>formula_Today</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Processes.nepa_sla_overdue__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Build_OverdueUpdate</targetReference>
            </connector>
            <label>Overdue (not yet flagged)</label>
        </rules>
        <rules>
            <name>In_Warning_Window</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <!-- Uses per-review-type cutoff instead of hardcoded 30 days (M4 fix) -->
                <leftValueReference>Loop_Processes.nepa_sla_due_date__c</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>formula_SpecificWarningCutoff</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Loop_Processes.nepa_sla_warning_sent__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Build_WarningUpdate</targetReference>
            </connector>
            <label>In Warning Window (warning not yet sent)</label>
        </rules>
    </decisions>

    <!-- After main loop: check if any FeedItems were collected before bulk create (M5 fix) -->
    <decisions>
        <name>Decision_HasFeedItems</name>
        <label>Any Chatter Notifications to Post?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No Feed Items — proceed to record updates</defaultConnectorLabel>
        <defaultConnector>
            <targetReference>Decision_HasWarningUpdates</targetReference>
        </defaultConnector>
        <rules>
            <name>Has_Feed_Items</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>col_FeedItemsToCreate</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Post_Chatter_Bulk</targetReference>
            </connector>
            <label>Has Feed Items</label>
        </rules>
    </decisions>

    <decisions>
        <name>Decision_HasWarningUpdates</name>
        <label>Any Warning Updates to Write?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No Warning Updates</defaultConnectorLabel>
        <defaultConnector>
            <targetReference>Decision_HasOverdueUpdates</targetReference>
        </defaultConnector>
        <rules>
            <name>Has_Warning_Updates</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>col_WarningUpdates</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Bulk_UpdateWarning</targetReference>
            </connector>
            <label>Has Warning Updates</label>
        </rules>
    </decisions>

    <decisions>
        <name>Decision_HasOverdueUpdates</name>
        <label>Any Overdue Updates to Write?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No Overdue Updates — done</defaultConnectorLabel>
        <rules>
            <name>Has_Overdue_Updates</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>col_OverdueUpdates</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Bulk_UpdateOverdue</targetReference>
            </connector>
            <label>Has Overdue Updates</label>
        </rules>
    </decisions>

    <!-- ============================================================
         FORMULAS
    ============================================================ -->

    <formulas>
        <name>formula_ErrorContext</name>
        <dataType>String</dataType>
        <expression>"Step:" &amp; {!var_CurrentStep}</expression>
    </formulas>

    <formulas>
        <name>formula_Today</name>
        <dataType>Date</dataType>
        <expression>TODAY()</expression>
    </formulas>

    <!-- Query bound: TODAY + max warning days across all review types.
         var_MaxWarningDays is computed by Loop_ComputeMaxWarning before Get_ActiveProcesses runs.
         Replaces hardcoded TODAY() + 30 (M4 fix). -->
    <formulas>
        <name>formula_WarningCutoff</name>
        <dataType>Date</dataType>
        <expression>TODAY() + {!var_MaxWarningDays}</expression>
    </formulas>

    <!-- Per-process warning cutoff: TODAY + warning days specific to this process's review type.
         var_SpecificWarningDays is resolved by Loop_FindConfigForProcess each outer loop iteration.
         Falls back to var_MaxWarningDays when no matching config is found (M4 fix). -->
    <formulas>
        <name>formula_SpecificWarningCutoff</name>
        <dataType>Date</dataType>
        <expression>TODAY() + {!var_SpecificWarningDays}</expression>
    </formulas>

    <!-- ============================================================
         LOOPS
    ============================================================ -->

    <!-- Pre-loop to compute var_MaxWarningDays from CMT before querying processes (M4 fix).
         O(n) over CMT configs — typically 3–5 records, governor-exempt. -->
    <loops>
        <name>Loop_ComputeMaxWarning</name>
        <label>Compute Max Warning Days from SLA Configs</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>col_SLAConfigs</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Decision_IsNewMax</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Get_ActiveProcesses</targetReference>
        </noMoreValuesConnector>
    </loops>

    <!-- Main loop: one record per iteration. No DML inside. (M5 fix) -->
    <loops>
        <name>Loop_Processes</name>
        <label>Loop Through Active Processes</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>col_ActiveProcesses</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <!-- Reset specific warning days, then find review-type-specific value (M4 fix) -->
        <nextValueConnector>
            <targetReference>Init_SpecificWarningDays</targetReference>
        </nextValueConnector>
        <!-- Bulk create FeedItems after all iterations complete (M5 fix) -->
        <noMoreValuesConnector>
            <targetReference>Decision_HasFeedItems</targetReference>
        </noMoreValuesConnector>
    </loops>

    <!-- Inner loop: iterate col_SLAConfigs to find var_SpecificWarningDays for this process (M4 fix).
         Pure iteration — no SOQL, no DML. O(n*m) where n = active processes, m = SLA configs (~5).
         Acceptable at NEPA caseload scale. -->
    <loops>
        <name>Loop_FindConfigForProcess</name>
        <label>Find Warning Days for This Review Type</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>col_SLAConfigs</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Decision_ConfigMatchesReviewType</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Decision_EvaluateSLAState</targetReference>
        </noMoreValuesConnector>
    </loops>

    <!-- ============================================================
         STEP 1: Load all active SLA configs (CMT — governor-exempt)
    ============================================================ -->
    <recordLookups>
        <name>Get_SLAConfigs</name>
        <label>Get All Active SLA Configs</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Decision_ConfigsLoaded</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Active__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>NEPA_SLA_Config__mdt</object>
        <outputReference>col_SLAConfigs</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Review_Type__c</queriedFields>
        <queriedFields>Warning_Days_Before_Due__c</queriedFields>
    </recordLookups>

    <!-- ============================================================
         STEP 2 (after max-warning compute): Query active processes.
         Bounded by formula_WarningCutoff (dynamic max warning days).
    ============================================================ -->
    <recordLookups>
        <name>Get_ActiveProcesses</name>
        <label>Get Active Processes Approaching or Past SLA Due Date</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Decision_ProcessesFound</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Handle_QueryError</targetReference>
        </faultConnector>
        <filterLogic>1 AND 2 AND 3 AND (4 OR 5)</filterLogic>
        <filters>
            <field>nepa_sla_due_date__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <filters>
            <field>nepa_process_status__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>completed</stringValue>
            </value>
        </filters>
        <filters>
            <field>nepa_process_status__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>cancelled</stringValue>
            </value>
        </filters>
        <filters>
            <field>nepa_sla_due_date__c</field>
            <operator>LessThanOrEqualTo</operator>
            <value>
                <elementReference>formula_WarningCutoff</elementReference>
            </value>
        </filters>
        <filters>
            <field>nepa_sla_overdue__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>IndividualApplication</object>
        <outputReference>col_ActiveProcesses</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Name</queriedFields>
        <queriedFields>OwnerId</queriedFields>
        <queriedFields>nepa_review_type__c</queriedFields>
        <queriedFields>nepa_sla_due_date__c</queriedFields>
        <queriedFields>nepa_sla_warning_sent__c</queriedFields>
        <queriedFields>nepa_sla_overdue__c</queriedFields>
    </recordLookups>

    <!-- ============================================================
         POST-LOOP: Bulk create all collected FeedItems in one DML call (M5 fix).
         Eliminates the original DML-in-loop anti-pattern.
    ============================================================ -->
    <recordCreates>
        <name>Post_Chatter_Bulk</name>
        <label>Post All Chatter Notifications (Bulk)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Handle_UpdateError</targetReference>
        </faultConnector>
        <inputReference>col_FeedItemsToCreate</inputReference>
        <connector>
            <targetReference>Decision_HasWarningUpdates</targetReference>
        </connector>
    </recordCreates>

    <!-- ============================================================
         POST-LOOP: Bulk update record flags
    ============================================================ -->
    <recordUpdates>
        <name>Bulk_UpdateWarning</name>
        <label>Bulk Set nepa_sla_warning_sent__c = true</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Handle_UpdateError</targetReference>
        </faultConnector>
        <inputReference>col_WarningUpdates</inputReference>
        <connector>
            <targetReference>Decision_HasOverdueUpdates</targetReference>
        </connector>
    </recordUpdates>

    <recordUpdates>
        <name>Bulk_UpdateOverdue</name>
        <label>Bulk Set nepa_sla_overdue__c = true</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <faultConnector>
            <targetReference>Handle_UpdateError</targetReference>
        </faultConnector>
        <inputReference>col_OverdueUpdates</inputReference>
    </recordUpdates>

    <!-- code-analyzer-suppress flow:MissingFaultHandler - terminal error handler; fault-handling Call_ErrorLogger would be circular -->
    <subflows>
        <name>Call_ErrorLogger</name>
        <label>Log Flow Error</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <flowName>NEPA_Error_Logger</flowName>
        <inputAssignments>
            <name>inp_FlowName</name>
