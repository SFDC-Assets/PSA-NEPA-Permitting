<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <description>Before-save flow on ContentVersion Create and Update. Stamps nepa_fra_page_limit__c with the FRA statutory page limit for the document type (EA = 75, Draft EIS = 150, Final EIS = 300, per 42 U.S.C. 4336a). Also propagates nepa_is_appendix__c = true when nepa_section_type__c is blank and the document type is an appendix type. Does not write nepa_fra_overlimit__c — that is a formula field. Runs on create and on update when nepa_document_type__c changes.</description>
    <label>NEPA FRA Page Limit Setter</label>
    <processType>AutoLaunchedFlow</processType>
    <status>Active</status>

    <!-- ── Decision: document type changed or new record ────────────────── -->

    <decisions>
        <name>Decision_SetPageLimit</name>
        <label>Set FRA Page Limit for Document Type</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>No FRA limit — clear field</defaultConnectorLabel>
        <defaultConnector>
            <targetReference>Assign_ClearPageLimit</targetReference>
        </defaultConnector>
        <rules>
            <name>Is_EA</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.nepa_document_type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue><stringValue>EA</stringValue></rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_EA_Limit</targetReference>
            </connector>
            <label>EA</label>
        </rules>
        <rules>
            <name>Is_Draft_EIS</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.nepa_document_type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue><stringValue>Draft EIS</stringValue></rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_DraftEIS_Limit</targetReference>
            </connector>
            <label>Draft EIS</label>
        </rules>
        <rules>
            <name>Is_Final_EIS</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.nepa_document_type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue><stringValue>Final EIS</stringValue></rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_FinalEIS_Limit</targetReference>
            </connector>
            <label>Final EIS</label>
        </rules>
        <rules>
            <name>Is_Appendix_Type</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.nepa_document_type__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue><stringValue>Appendix</stringValue></rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Appendix_Flag</targetReference>
            </connector>
            <label>Appendix Document Type</label>
        </rules>
    </decisions>

    <!-- ── Assignments ───────────────────────────────────────────────────── -->

    <assignments>
        <name>Assign_EA_Limit</name>
        <label>Set EA Page Limit (75)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.nepa_fra_page_limit__c</assignToReference>
            <operator>Assign</operator>
            <value><numberValue>75</numberValue></value>
        </assignmentItems>
    </assignments>

    <assignments>
        <name>Assign_DraftEIS_Limit</name>
        <label>Set Draft EIS Page Limit (150)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.nepa_fra_page_limit__c</assignToReference>
            <operator>Assign</operator>
            <value><numberValue>150</numberValue></value>
        </assignmentItems>
    </assignments>

    <assignments>
        <name>Assign_FinalEIS_Limit</name>
        <label>Set Final EIS Page Limit (300)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.nepa_fra_page_limit__c</assignToReference>
            <operator>Assign</operator>
            <value><numberValue>300</numberValue></value>
        </assignmentItems>
    </assignments>

    <assignments>
        <name>Assign_Appendix_Flag</name>
        <label>Set Appendix Flag and Clear Page Limit</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.nepa_is_appendix__c</assignToReference>
            <operator>Assign</operator>
            <value><booleanValue>true</booleanValue></value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.nepa_fra_page_limit__c</assignToReference>
            <operator>Assign</operator>
            <value><numberValue>0</numberValue></value>
        </assignmentItems>
    </assignments>

    <assignments>
        <name>Assign_ClearPageLimit</name>
        <label>Clear FRA Page Limit (not applicable)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <!-- Null assignment: set page limit to 0 for non-applicable document types.
                 nepa_fra_overlimit__c formula requires non-blank value to evaluate,
                 so 0 is safer than null here for CE, NOI, ROD, and other exempt types. -->
            <assignToReference>$Record.nepa_fra_page_limit__c</assignToReference>
            <operator>Assign</operator>
            <value><numberValue>0</numberValue></value>
        </assignmentItems>
    </assignments>

    <!-- ── Trigger ────────────────────────────────────────────────────────── -->

    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Decision_SetPageLimit</targetReference>
        </connector>
        <object>ContentVersion</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
        <filterLogic>or</filterLogic>
        <filters>
            <field>nepa_document_type__c</field>
            <operator>IsChanged</operator>
            <value><booleanValue>true</booleanValue></value>
        </filters>
        <filters>
            <field>nepa_document_type__c</field>
            <operator>IsNull</operator>
            <value><booleanValue>false</booleanValue></value>
        </filters>
    </start>

</Flow>
