<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <description>Subflow called by all NEPA record-triggered flows on fault. Creates a NEPA_Flow_Error__c record capturing the flow name, fault message, and triggering record Id. Migration path: when Nebula Logger is installed, replace the recordCreates element here with a Nebula Logger Apex action call — no caller changes required.</description>
    <label>NEPA Error Logger</label>
    <processType>AutoLaunchedFlow</processType>
    <status>Active</status>

    <!-- ============================================================
         INPUT VARIABLES
         All callers pass: inp_FlowName, inp_ErrorMessage, inp_RecordId
    ============================================================ -->

    <variables>
        <name>inp_FlowName</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>inp_ErrorMessage</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
    <variables>
        <name>inp_RecordId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>

    <!-- ============================================================
         START
    ============================================================ -->

    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Create_FlowErrorRecord</targetReference>
        </connector>
    </start>

    <!-- ============================================================
         CREATE LOG RECORD
         Nebula Logger migration: replace this recordCreates with an
         Apex action targeting Logger.error() — inputs map directly.
    ============================================================ -->

    <!-- code-analyzer-suppress flow:MissingFaultHandler - terminal error handler; adding a fault path here would require a second logger creating an infinite loop -->
    <recordCreates>
        <name>Create_FlowErrorRecord</name>
        <label>Create Flow Error Record</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <inputAssignments>
            <field>nepa_flow_api_name__c</field>
            <value>
                <elementReference>inp_FlowName</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>nepa_error_message__c</field>
            <value>
                <elementReference>inp_ErrorMessage</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>nepa_record_id__c</field>
            <value>
                <elementReference>inp_RecordId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>nepa_occurred_at__c</field>
            <value>
                <elementReference>$Flow.CurrentDateTime</elementReference>
            </value>
        </inputAssignments>
        <object>NEPA_Flow_Error__c</object>
    </recordCreates>

</Flow>
