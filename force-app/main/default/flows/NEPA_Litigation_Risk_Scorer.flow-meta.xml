        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Not Found - use default</defaultConnectorLabel>
        <defaultConnector>
            <targetReference>Get_StatuteWeights</targetReference>
        </defaultConnector>
        <rules>
            <name>Circuit_Found</name>
