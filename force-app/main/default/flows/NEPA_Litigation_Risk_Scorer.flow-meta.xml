    <decisions>
        <name>Decision_CapScore</name>
        <label>Cap Score at 100</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Score &lt;= 100</defaultConnectorLabel>
        <defaultConnector>
            <targetReference>Decision_AssignTier</targetReference>
        </defaultConnector>
        <rules>
            <name>Score_Over_100</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_RiskScore</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <numberValue>100.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Score_Cap</targetReference>
            </connector>
            <label>Score &gt; 100</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decision_AssignTier</name>
        <label>Assign Risk Tier</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Low (0-24)</defaultConnectorLabel>
        <defaultConnector>
            <targetReference>Assign_Tier_Low</targetReference>
        </defaultConnector>
        <rules>
            <name>Tier_VeryHigh</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_RiskScore</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>75.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Tier_VeryHigh</targetReference>
            </connector>
            <label>Very High (75-100)</label>
        </rules>
        <rules>
            <name>Tier_High</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_RiskScore</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>50.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Tier_High</targetReference>
            </connector>
            <label>High (50-74)</label>
        </rules>
        <rules>
            <name>Tier_Moderate</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_RiskScore</leftValueReference>
                <operator>GreaterThanOrEqualTo</operator>
                <rightValue>
                    <numberValue>25.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Tier_Moderate</targetReference>
            </connector>
            <label>Moderate (25-49)</label>
        </rules>
    </decisions>
    <!-- Confidence: 50 base (review type + statute always scored) + 25 per CMT hit (agency, circuit) -->
    <formulas>
        <name>formula_AIConfidence</name>
        <dataType>Number</dataType>
        <expression>50 + IF(NOT(ISBLANK({!rec_AgencyRiskRate.Id})), 25, 0) + IF(NOT(ISBLANK({!rec_CircuitRiskWeight.Id})), 25, 0)</expression>
        <scale>1</scale>
    </formulas>

    <formulas>
        <name>formula_ErrorContext</name>
        <dataType>String</dataType>
        <expression>"Agency:" &amp; {!var_AgencyName} &amp; "|Circuit:" &amp; {!var_CircuitKey} &amp; "|RiskScore:" &amp; TEXT({!var_RiskScore}) &amp; "|RiskTier:" &amp; {!var_RiskTier} &amp; "|Step:" &amp; {!var_CurrentStep}</expression>
    </formulas>
    <formulas>
        <name>formula_ScoreFactorsWithPenalty</name>
        <dataType>String</dataType>
        <expression>{!var_ScoreFactors} &amp; "; APA PENALTY: 1.5x multiplier applied — Expedited/Emergency procedure. Immediate record gap remediation required."</expression>
    </formulas>
    <formulas>
        <name>formula_ScoreFactorsSummary</name>
        <dataType>String</dataType>
        <expression>"[AI-GENERATED — PermitTEC v0.1, PNNL 2025, 761 cases; circuit weights based on small sample, treat as directional] " &amp; "ReviewType:" &amp; TEXT({!var_ReviewTypePoints}) &amp; "pts; Agency:" &amp; TEXT({!var_AgencyPoints}) &amp; "pts; Circuit:" &amp; TEXT({!var_CircuitPoints}) &amp; "pts; Statutes:" &amp; TEXT({!var_AdjacentStatutePoints}) &amp; "pts; Total:" &amp; TEXT({!var_RiskScore})</expression>
    </formulas>
    <formulas>
        <name>formula_RiskScoreMultiplied</name>
        <dataType>Number</dataType>
        <expression>{!var_RiskScore} * 1.5</expression>
        <scale>2</scale>
    </formulas>
    <loops>
        <name>Loop_StatuteWeights</name>
        <label>Loop: Statute Risk Weights</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <collectionReference>col_StatuteWeights</collectionReference>
        <iterationOrder>Asc</iterationOrder>
        <nextValueConnector>
            <targetReference>Assign_CurrentStatute</targetReference>
        </nextValueConnector>
        <noMoreValuesConnector>
            <targetReference>Calculate_Total_Score</targetReference>
        </noMoreValuesConnector>
    </loops>
