    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <recordLookups>
        <name>GetRelatedProcess</name>
        <label>Get Related NEPA Process</label>
        <locationX>176</locationX>
        <locationY>168</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Decision_ProcessFound</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Handle_Error</targetReference>
        </faultConnector>
        <filterLogic>1 AND 2</filterLogic>
        <filters>
            <field>nepa_related_project__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>nepa_process_status__c</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Completed</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>IndividualApplication</object>
        <outputReference>var_RelatedProcess</outputReference>
        <queriedFields>Id</queriedFields>
        <queriedFields>Name</queriedFields>
        <queriedFields>OwnerId</queriedFields>
        <queriedFields>AccountId</queriedFields>
        <sortField>CreatedDate</sortField>
        <sortOrder>Desc</sortOrder>
    </recordLookups>
    <recordLookups>
        <name>CheckExistingAutoTeam</name>
        <label>Check Existing Auto Team Members</label>
        <locationX>176</locationX>
        <locationY>408</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Decision_ReRunOrFirstTime</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Handle_Error</targetReference>
        </faultConnector>
        <filterLogic>1 AND 2</filterLogic>
        <filters>
            <field>nepa_process__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>var_RelatedProcess.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>nepa_assembly_source__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>GIS_Auto_Assembly</stringValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>nepa_process_team_member__c</object>
        <outputReference>var_ExistingAutoTeam</outputReference>
        <queriedFields>Id</queriedFields>
    </recordLookups>
    <recordLookups>
        <name>GetExistingAutoVisits</name>
        <label>Get Existing Auto-Generated Visits</label>
        <locationX>176</locationX>
        <locationY>768</locationY>
        <assignNullValuesIfNoRecordsFound>true</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Decision_AutoVisitsExist</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Handle_Error</targetReference>
        </faultConnector>
        <filterLogic>1 AND 2</filterLogic>
        <filters>
            <field>nepa_process__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>var_RelatedProcess.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>nepa_auto_generated__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <getFirstRecordOnly>false</getFirstRecordOnly>
        <object>Visit</object>
        <outputReference>var_ExistingAutoVisits</outputReference>
        <queriedFields>Id</queriedFields>
    </recordLookups>
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <recordUpdates>
        <name>Update_DeactivatedMembers</name>
        <label>Bulk Deactivate Team Members</label>
        <locationX>176</locationX>
        <locationY>648</locationY>
        <connector>
            <targetReference>GetExistingAutoVisits</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Handle_Error</targetReference>
        </faultConnector>
        <filterLogic>1 AND 2 AND 3</filterLogic>
        <filters>
            <field>nepa_process__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>var_RelatedProcess.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>nepa_assembly_source__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>GIS_Auto_Assembly</stringValue>
            </value>
        </filters>
        <filters>
            <field>nepa_active__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <inputAssignments>
            <field>nepa_active__c</field>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </inputAssignments>
        <object>nepa_process_team_member__c</object>
    </recordUpdates>
    <recordUpdates>
        <name>Update_CancelledVisits</name>
        <label>Bulk Cancel Auto Visits</label>
        <locationX>176</locationX>
        <locationY>1008</locationY>
        <connector>
            <targetReference>Assemble_TeamAndVisits</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Handle_Error</targetReference>
        </faultConnector>
        <filterLogic>1 AND 2 AND 3</filterLogic>
        <filters>
            <field>nepa_process__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>var_RelatedProcess.Id</elementReference>
            </value>
        </filters>
        <filters>
            <field>nepa_auto_generated__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <filters>
            <field>Status</field>
            <operator>NotEqualTo</operator>
            <value>
                <stringValue>Canceled</stringValue>
            </value>
        </filters>
        <inputAssignments>
            <field>Status</field>
            <value>
                <stringValue>Canceled</stringValue>
            </value>
        </inputAssignments>
        <object>Visit</object>
    </recordUpdates>
    <!-- code-analyzer-suppress flow:MissingFaultHandler - terminal error handler; fault on error logger would be circular -->
