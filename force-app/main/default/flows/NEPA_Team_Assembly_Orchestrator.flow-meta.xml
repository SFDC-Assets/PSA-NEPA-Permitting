<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <description>After-save async flow on Program. Fires when nepa_gis_proximity_complete__c changes to true. Delegates CMT-to-hit-layer matching, ServiceResource lookup, team member creation, and Visit creation to NepaLayerDisciplineResolver (Apex invocable). On re-run, deactivates existing auto-assembled team members and cancels auto-generated Visits before re-assembling via filter-based recordUpdates.</description>
    <environments>Default</environments>
    <interviewLabel>NEPA Team Assembly Orchestrator {!$Flow.CurrentDateTime}</interviewLabel>
    <label>NEPA Team Assembly Orchestrator</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <status>Active</status>
    <start>
        <locationX>176</locationX>
        <locationY>48</locationY>
        <filters>
            <field>nepa_gis_proximity_complete__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>Program</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <scheduledPaths>
            <connector>
                <targetReference>GetRelatedProcess</targetReference>
            </connector>
            <pathType>AsyncAfterCommit</pathType>
        </scheduledPaths>
        <triggerType>RecordAfterSave</triggerType>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
    </start>
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <assignments>
        <name>Handle_Error</name>
        <label>Capture Fault Message</label>
        <locationX>640</locationX>
        <locationY>288</locationY>
        <assignmentItems>
            <assignToReference>var_ErrorMessage</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Flow.FaultMessage</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Create_ErrorTask</targetReference>
        </connector>
    </assignments>
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <decisions>
        <name>Decision_ProcessFound</name>
        <label>Active NEPA Process Found?</label>
        <locationX>176</locationX>
        <locationY>288</locationY>
        <defaultConnectorLabel>No Process — Create Alert Task</defaultConnectorLabel>
        <defaultConnector>
            <targetReference>Create_NoProcessTask</targetReference>
        </defaultConnector>
        <rules>
            <name>ProcessFound</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_RelatedProcess</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>CheckExistingAutoTeam</targetReference>
            </connector>
            <label>Process Found</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decision_ReRunOrFirstTime</name>
        <label>Re-Run or First Time?</label>
        <locationX>176</locationX>
        <locationY>528</locationY>
        <defaultConnectorLabel>First Time — Assemble Team</defaultConnectorLabel>
        <defaultConnector>
            <targetReference>Assemble_TeamAndVisits</targetReference>
        </defaultConnector>
        <rules>
            <name>IsReRun</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_ExistingAutoTeam</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_DeactivatedMembers</targetReference>
            </connector>
            <label>Re-Run — Deactivate Previous Team</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decision_AutoVisitsExist</name>
        <label>Auto Visits to Cancel?</label>
        <locationX>176</locationX>
        <locationY>888</locationY>
        <defaultConnectorLabel>No Auto Visits — Assemble Team</defaultConnectorLabel>
        <defaultConnector>
            <targetReference>Assemble_TeamAndVisits</targetReference>
        </defaultConnector>
        <rules>
            <name>AutoVisitsExist</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_ExistingAutoVisits</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_CancelledVisits</targetReference>
            </connector>
            <label>Auto Visits Exist</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decision_AssemblyResult</name>
        <label>Assembly Result</label>
        <locationX>176</locationX>
        <locationY>1248</locationY>
        <defaultConnectorLabel>Success — End</defaultConnectorLabel>
        <rules>
            <name>AssemblyError</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_ApexErrorMessage</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_ApexErrorTask</targetReference>
            </connector>
            <label>Assembly Error</label>
        </rules>
        <rules>
            <name>NoHitsFound</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_ApexAnyHitsFound</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_NoHitsTask</targetReference>
            </connector>
            <label>No Hits Found</label>
        </rules>
        <rules>
            <name>UnmatchedDisciplines</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>var_ApexUnmatchedDisciplines</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Create_UnmatchedTask</targetReference>
            </connector>
            <label>Unmatched Disciplines</label>
        </rules>
    </decisions>
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <actionCalls>
        <name>Assemble_TeamAndVisits</name>
        <label>Assemble Team and Create Visits</label>
        <locationX>176</locationX>
        <locationY>1128</locationY>
        <actionName>NepaLayerDisciplineResolver</actionName>
        <actionType>apex</actionType>
        <connector>
            <targetReference>Decision_AssemblyResult</targetReference>
        </connector>
        <faultConnector>
            <targetReference>Handle_Error</targetReference>
        </faultConnector>
        <inputParameters>
            <name>programId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>relatedAppId</name>
            <value>
                <elementReference>var_RelatedProcess.Id</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>accountId</name>
            <value>
                <elementReference>var_RelatedProcess.AccountId</elementReference>
            </value>
        </inputParameters>
        <outputParameters>
            <assignToReference>var_ApexErrorMessage</assignToReference>
            <name>errorMessage</name>
        </outputParameters>
        <outputParameters>
            <assignToReference>var_ApexAnyHitsFound</assignToReference>
            <name>anyHitsFound</name>
        </outputParameters>
        <outputParameters>
            <assignToReference>var_ApexUnmatchedDisciplines</assignToReference>
            <name>unmatchedDisciplines</name>
        </outputParameters>
        <outputParameters>
            <assignToReference>var_ApexTeamMembersCreated</assignToReference>
            <name>teamMembersCreated</name>
        </outputParameters>
        <outputParameters>
            <assignToReference>var_ApexVisitsCreated</assignToReference>
            <name>visitsCreated</name>
        </outputParameters>
        <storeOutputAutomatically>false</storeOutputAutomatically>
    </actionCalls>
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <recordCreates>
