{
  "Name": "DR_Extract_CE_LibraryByAgency",
  "Type": "Extract",
  "IsActive__c": false,
  "Description": "Returns up to 5 active CE Library entries for a given agency abbreviation. Used by NEPA_CEScreeningIP to surface matching categorical exclusions during applicant intake in the CE Intake OmniScript.",
  "SObjectType": "nepa_ce_library__c",
  "WhereClause": "nepa_agency_abbr__c = :AgencyAbbr AND nepa_active__c = true",
  "OrderBy": "nepa_context__c ASC",
  "Limit": 5,
  "OutputPath": "LibraryEntries",
  "Mappings": [
    {"SObjectField": "Id",                              "OutputKey": "id",              "DataType": "STRING"},
    {"SObjectField": "nepa_ce_explorer_id__c",          "OutputKey": "ce_explorer_id",  "DataType": "STRING"},
    {"SObjectField": "nepa_agency_abbr__c",             "OutputKey": "agency_abbr",     "DataType": "STRING"},
    {"SObjectField": "nepa_context__c",                 "OutputKey": "context",         "DataType": "STRING"},
    {"SObjectField": "nepa_origin__c",                  "OutputKey": "origin",          "DataType": "STRING"},
    {"SObjectField": "nepa_exclusion_text__c",          "OutputKey": "exclusion_text",  "DataType": "STRING"},
    {"SObjectField": "nepa_source_url__c",              "OutputKey": "source_url",      "DataType": "STRING"}
  ]
}
