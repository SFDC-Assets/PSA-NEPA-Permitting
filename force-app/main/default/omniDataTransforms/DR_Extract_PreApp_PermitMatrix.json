{
  "Name": "DR_Extract_PreApp_PermitMatrix",
  "Type": "Extract",
  "IsActive__c": true,
  "Description": "Extracts the best-matching NEPA_Permit_Matrix__mdt row for a given SectorKey (contains match) and optional LeadAgencyKey. Used by NEPA_PreApp_Screening_IP to return required permits, adjacent reviews, typical timeline, and EIS likelihood percentage to the pre-application screener. Guest-safe: CMT records are always readable regardless of profile.",
  "SObjectType": "NEPA_Permit_Matrix__mdt",
  "WhereClause": "Active__c = true AND Sector__c LIKE :SectorKeyPattern",
  "OrderBy": "Lead_Agency_Key__c ASC",
  "Limit": 1,
  "OutputPath": "MatrixData",
  "Mappings": [
    {"SObjectField": "DeveloperName",            "OutputKey": "DeveloperName",           "DataType": "STRING"},
    {"SObjectField": "Sector__c",                "OutputKey": "Sector__c",              "DataType": "STRING"},
    {"SObjectField": "Lead_Agency_Key__c",       "OutputKey": "Lead_Agency_Key__c",     "DataType": "STRING"},
    {"SObjectField": "Cooperating_Agencies__c",  "OutputKey": "Cooperating_Agencies__c","DataType": "STRING"},
    {"SObjectField": "Required_Permits__c",      "OutputKey": "Required_Permits__c",    "DataType": "STRING"},
    {"SObjectField": "Adjacent_Reviews__c",      "OutputKey": "Adjacent_Reviews__c",    "DataType": "STRING"},
    {"SObjectField": "Typical_Timeline_Months__c","OutputKey": "Typical_Timeline_Months__c","DataType": "DECIMAL"},
    {"SObjectField": "EIS_Likelihood_Pct__c",    "OutputKey": "EIS_Likelihood_Pct__c",  "DataType": "DECIMAL"},
    {"SObjectField": "GIS_Trigger_Layers__c",    "OutputKey": "GIS_Trigger_Layers__c",  "DataType": "STRING"},
    {"SObjectField": "Initiation_Gate__c",       "OutputKey": "Initiation_Gate__c",     "DataType": "STRING"}
  ]
}
