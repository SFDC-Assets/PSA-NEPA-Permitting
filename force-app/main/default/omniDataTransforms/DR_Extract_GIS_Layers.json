{
  "Name": "DR_Extract_GIS_Layers",
  "Type": "Extract",
  "IsActive__c": true,
  "Description": "Extracts all active NEPA_GIS_Layer__mdt records ordered by Priority__c ascending. Output path: GISLayers (list). Called by NEPA_GIS_Proximity_IP to dynamically load the registered layer registry — adding a new layer requires only a new CMT record.",
  "SObjectType": "NEPA_GIS_Layer__mdt",
  "WhereClause": "Active__c = true ORDER BY Priority__c ASC",
  "OutputPath": "GISLayers",
  "Mappings": [
    {"SObjectField": "DeveloperName", "OutputKey": "DeveloperName", "DataType": "STRING"},
    {"SObjectField": "Label", "OutputKey": "Layer_Label__c", "DataType": "STRING"},
    {"SObjectField": "Service_URL__c", "OutputKey": "Service_URL__c", "DataType": "STRING"},
    {"SObjectField": "Layer_Number__c", "OutputKey": "Layer_Number__c", "DataType": "DECIMAL"},
    {"SObjectField": "Buffer_Miles__c", "OutputKey": "Buffer_Miles__c", "DataType": "DECIMAL"},
    {"SObjectField": "Result_Key_Field__c", "OutputKey": "Result_Key_Field__c", "DataType": "STRING"},
    {"SObjectField": "Query_Template__c", "OutputKey": "Query_Template__c", "DataType": "STRING"},
    {"SObjectField": "Named_Credential__c", "OutputKey": "Named_Credential__c", "DataType": "STRING"},
    {"SObjectField": "Extraordinary_Circumstances_Keyword__c", "OutputKey": "Extraordinary_Circumstances_Keyword__c", "DataType": "STRING"},
    {"SObjectField": "Priority__c", "OutputKey": "Priority__c", "DataType": "DECIMAL"}
  ]
}
