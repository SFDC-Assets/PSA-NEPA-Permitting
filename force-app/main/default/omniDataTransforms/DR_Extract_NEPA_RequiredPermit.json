    {"SObjectField": "Name", "OutputKey": "name", "DataType": "STRING"},
    {"SObjectField": "nepa_permit_type__c", "OutputKey": "permit_type", "DataType": "STRING"},
    {"SObjectField": "nepa_lead_agency__c", "OutputKey": "lead_agency", "DataType": "STRING"},
    {"SObjectField": "nepa_regulatory_citation__c", "OutputKey": "regulatory_citation", "DataType": "STRING"},
    {"SObjectField": "nepa_is_critical_path__c", "OutputKey": "is_critical_path", "DataType": "BOOLEAN"},
    {"SObjectField": "nepa_permit_status__c", "OutputKey": "permit_status", "DataType": "STRING"},
    {"SObjectField": "nepa_nepa_stage_gate__c", "OutputKey": "nepa_stage_gate", "DataType": "STRING"},
    {"SObjectField": "nepa_expected_completion__c", "OutputKey": "expected_completion", "DataType": "DATE"},
    {"SObjectField": "nepa_actual_completion__c", "OutputKey": "actual_completion", "DataType": "DATE"},
