{
  "Name": "DR_Upsert_Detected_Layer",
  "Type": "Load",
  "IsActive__c": true,
  "Description": "Bulk-upserts nepa_detected_protection_layer__c records from a collection built during the NEPA_GIS_Proximity_IP loop. Upsert key: nepa_upsert_key__c ({programId}_{layerDeveloperName}). Re-running the GIS proximity check for the same project updates existing detection records rather than creating duplicates. Called by Step 14 (SaveDetectedLayers) of NEPA_GIS_Proximity_IP after the layer loop completes.",
  "SObjectType": "nepa_detected_protection_layer__c",
  "OperationType": "Upsert",
  "UpsertKey": "nepa_upsert_key__c",
  "Mappings": [
