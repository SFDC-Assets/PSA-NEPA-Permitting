    {"InputKey": "nepa_program__c",                                 "SObjectField": "nepa_program__c",                                 "DataType": "STRING"},
    {"InputKey": "nepa_layer_developer_name__c",                    "SObjectField": "nepa_layer_developer_name__c",                    "DataType": "STRING"},
    {"InputKey": "nepa_layer_label__c",                             "SObjectField": "nepa_layer_label__c",                             "DataType": "STRING"},
