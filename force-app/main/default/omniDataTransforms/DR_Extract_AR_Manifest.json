{
  "Name": "DR_Extract_AR_Manifest",
  "Type": "Extract",
  "IsActive__c": true,
  "Description": "MFR 9 — Administrative Record Manifest. Extracts a complete administrative record package for a closed NEPA process: application summary, indexed documents, milestones, consultations, public comments, and litigation risk snapshot. Input: processId. Output path: administrativeRecord. Called by NEPA_Close_Administrative_Record flow on ROD/FONSI issuance and wired into NEPA/CEQExport Integration Procedure.",
  "SObjectType": "IndividualApplication",
  "WhereClause": "Id = :processId",
  "OutputPath": "administrativeRecord",
  "Mappings": [
    {"SObjectField": "Id", "OutputKey": "process_id", "DataType": "STRING"},
    {"SObjectField": "Name", "OutputKey": "process_name", "DataType": "STRING"},
    {"SObjectField": "nepa_federal_unique_id__c", "OutputKey": "federal_unique_id", "DataType": "STRING"},
    {"SObjectField": "nepa_agency_id__c", "OutputKey": "agency_process_id", "DataType": "STRING"},
    {"SObjectField": "nepa_review_type__c", "OutputKey": "nepa_review_type", "DataType": "STRING"},
    {"SObjectField": "nepa_process_status__c", "OutputKey": "status", "DataType": "STRING"},
    {"SObjectField": "nepa_process_stage__c", "OutputKey": "stage", "DataType": "STRING"},
    {"SObjectField": "nepa_process_outcome__c", "OutputKey": "outcome", "DataType": "STRING"},
    {"SObjectField": "nepa_ce_pathway_recommendation__c", "OutputKey": "ce_recommendation", "DataType": "STRING"},
    {"SObjectField": "nepa_process_code__c", "OutputKey": "ce_code", "DataType": "STRING"},
    {"SObjectField": "nepa_classification_basis__c", "OutputKey": "classification_basis", "DataType": "STRING"},
    {"SObjectField": "nepa_purpose_need__c", "OutputKey": "purpose_and_need", "DataType": "STRING"},
    {"SObjectField": "nepa_action_type__c", "OutputKey": "action_type", "DataType": "STRING"},
    {"SObjectField": "nepa_disturbance_acres__c", "OutputKey": "disturbance_acres", "DataType": "DECIMAL"},
    {"SObjectField": "nepa_extraordinary_circumstances__c", "OutputKey": "extraordinary_circumstances", "DataType": "STRING"},
    {"SObjectField": "nepa_nhd_proximity_flag__c", "OutputKey": "nhd_proximity_flag", "DataType": "BOOLEAN"},
    {"SObjectField": "nepa_tribal_lands_flag__c", "OutputKey": "tribal_lands_flag", "DataType": "BOOLEAN"},
    {"SObjectField": "nepa_plss_flag__c", "OutputKey": "plss_flag", "DataType": "BOOLEAN"},
    {"SObjectField": "nepa_risk_score__c", "OutputKey": "litigation_risk_score", "DataType": "DECIMAL"},
    {"SObjectField": "nepa_risk_tier__c", "OutputKey": "litigation_risk_tier", "DataType": "STRING"},
    {"SObjectField": "nepa_risk_score_factors__c", "OutputKey": "risk_score_factors", "DataType": "STRING"},
    {"SObjectField": "nepa_predicted_challenge_grounds__c", "OutputKey": "predicted_challenge_grounds", "DataType": "STRING"},
    {"SObjectField": "nepa_defensibility_score__c", "OutputKey": "defensibility_score", "DataType": "DECIMAL"},
    {"SObjectField": "nepa_defensibility_gaps__c", "OutputKey": "defensibility_gaps", "DataType": "STRING"},
    {"SObjectField": "nepa_start_date__c", "OutputKey": "start_date", "DataType": "DATE"},
    {"SObjectField": "nepa_completion_date__c", "OutputKey": "completion_date", "DataType": "DATE"},
    {"SObjectField": "nepa_public_comment_period_start__c", "OutputKey": "public_comment_period_start", "DataType": "DATE"},
    {"SObjectField": "nepa_public_comment_period_end_date__c", "OutputKey": "public_comment_period_end", "DataType": "DATE"},
    {"SObjectField": "nepa_record_completeness__c", "OutputKey": "record_completeness_score", "DataType": "DECIMAL"},
    {"SObjectField": "nepa_joint_lead_agency__c", "OutputKey": "joint_lead_agency", "DataType": "STRING"},
    {"SObjectField": "nepa_cooperating_agencies__c", "OutputKey": "cooperating_agencies", "DataType": "STRING"},
    {"SObjectField": "nepa_data_record_version__c", "OutputKey": "data_record_version", "DataType": "STRING"},
    {"SObjectField": "nepa_data_source_agency__c", "OutputKey": "data_source_agency", "DataType": "STRING"},
    {"SObjectField": "nepa_record_owner_agency__c", "OutputKey": "record_owner_agency", "DataType": "STRING"},
    {"SObjectField": "nepa_risk_score_updated__c", "OutputKey": "risk_score_updated", "DataType": "DATETIME"},
    {"SObjectField": "LastModifiedDate", "OutputKey": "last_updated", "DataType": "DATETIME"}
  ],
  "ChildRelationships": [
    {
      "RelationshipName": "ContentDocumentLinks",
      "SObjectType": "ContentVersion",
      "WhereClause": "ContentDocumentId IN (SELECT ContentDocumentId FROM ContentDocumentLink WHERE LinkedEntityId = :processId) AND IsLatest = true",
      "OutputPath": "documents",
      "Mappings": [
        {"SObjectField": "Id", "OutputKey": "id", "DataType": "STRING"},
        {"SObjectField": "Title", "OutputKey": "title", "DataType": "STRING"},
        {"SObjectField": "nepa_document_type__c", "OutputKey": "document_type", "DataType": "STRING"},
        {"SObjectField": "nepa_document_stage__c", "OutputKey": "stage", "DataType": "STRING"},
        {"SObjectField": "nepa_review_type__c", "OutputKey": "review_type", "DataType": "STRING"},
        {"SObjectField": "nepa_is_required__c", "OutputKey": "is_required", "DataType": "BOOLEAN"},
        {"SObjectField": "nepa_ai_generated__c", "OutputKey": "ai_generated", "DataType": "BOOLEAN"},
        {"SObjectField": "nepa_agency_citation__c", "OutputKey": "agency_citation", "DataType": "STRING"},
        {"SObjectField": "nepa_record_owner_agency__c", "OutputKey": "record_owner_agency", "DataType": "STRING"},
        {"SObjectField": "ContentSize", "OutputKey": "file_size_bytes", "DataType": "INTEGER"},
        {"SObjectField": "FileExtension", "OutputKey": "file_extension", "DataType": "STRING"},
        {"SObjectField": "CreatedDate", "OutputKey": "uploaded_date", "DataType": "DATETIME"},
        {"SObjectField": "LastModifiedDate", "OutputKey": "last_modified", "DataType": "DATETIME"}
      ]
    },
    {
      "RelationshipName": "Milestones",
      "SObjectType": "ApplicationTimeline",
      "WhereClause": "nepa_related_process__c = :processId ORDER BY nepa_start_date__c ASC",
      "OutputPath": "milestones",
      "Mappings": [
        {"SObjectField": "Id", "OutputKey": "id", "DataType": "STRING"},
        {"SObjectField": "nepa_event_type__c", "OutputKey": "event_type", "DataType": "STRING"},
        {"SObjectField": "nepa_event_description__c", "OutputKey": "description", "DataType": "STRING"},
        {"SObjectField": "nepa_start_date__c", "OutputKey": "start_date", "DataType": "DATE"},
        {"SObjectField": "nepa_end_date__c", "OutputKey": "end_date", "DataType": "DATE"},
        {"SObjectField": "nepa_outcome__c", "OutputKey": "outcome", "DataType": "STRING"},
        {"SObjectField": "nepa_assigned_entity__c", "OutputKey": "assigned_entity", "DataType": "STRING"},
        {"SObjectField": "nepa_public_access__c", "OutputKey": "public_access", "DataType": "BOOLEAN"},
        {"SObjectField": "nepa_data_source_agency__c", "OutputKey": "data_source_agency", "DataType": "STRING"},
        {"SObjectField": "LastModifiedDate", "OutputKey": "last_updated", "DataType": "DATETIME"}
      ]
    },
    {
      "RelationshipName": "Consultations",
      "SObjectType": "nepa_engagement__c",
      "WhereClause": "nepa_related_process__c = :processId",
      "OutputPath": "consultations",
      "Mappings": [
        {"SObjectField": "Id", "OutputKey": "id", "DataType": "STRING"},
        {"SObjectField": "Name", "OutputKey": "name", "DataType": "STRING"},
        {"SObjectField": "nepa_engagement_type__c", "OutputKey": "engagement_type", "DataType": "STRING"},
        {"SObjectField": "nepa_engagement_date__c", "OutputKey": "engagement_date", "DataType": "DATE"},
        {"SObjectField": "nepa_engagement_status__c", "OutputKey": "status", "DataType": "STRING"},
        {"SObjectField": "nepa_entity_type__c", "OutputKey": "entity_type", "DataType": "STRING"},
        {"SObjectField": "nepa_is_tribal__c", "OutputKey": "is_tribal", "DataType": "BOOLEAN"},
        {"SObjectField": "nepa_record_owner_agency__c", "OutputKey": "record_owner_agency", "DataType": "STRING"},
        {"SObjectField": "LastModifiedDate", "OutputKey": "last_updated", "DataType": "DATETIME"}
      ]
    },
    {
      "RelationshipName": "Comments",
      "SObjectType": "PublicComplaint",
      "WhereClause": "nepa_related_process__c = :processId",
      "OutputPath": "public_comments",
      "Mappings": [
        {"SObjectField": "Id", "OutputKey": "id", "DataType": "STRING"},
        {"SObjectField": "Name", "OutputKey": "reference_number", "DataType": "STRING"},
        {"SObjectField": "nepa_comment_type__c", "OutputKey": "comment_type", "DataType": "STRING"},
        {"SObjectField": "nepa_comment_stage__c", "OutputKey": "stage", "DataType": "STRING"},
        {"SObjectField": "nepa_submission_date__c", "OutputKey": "submission_date", "DataType": "DATE"},
        {"SObjectField": "nepa_ai_substantive_recommendation__c", "OutputKey": "ai_substantive_recommendation", "DataType": "STRING"},
        {"SObjectField": "nepa_is_substantive__c", "OutputKey": "is_substantive", "DataType": "BOOLEAN"},
        {"SObjectField": "nepa_sentiment__c", "OutputKey": "ai_sentiment", "DataType": "STRING"},
        {"SObjectField": "nepa_response_status__c", "OutputKey": "response_status", "DataType": "STRING"},
        {"SObjectField": "nepa_requires_human_review__c", "OutputKey": "requires_human_review", "DataType": "BOOLEAN"},
        {"SObjectField": "nepa_is_ej_comment__c", "OutputKey": "is_ej_comment", "DataType": "BOOLEAN"},
        {"SObjectField": "nepa_record_owner_agency__c", "OutputKey": "record_owner_agency", "DataType": "STRING"},
        {"SObjectField": "LastModifiedDate", "OutputKey": "last_updated", "DataType": "DATETIME"}
      ]
    }
  ]
}
