            <stepType>BusinessKnowledgeModel</stepType>
        </steps>
        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>Confidence</assignedParameter>
                <expression>IF( LEN(NEPA_CE_Screener_NAICS__Confidence) &gt; 0, NEPA_CE_Screener_NAICS__Confidence, IF( LEN(NEPA_CE_Screener_Tier1__Confidence) &gt; 0, NEPA_CE_Screener_Tier1__Confidence, IF( LEN(NEPA_CE_Screener_Tier2__Confidence) &gt; 0, NEPA_CE_Screener_Tier2__Confidence, &apos;Low&apos; ) ) )</expression>
