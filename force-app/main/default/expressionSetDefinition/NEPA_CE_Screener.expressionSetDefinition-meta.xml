<?xml version="1.0" encoding="UTF-8"?>
<ExpressionSetDefinition xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>NEPA CE Screener</label>
    <processType>Bre</processType>
    <template>false</template>
    <versions>
        <fullName>NEPA_CE_Screener_V1</fullName>
        <description>CE screening BRE: routes a NEPA project to the correct review type (CE/EA/EIS) based on NAICS code, agency, sector, type key, and action type using a three-tier Decision Matrix lookup. Outputs ReviewType, CECode, Confidence, and ClassificationBasis.</description>
        <expressionSetDefinition>NEPA_CE_Screener</expressionSetDefinition>
        <label>NEPA CE Screener V1</label>
        <processType>Bre</processType>
        <rank>1</rank>
        <shouldShowExplExternally>false</shouldShowExplExternally>
        <startDate>2026-05-01T00:00:00.000Z</startDate>
        <status>Active</status>

        <!-- ═══════════════════════════════════════════════════════
             STEP 1  —  Branch: choose screening path
             Three branches run in parallel priority order:
               Seq 1: NAICS-first path (most projects have NAICS)
               Seq 2: Agency+Sector+Type Tier-1 path
               Seq 3: Agency+ActionType Tier-2 path
             ═══════════════════════════════════════════════════════ -->
        <steps>
            <label>Screening Path Branch</label>
            <name>ScreeningPathBranch</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>1</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>Branch</stepType>
        </steps>

        <!-- ───── Branch 1: NAICS path ───── -->
        <steps>
            <advancedCondition>
                <conditionLogic>1</conditionLogic>
                <criteria>
                    <operator>NotEquals</operator>
                    <sequenceNumber>1</sequenceNumber>
                    <sourceFieldName>NAICSCode</sourceFieldName>
                    <value></value>
                    <valueType>Literal</valueType>
                </criteria>
                <resultParameter>cond_HasNAICS</resultParameter>
            </advancedCondition>
            <label>Has NAICS Code</label>
            <name>HasNAICSCode</name>
            <parentStep>ScreeningPathBranch</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>1</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>AdvancedCondition</stepType>
        </steps>

        <steps>
            <actionType>GetOutputsFromDecisionMatrix</actionType>
            <decisionTable>
                <decisionTableName>NEPA_CE_Screener_NAICS</decisionTableName>
                <type>DecisionMatrix</type>
            </decisionTable>
            <label>NAICS Lookup</label>
            <name>NAICSLookup</name>
            <parentStep>HasNAICSCode</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>1</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>ReviewType</assignedParameter>
                <expression>NEPA_CE_Screener_NAICS__ReviewType</expression>
            </assignment>
            <label>Set Review Type from NAICS</label>
            <name>SetReviewTypeFromNAICS</name>
            <parentStep>HasNAICSCode</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>2</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>CECode</assignedParameter>
                <expression>NEPA_CE_Screener_NAICS__CECode</expression>
            </assignment>
            <label>Set CE Code from NAICS</label>
            <name>SetCECodeFromNAICS</name>
            <parentStep>HasNAICSCode</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>3</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>Confidence</assignedParameter>
                <expression>NEPA_CE_Screener_NAICS__Confidence</expression>
            </assignment>
            <label>Set Confidence from NAICS</label>
            <name>SetConfidenceFromNAICS</name>
            <parentStep>HasNAICSCode</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>4</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>ClassificationBasis</assignedParameter>
                <expression>NEPA_CE_Screener_NAICS__ClassificationBasis</expression>
            </assignment>
            <label>Set Classification Basis from NAICS</label>
            <name>SetClassificationBasisFromNAICS</name>
            <parentStep>HasNAICSCode</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>5</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <!-- ───── Branch 2: Agency + Sector + TypeKey (Tier 1) ───── -->
        <steps>
            <advancedCondition>
                <conditionLogic>1 AND 2 AND 3</conditionLogic>
                <criteria>
                    <operator>Equals</operator>
                    <sequenceNumber>1</sequenceNumber>
                    <sourceFieldName>NAICSCode</sourceFieldName>
                    <value></value>
                    <valueType>Literal</valueType>
                </criteria>
                <criteria>
                    <operator>NotEquals</operator>
                    <sequenceNumber>2</sequenceNumber>
                    <sourceFieldName>AgencyAbbr</sourceFieldName>
                    <value></value>
                    <valueType>Literal</valueType>
                </criteria>
                <criteria>
                    <operator>NotEquals</operator>
                    <sequenceNumber>3</sequenceNumber>
                    <sourceFieldName>SectorKey</sourceFieldName>
                    <value></value>
                    <valueType>Literal</valueType>
                </criteria>
                <resultParameter>cond_Tier1</resultParameter>
            </advancedCondition>
            <label>Agency and Sector Available</label>
            <name>AgencyAndSectorAvailable</name>
            <parentStep>ScreeningPathBranch</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>2</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>AdvancedCondition</stepType>
        </steps>

        <steps>
            <actionType>GetOutputsFromDecisionMatrix</actionType>
            <decisionTable>
                <decisionTableName>NEPA_CE_Screener_Tier1</decisionTableName>
                <type>DecisionMatrix</type>
            </decisionTable>
            <label>Tier 1 Agency Sector Lookup</label>
            <name>Tier1AgencySectorLookup</name>
            <parentStep>AgencyAndSectorAvailable</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>1</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>ReviewType</assignedParameter>
                <expression>NEPA_CE_Screener_Tier1__ReviewType</expression>
            </assignment>
            <label>Set Review Type from Tier1</label>
            <name>SetReviewTypeFromTier1</name>
            <parentStep>AgencyAndSectorAvailable</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>2</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>CECode</assignedParameter>
                <expression>NEPA_CE_Screener_Tier1__CECode</expression>
            </assignment>
            <label>Set CE Code from Tier1</label>
            <name>SetCECodeFromTier1</name>
            <parentStep>AgencyAndSectorAvailable</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>3</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>Confidence</assignedParameter>
                <expression>NEPA_CE_Screener_Tier1__Confidence</expression>
            </assignment>
            <label>Set Confidence from Tier1</label>
            <name>SetConfidenceFromTier1</name>
            <parentStep>AgencyAndSectorAvailable</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>4</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>ClassificationBasis</assignedParameter>
                <expression>NEPA_CE_Screener_Tier1__ClassificationBasis</expression>
            </assignment>
            <label>Set Classification Basis from Tier1</label>
            <name>SetClassificationBasisFromTier1</name>
            <parentStep>AgencyAndSectorAvailable</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>5</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <!-- ───── Branch 3: Agency + ActionType (Tier 2) ───── -->
        <steps>
            <advancedCondition>
                <conditionLogic>1 AND 2 AND 3</conditionLogic>
                <criteria>
                    <operator>Equals</operator>
                    <sequenceNumber>1</sequenceNumber>
                    <sourceFieldName>NAICSCode</sourceFieldName>
                    <value></value>
                    <valueType>Literal</valueType>
                </criteria>
                <criteria>
                    <operator>Equals</operator>
                    <sequenceNumber>2</sequenceNumber>
                    <sourceFieldName>SectorKey</sourceFieldName>
                    <value></value>
                    <valueType>Literal</valueType>
                </criteria>
                <criteria>
                    <operator>NotEquals</operator>
                    <sequenceNumber>3</sequenceNumber>
                    <sourceFieldName>ActionType</sourceFieldName>
                    <value></value>
                    <valueType>Literal</valueType>
                </criteria>
                <resultParameter>cond_Tier2</resultParameter>
            </advancedCondition>
            <label>Action Type Available</label>
            <name>ActionTypeAvailable</name>
            <parentStep>ScreeningPathBranch</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>3</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>AdvancedCondition</stepType>
        </steps>

        <steps>
            <actionType>GetOutputsFromDecisionMatrix</actionType>
            <decisionTable>
                <decisionTableName>NEPA_CE_Screener_Tier2</decisionTableName>
                <type>DecisionMatrix</type>
            </decisionTable>
            <label>Tier 2 Agency Action Type Lookup</label>
            <name>Tier2AgencyActionTypeLookup</name>
            <parentStep>ActionTypeAvailable</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>1</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>ReviewType</assignedParameter>
                <expression>NEPA_CE_Screener_Tier2__ReviewType</expression>
            </assignment>
            <label>Set Review Type from Tier2</label>
            <name>SetReviewTypeFromTier2</name>
            <parentStep>ActionTypeAvailable</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>2</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>CECode</assignedParameter>
                <expression>NEPA_CE_Screener_Tier2__CECode</expression>
            </assignment>
            <label>Set CE Code from Tier2</label>
            <name>SetCECodeFromTier2</name>
            <parentStep>ActionTypeAvailable</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>3</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>Confidence</assignedParameter>
                <expression>NEPA_CE_Screener_Tier2__Confidence</expression>
            </assignment>
            <label>Set Confidence from Tier2</label>
            <name>SetConfidenceFromTier2</name>
            <parentStep>ActionTypeAvailable</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>4</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>ClassificationBasis</assignedParameter>
                <expression>NEPA_CE_Screener_Tier2__ClassificationBasis</expression>
            </assignment>
            <label>Set Classification Basis from Tier2</label>
            <name>SetClassificationBasisFromTier2</name>
            <parentStep>ActionTypeAvailable</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>5</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <!-- ═══════════════════════════════════════════════════════
             STEP 2  —  Acreage override: if DisturbanceAcres exceeds
             the T2_HighAcreage threshold, force EA regardless of
             any CE assignment already set.
             ═══════════════════════════════════════════════════════ -->
        <steps>
            <label>Acreage Override Branch</label>
            <name>AcreageOverrideBranch</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>2</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>Branch</stepType>
        </steps>

        <steps>
            <advancedCondition>
                <conditionLogic>1 AND 2</conditionLogic>
                <criteria>
                    <operator>GreaterThan</operator>
                    <sequenceNumber>1</sequenceNumber>
                    <sourceFieldName>DisturbanceAcres</sourceFieldName>
                    <value>CONST_AcreageThreshold</value>
                    <valueType>Parameter</valueType>
                </criteria>
                <criteria>
                    <operator>Equals</operator>
                    <sequenceNumber>2</sequenceNumber>
                    <sourceFieldName>ReviewType</sourceFieldName>
                    <value>CE</value>
                    <valueType>Literal</valueType>
                </criteria>
                <resultParameter>cond_AcreageExceeded</resultParameter>
            </advancedCondition>
            <label>Acreage Exceeds CE Threshold</label>
            <name>AcreageExceedsCEThreshold</name>
            <parentStep>AcreageOverrideBranch</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>1</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>AdvancedCondition</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>ReviewType</assignedParameter>
                <expression>EA</expression>
            </assignment>
            <label>Override to EA for High Acreage</label>
            <name>OverrideToEAForHighAcreage</name>
            <parentStep>AcreageExceedsCEThreshold</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>1</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>CECode</assignedParameter>
                <expression></expression>
            </assignment>
            <label>Clear CE Code on Acreage Override</label>
            <name>ClearCECodeOnAcreageOverride</name>
            <parentStep>AcreageExceedsCEThreshold</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>2</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>Confidence</assignedParameter>
                <expression>Low</expression>
            </assignment>
            <label>Set Low Confidence on Acreage Override</label>
            <name>SetLowConfidenceOnAcreageOverride</name>
            <parentStep>AcreageExceedsCEThreshold</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>3</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>ClassificationBasis</assignedParameter>
                <expression>&apos;Acreage threshold exceeded (&apos; &amp; TEXT(DisturbanceAcres) &amp; &apos; acres &gt; &apos; &amp; TEXT(CONST_AcreageThreshold) &amp; &apos; acre CE limit); escalated to EA&apos;</expression>
            </assignment>
            <label>Set Acreage Override Basis</label>
            <name>SetAcreageOverrideBasis</name>
            <parentStep>AcreageExceedsCEThreshold</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>4</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <!-- ═══════════════════════════════════════════════════════
             STEP 3  —  Default fallback: if no path matched, output
             EA with Low confidence (conservative).
             ═══════════════════════════════════════════════════════ -->
        <steps>
            <label>Default Fallback Branch</label>
            <name>DefaultFallbackBranch</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>3</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
