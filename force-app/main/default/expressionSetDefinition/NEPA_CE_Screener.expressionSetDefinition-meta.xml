    <versions>
        <fullName>NEPA_CE_Screener_V3</fullName>
        <description>CE screening BRE V3: uses LEN()&gt;0 guards instead of !=null to correctly handle empty-string DM lookup results. Routes to CE/EA/EIS via three-tier DM lookup with acreage override and no-match EA fallback.</description>
        <expressionSetDefinition>NEPA_CE_Screener</expressionSetDefinition>
        <label>NEPA CE Screener V3</label>
        <processType>Bre</processType>
        <rank>3</rank>
        <shouldShowExplExternally>false</shouldShowExplExternally>
        <startDate>2026-05-08T00:00:00.000Z</startDate>
        <status>Active</status>
        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>ReviewType</assignedParameter>
                <expression>IF( ReviewType == &apos;CE&apos; &amp;&amp; DisturbanceAcres &gt; CONST_AcreageThreshold, &apos;EA&apos;, IF( LEN(ReviewType) &gt; 0, ReviewType, &apos;EA&apos; ) )</expression>
            </assignment>
            <label>Apply Acreage Override</label>
            <name>ApplyAcreageOverride</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>8</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>
        <steps>
            <actionType>AssignParameterValues</actionType>
