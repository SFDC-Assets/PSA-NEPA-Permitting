                <assignedParameter>CECode</assignedParameter>
                <expression>IF( ReviewType == &apos;CE&apos;, CECode, &apos;&apos; )</expression>
            </assignment>
            <label>Clear CE Code on Non-CE</label>
            <name>ClearCECodeOnNonCE</name>
