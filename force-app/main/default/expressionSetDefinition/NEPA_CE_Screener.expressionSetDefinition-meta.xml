            </assignment>
            <label>Default Confidence to Low</label>
            <name>DefaultConfidenceToLow</name>
            <parentStep>NoScreeningMatch</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>2</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>ClassificationBasis</assignedParameter>
                <expression>No screening rule matched provided inputs; defaulted to EA for manual review</expression>
            </assignment>
            <label>Default Classification Basis</label>
            <name>DefaultClassificationBasis</name>
            <parentStep>NoScreeningMatch</parentStep>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>3</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <!-- ═══════════════════════════════════════════════════════
             STEP 4  —  Output: expose final determination
             ═══════════════════════════════════════════════════════ -->
        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>ReviewType</assignedParameter>
                <expression>ReviewType</expression>
            </assignment>
            <label>Output Screening Result</label>
            <name>OutputScreeningResult</name>
            <resultIncluded>true</resultIncluded>
            <sequenceNumber>4</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <!-- ══════════════════════ VARIABLES ══════════════════════ -->

        <!-- Input variables -->
        <variables>
            <collection>false</collection>
            <dataType>Text</dataType>
            <decimalPlaces>2</decimalPlaces>
            <description>Agency abbreviation (BLM, DOE, USFS, etc.)</description>
            <input>true</input>
            <name>AgencyAbbr</name>
            <output>false</output>
            <type>Variable</type>
