            <stepType>BusinessKnowledgeModel</stepType>
        </steps>
        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>CECode</assignedParameter>
                <expression>IF( LEN(NEPA_CE_Screener_NAICS__CECode) &gt; 0, NEPA_CE_Screener_NAICS__CECode, IF( LEN(NEPA_CE_Screener_Tier1__CECode) &gt; 0, NEPA_CE_Screener_Tier1__CECode, IF( LEN(NEPA_CE_Screener_Tier2__CECode) &gt; 0, NEPA_CE_Screener_Tier2__CECode, &apos;&apos; ) ) )</expression>
            </assignment>
            <label>Consolidate CE Code</label>
            <name>ConsolidateCECode</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>5</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
