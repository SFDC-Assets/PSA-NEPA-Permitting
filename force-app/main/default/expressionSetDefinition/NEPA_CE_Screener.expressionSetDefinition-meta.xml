            <stepType>BusinessKnowledgeModel</stepType>
        </steps>
        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>ClassificationBasis</assignedParameter>
                <expression>IF( LEN(NEPA_CE_Screener_NAICS__ClassificationBasis) &gt; 0, NEPA_CE_Screener_NAICS__ClassificationBasis, IF( LEN(NEPA_CE_Screener_Tier1__ClassificationBasis) &gt; 0, NEPA_CE_Screener_Tier1__ClassificationBasis, IF( LEN(NEPA_CE_Screener_Tier2__ClassificationBasis) &gt; 0, NEPA_CE_Screener_Tier2__ClassificationBasis, &apos;No screening rule matched; defaulted to EA for manual review&apos; ) ) )</expression>
            </assignment>
            <label>Consolidate Classification Basis</label>
            <name>ConsolidateClassificationBasis</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>7</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
