        <fullName>NEPA_Litigation_Risk_Scorer_V1</fullName>
        <description>Composite litigation risk scoring: ReviewType + Agency + Circuit + SectorCircuit DM lookups; statute points passed as pre-computed flow input; 1.5x expedited multiplier when record is incomplete; cap at 100; tier assignment.</description>
        <expressionSetDefinition>NEPA_Litigation_Risk_Scorer</expressionSetDefinition>
        <label>NEPA Litigation Risk Scorer V1</label>
        <processType>Bre</processType>
        <rank>1</rank>
        <shouldShowExplExternally>false</shouldShowExplExternally>
        <startDate>2026-05-20T00:00:00.000Z</startDate>
        <status>Active</status>
        <steps>
            <actionType>GetOutputsFromDecisionMatrix</actionType>
            <decisionTable>
                <decisionTableName>NEPA_Risk_Agency</decisionTableName>
                <type>DecisionMatrix</type>
            </decisionTable>
            <label>Agency Risk Points Lookup</label>
            <name>AgencyRiskPointsLookup</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>2</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>
        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>RiskScore</assignedParameter>
                <expression>IF( IsExpedited &amp;&amp; RecordCompleteness &lt; 100, RawScore * 1.5, RawScore )</expression>
            </assignment>
            <label>Apply Expedited Multiplier</label>
            <name>ApplyExpeditedMultiplier</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>7</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>
        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>RiskTier</assignedParameter>
                <expression>IF( RiskScore &gt;= 58, &apos;Very High&apos;, IF( RiskScore &gt;= 45, &apos;High&apos;, IF( RiskScore &gt;= 35, &apos;Moderate&apos;, &apos;Low&apos; ) ) )</expression>
            </assignment>
            <label>Assign Risk Tier</label>
            <name>AssignRiskTier</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>10</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>
        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>RiskScore</assignedParameter>
                <expression>IF( RiskScore &gt; 100, 100, RiskScore )</expression>
            </assignment>
            <label>Cap Score at 100</label>
            <name>CapScoreAt100</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>9</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>
        <steps>
            <actionType>GetOutputsFromDecisionMatrix</actionType>
