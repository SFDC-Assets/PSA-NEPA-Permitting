        <!-- Step 4: NEW — Sector-circuit DM lookup (V3 addition) -->
        <steps>
            <actionType>GetOutputsFromDecisionMatrix</actionType>
            <decisionTable>
                <decisionTableName>NEPA_Risk_SectorCircuit</decisionTableName>
                <type>DecisionMatrix</type>
            </decisionTable>
            <label>Sector Circuit Risk Lookup</label>
            <name>SectorCircuitRiskLookup</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>4</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <!-- Step 5: NEW — Compute V2 composite terms: ScopingTerm + SectorCircuitTerm.
             ScopingTerm = 0.15×ScopingOverrunFlag + 0.10×MIN(ScopingOverrunMonths/48, 1.0)
             SectorCircuitTerm = 0.20×(1−WinRatePct/100) × DataQuality × 100
             DataQuality = IF(CaseCount≥3, 1.0, 0.5)
             VALUE() required for Text-typed DM binding vars. -->
        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>V2Terms</assignedParameter>
                <expression>( 0.15 * IF(ScopingOverrunFlag, 1, 0) + 0.10 * MIN(ScopingOverrunMonths / 48, 1.0) ) * 100 + ( 0.20 * (1 - VALUE(NEPA_Risk_SectorCircuit__WinRatePct) / 100) * IF(VALUE(NEPA_Risk_SectorCircuit__CaseCount) &gt;= 3, 1.0, 0.5) ) * 100</expression>
            </assignment>
            <label>Compute V2 Composite Terms</label>
            <name>ComputeV2Terms</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>5</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <!-- Step 6: Sum all components including V2 terms -->
        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>RawScore</assignedParameter>
                <expression>VALUE(NEPA_Risk_ReviewType__Points) + VALUE(NEPA_Risk_Agency__Points) + VALUE(NEPA_Risk_Circuit__Points) + StatutePoints + ChallengeDelta + V2Terms</expression>
            </assignment>
            <label>Sum Risk Components V3</label>
            <name>SumRiskComponentsV3</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>6</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>

        <!-- Step 7: Apply 1.5x APA expedited multiplier when record is incomplete -->
        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>RiskScore</assignedParameter>
                <expression>IF( IsExpedited &amp;&amp; RecordCompleteness &lt; 100, RawScore * 1.5, RawScore )</expression>
            </assignment>
            <label>Apply Expedited Multiplier</label>
            <name>ApplyExpeditedMultiplier</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>7</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
