    <!-- V3: Adds sector-circuit DM lookup + composite V2 terms (scoping overrun + sector-circuit risk).
         Deploy as Draft. Activate after sandbox validation of NEPA_Risk_SectorCircuit DM rows.
         V2 remains Active during transition. -->
    <versions>
        <fullName>NEPA_Litigation_Risk_Scorer_V3</fullName>
        <description>Composite litigation risk scoring V3: adds GetSectorCircuitRisk DM lookup and ComputeV2Terms (ScopingTerm + SectorCircuitTerm). ScopingTerm = 0.15×ScopingOverrunFlag + 0.10×MIN(ScopingOverrunMonths/48,1.0). SectorCircuitTerm = 0.20×(1−WinRatePct/100)×IF(CaseCount≥3,1.0,0.5) × 100. All other steps carried forward from V2.</description>
        <expressionSetDefinition>NEPA_Litigation_Risk_Scorer</expressionSetDefinition>
        <label>NEPA Litigation Risk Scorer V3</label>
        <processType>Bre</processType>
        <rank>3</rank>
        <shouldShowExplExternally>false</shouldShowExplExternally>
        <startDate>2026-05-13T00:00:00.000Z</startDate>
        <status>Draft</status>

        <!-- Step 1: Review Type points lookup -->
        <steps>
            <actionType>GetOutputsFromDecisionMatrix</actionType>
            <decisionTable>
                <decisionTableName>NEPA_Risk_ReviewType</decisionTableName>
                <type>DecisionMatrix</type>
            </decisionTable>
            <label>Review Type Points Lookup</label>
            <name>ReviewTypePointsLookup</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>1</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
