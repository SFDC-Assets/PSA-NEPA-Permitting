            <stepType>BusinessKnowledgeModel</stepType>
        </steps>
        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>AIConfidence</assignedParameter>
                <expression>40 + ( IF( NEPA_Risk_Agency__MatchScore &gt;= 1, 20, 0 ) ) + ( IF( NEPA_Risk_Circuit__MatchScore &gt;= 1, 20, 0 ) ) + ( IF( NEPA_Risk_SectorCircuit__CaseCount &gt;= 3, 20, 0 ) )</expression>
            </assignment>
            <label>Compute AI Confidence</label>
            <name>ComputeAIConfidence</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>11</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
            <shouldExposeConditionDetails>false</shouldExposeConditionDetails>
            <shouldShowExplExternally>false</shouldShowExplExternally>
            <stepType>BusinessKnowledgeModel</stepType>
        </steps>
        <steps>
            <actionType>AssignParameterValues</actionType>
            <assignment>
                <assignedParameter>V2Terms</assignedParameter>
                <expression>( 0.15 * IF(ScopingOverrunFlag, 1, 0) + 0.10 * MIN(ScopingOverrunMonths / 48, 1.0) ) * 100 + ( 0.20 * (1 - NEPA_Risk_SectorCircuit__WinRatePct / 100) * IF(NEPA_Risk_SectorCircuit__CaseCount &gt;= 3, 1.0, 0.5) ) * 100</expression>
            </assignment>
            <label>Compute V2 Composite Terms</label>
            <name>ComputeV2Terms</name>
            <resultIncluded>false</resultIncluded>
            <sequenceNumber>5</sequenceNumber>
            <shouldExposExecPathMsgOnly>true</shouldExposExecPathMsgOnly>
